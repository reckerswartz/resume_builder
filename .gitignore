# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore generated dependency directories.
node_modules/
vendor/bundle/
/package-lock.json
/.yarn/*
!/.yarn/patches
!/.yarn/plugins
!/.yarn/releases
!/.yarn/sdks
!/.yarn/versions

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets
/docs/template_audits/artifacts/
/docs/templates/*.pdf

# Audit run logs (ephemeral per-execution chronicles — registries hold cumulative state)
docs/*/runs/
docs/*/*/runs/
docs/*/*/*/runs/

# Historical one-time audit snapshots (superseded by ongoing audit pages)
/docs/ui_audits/2026-03-20/

# Scaffolding templates (not source code)
docs/*/areas/TEMPLATE.md
docs/*/*/areas/TEMPLATE.md
docs/*/*/pages/TEMPLATE.md
docs/*/*/*/pages/TEMPLATE.md

# Playwright and audit artifacts (generated locally)
/tmp/ui_audit_artifacts/
/tmp/reference_captures/
/tmp/reference_artifacts/
/tmp/playwright-sessions/
/tmp/playwright-audit/
/tmp/meta_learning/

# Ignore key files for decrypting credentials and more.
/config/*.key


/app/assets/builds/*
!/app/assets/builds/.keep
