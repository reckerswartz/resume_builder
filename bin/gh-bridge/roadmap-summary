#!/usr/bin/env bash
# Generates a Markdown roadmap summary from all open GitHub issues.
# Groups by workflow, domain, and severity.
#
# Usage: bin/gh-bridge/roadmap-summary [--output "docs/github_ops/roadmap.md"]
#
# Outputs: Markdown roadmap to stdout or to the specified file.

set -euo pipefail

OUTPUT=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --output) OUTPUT="$2"; shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

REPO="${GH_REPO:-$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null)}"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

generate_roadmap() {
  echo "# Resume Builder Roadmap"
  echo ""
  echo "> Auto-generated from GitHub issues on ${TIMESTAMP}"
  echo "> Repository: ${REPO}"
  echo ""

  # Total counts
  TOTAL_OPEN=$(gh issue list --repo "$REPO" --state open --json number -q 'length' 2>/dev/null || echo "0")
  TOTAL_CLOSED=$(gh issue list --repo "$REPO" --state closed --json number --limit 1000 -q 'length' 2>/dev/null || echo "0")
  echo "## Summary"
  echo ""
  echo "- **Open issues**: ${TOTAL_OPEN}"
  echo "- **Closed issues**: ${TOTAL_CLOSED}"
  echo ""

  # By severity
  echo "## By Severity"
  echo ""
  for sev in critical high medium low; do
    COUNT=$(gh issue list --repo "$REPO" --state open --label "severity:${sev}" --json number -q 'length' 2>/dev/null || echo "0")
    echo "- **${sev}**: ${COUNT} open"
  done
  echo ""

  # By workflow
  echo "## By Workflow"
  echo ""
  for wf in template-audit responsive-ui-audit ui-guidelines-audit ux-usability-audit maintainability-audit security-audit code-review behance-template-rollout behance-template-implementation resumebuilder-reference-rollout feature-spec feature-plan tdd-red-agent implementation-agent tdd-refactoring-agent rspec-agent c4-architecture smart-fix; do
    COUNT=$(gh issue list --repo "$REPO" --state open --label "workflow:${wf}" --json number -q 'length' 2>/dev/null || echo "0")
    if [ "$COUNT" -gt 0 ]; then
      echo "### \`/${wf}\` (${COUNT} open)"
      echo ""
      gh issue list --repo "$REPO" --state open --label "workflow:${wf}" --json number,title,labels --template '{{range .}}- #{{.number}} {{.title}}
{{end}}' 2>/dev/null || true
      echo ""
    fi
  done

  # By domain
  echo "## By Domain"
  echo ""
  for dom in templates builder workspace admin auth photos llm i18n infrastructure docs marketplace security testing; do
    COUNT=$(gh issue list --repo "$REPO" --state open --label "domain:${dom}" --json number -q 'length' 2>/dev/null || echo "0")
    if [ "$COUNT" -gt 0 ]; then
      echo "- **${dom}**: ${COUNT} open"
    fi
  done
  echo ""

  # Recently closed (last 10)
  echo "## Recently Closed"
  echo ""
  gh issue list --repo "$REPO" --state closed --limit 10 --json number,title,closedAt --template '{{range .}}- #{{.number}} {{.title}} (closed {{.closedAt}})
{{end}}' 2>/dev/null || echo "_No closed issues yet._"
  echo ""

  echo "---"
  echo "_Generated by \`bin/gh-bridge/roadmap-summary\` at ${TIMESTAMP}_"
}

if [ -n "$OUTPUT" ]; then
  mkdir -p "$(dirname "$OUTPUT")"
  generate_roadmap > "$OUTPUT"
  echo "Roadmap written to ${OUTPUT}"
else
  generate_roadmap
fi
