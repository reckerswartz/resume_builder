#!/usr/bin/env bash
# Creates the full GitHub label taxonomy for workflow integration.
# Idempotent: skips labels that already exist.
#
# Usage: bin/gh-bridge/ensure-labels

set -euo pipefail

REPO="${GH_REPO:-$(gh repo view --json nameWithOwner -q '.nameWithOwner' 2>/dev/null)}"

if [ -z "$REPO" ]; then
  echo "ERROR: Could not determine repository. Set GH_REPO or run from a git repo with a GitHub remote." >&2
  exit 1
fi

create_label() {
  local name="$1"
  local color="$2"
  local description="${3:-}"

  if gh label list --repo "$REPO" --search "$name" --json name -q '.[].name' 2>/dev/null | grep -qx "$name"; then
    return 0
  fi

  gh label create "$name" --repo "$REPO" --color "$color" --description "$description" 2>/dev/null || true
}

echo "Syncing labels to $REPO..."

# Workflow labels (blue family)
