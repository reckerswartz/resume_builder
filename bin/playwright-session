#!/usr/bin/env node

/**
 * Playwright Session CLI
 *
 * Thin wrapper around PlaywrightSessionManager for workflow invocation.
 * Delegates all work to .github/scripts/playwright-session-manager.mjs.
 *
 * Usage:
 *   bin/playwright-session --action=create --workflow-id=template-audit --issue-id=SAC-003
 *   bin/playwright-session --action=audit --workflow-id=responsive-ui-audit --pages=/resumes,/templates --login=demo@resume-builder.local:password123!
 *   bin/playwright-session --action=help
 */

import { fileURLToPath } from "url";
import { dirname, resolve } from "path";

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Import and run the session manager CLI
const managerPath = resolve(__dirname, "../.github/scripts/playwright-session-manager.mjs");
const { PlaywrightSessionManager } = await import(managerPath);

// Re-export for programmatic use
export { PlaywrightSessionManager };
