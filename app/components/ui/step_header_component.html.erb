<div class="flex flex-col gap-4 border-b border-canvas-200/80 bg-canvas-100/84 px-6 py-6 lg:flex-row lg:items-start lg:justify-between">
  <div>
    <h3 class="text-xl font-semibold tracking-tight text-ink-950"><%= title %></h3>
    <% if description.present? %>
      <p class="mt-1 max-w-2xl text-sm text-ink-700/80"><%= description %></p>
    <% end %>
  </div>

  <% if content? %>
    <div class="<%= resolved_aside_classes %>">
      <%= content %>
    </div>
  <% end %>
</div>
