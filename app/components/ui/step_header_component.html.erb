<div class="flex flex-col gap-4 border-b border-slate-200 bg-slate-50/80 px-6 py-6 lg:flex-row lg:items-start lg:justify-between">
  <div>
    <h3 class="text-xl font-semibold tracking-tight text-slate-900"><%= title %></h3>
    <% if description.present? %>
      <p class="mt-1 max-w-2xl text-sm text-slate-600"><%= description %></p>
    <% end %>
  </div>

  <% if content? %>
    <div class="<%= resolved_aside_classes %>">
      <%= content %>
    </div>
  <% end %>
</div>
