<div class="min-h-screen text-ink-950">
  <header class="relative z-10 border-b border-white/10 bg-ink-950/55 backdrop-blur-xl">
    <div class="mx-auto flex max-w-[100rem] flex-wrap items-center justify-between gap-3 px-4 py-3.5 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3">
        <div class="relative flex h-10 w-10 items-center justify-center overflow-hidden rounded-[1.15rem] border border-white/12 bg-white/6 text-sm font-semibold tracking-[0.18em] text-white shadow-[0_16px_30px_rgba(2,6,23,0.24)]">
          <div class="absolute inset-0 atelier-glow opacity-90"></div>
          <span class="relative">RB</span>
        </div>

        <div>
          <%= link_to "Resume Builder", brand_destination, class: "text-lg font-semibold tracking-tight text-white" %>
          <p class="text-xs text-white/55"><%= brand_supporting_text %></p>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <% header_items.each do |item| %>
          <%= link_to item.fetch(:label), item.fetch(:path), class: header_link_classes(item.fetch(:active)) %>
        <% end %>

        <% if authenticated? %>
          <span class="hidden rounded-full border border-white/10 bg-white/6 px-3 py-1.5 text-sm text-white/72 backdrop-blur-sm lg:inline-flex"><%= current_user&.email_address %></span>
          <%= button_to "Sign out", helpers.session_path, method: :delete, form_class: "inline-flex", class: helpers.ui_button_classes(:hero_primary, size: :sm) %>
        <% else %>
          <%= link_to "Create account", helpers.new_registration_path, class: helpers.ui_button_classes(:hero_primary, size: :sm) %>
        <% end %>
      </div>
    </div>
  </header>

  <div class="<%= wrapper_classes %>">
    <% if authenticated? %>
      <aside class="app-shell-sidebar hidden xl:block xl:flex-none">
        <div class="sticky top-5 space-y-3.5">
          <%= render Ui::SurfaceCardComponent.new(tone: :brand, padding: :sm) do %>
            <div class="absolute -right-10 -top-10 h-32 w-32 rounded-full atelier-glow opacity-70"></div>
            <div class="absolute left-5 right-5 top-[4.5rem] h-px atelier-rule opacity-55"></div>

            <div class="relative flex items-start gap-3">
              <div class="flex h-12 w-12 items-center justify-center rounded-[1.35rem] border border-white/12 bg-white/8 text-sm font-semibold tracking-[0.18em] text-white shadow-inner shadow-white/10">
                <%= current_user&.email_address.to_s.first(2).upcase %>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/60"><%= admin? ? "Admin account" : "Signed-in shell" %></p>
                <p class="mt-2 text-base font-semibold tracking-tight text-white"><%= current_area_label %></p>
                <p class="mt-2 text-sm text-white/72"><%= current_area_description %></p>
                <p class="mt-2 text-xs text-white/65"><%= current_user&.email_address %></p>
              </div>
            </div>

            <div class="relative mt-5 flex flex-wrap gap-2">
              <% current_area_badges.each do |badge| %>
                <span class="<%= helpers.ui_badge_classes(:hero) %>"><%= badge %></span>
              <% end %>
            </div>
          <% end %>

          <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :sm) do %>
            <div class="absolute inset-x-4 top-0 h-px atelier-rule-ink opacity-70"></div>
            <p class="relative px-1 text-xs font-semibold uppercase tracking-[0.24em] text-ink-700/70">Workspace navigation</p>
            <div class="mt-4 flex flex-col gap-3">
              <% sidebar_items.each do |item| %>
                <%= link_to item.fetch(:path), class: sidebar_link_classes(item.fetch(:active)) do %>
                  <span class="block text-sm font-semibold"><%= item.fetch(:label) %></span>
                  <% if item[:caption].present? %>
                    <span class="mt-1 block text-xs <%= item.fetch(:active) ? 'text-white/68' : 'text-ink-700/70' %>"><%= item.fetch(:caption) %></span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </aside>
    <% end %>

    <main class="<%= main_classes %>">
      <%= content %>
    </main>
  </div>
</div>
