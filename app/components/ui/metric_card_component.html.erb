<div class="<%= hero? ? 'rounded-[1.6rem] border border-white/10 bg-white/6 p-4 text-white backdrop-blur-sm shadow-[0_16px_40px_rgba(2,6,23,0.2)]' : 'rounded-[1.6rem] border border-canvas-200/80 bg-canvas-50/92 p-5 shadow-[0_18px_44px_rgba(15,23,42,0.08)] backdrop-blur-sm' %>">
  <p class="<%= hero? ? 'text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-white/60' : 'text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/60' %>"><%= label %></p>
  <p class="<%= hero? ? 'mt-3 text-3xl font-semibold tracking-tight text-white' : 'mt-3 text-2xl font-semibold tracking-tight text-ink-950' %>"><%= value %></p>
  <p class="<%= hero? ? 'mt-2 text-sm text-white/62' : 'mt-2 text-sm text-ink-700/80' %>"><%= description %></p>
</div>
