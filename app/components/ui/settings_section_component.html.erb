<section id="<%= anchor %>" class="scroll-mt-24 <%= wrapper_classes %>">
  <div class="flex flex-col gap-4 border-b border-slate-200 pb-4 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0 flex-1">
      <% if eyebrow.present? %>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500"><%= eyebrow %></p>
      <% end %>

      <h2 class="mt-2 text-xl font-semibold tracking-tight text-slate-900"><%= title %></h2>

      <% if description.present? %>
        <p class="mt-2 text-sm text-slate-500"><%= description %></p>
      <% end %>
    </div>

    <% if badges.any? %>
      <div class="flex flex-wrap gap-2 text-xs font-medium">
        <% badges.each do |badge| %>
          <span class="<%= helpers.ui_badge_classes(badge.fetch(:tone, :neutral)) %>"><%= badge.fetch(:label) %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if content? %>
    <div class="<%= content_classes %>">
      <%= content %>
    </div>
  <% end %>
</section>
