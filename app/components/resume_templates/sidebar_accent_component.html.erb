<div class="<%= [shell_classes, "overflow-hidden"].join(" ") %>">
  <div class="sidebar-accent-layout grid gap-0">
    <div class="<%= ["px-6 py-6 sm:px-8 sm:py-8 lg:col-span-1", (sidebar_left? ? "lg:order-2" : "lg:order-1")].join(" ") %>">
      <% if resume.summary.present? %>
        <section class="rounded-2xl border px-5 py-5" style="border-color: <%= accent_color_with_alpha("22") %>; background-color: <%= accent_color_with_alpha("05") %>;;">
          <div class="flex items-center gap-4">
            <h2 class="<%= [section_title_text_class, "font-semibold tracking-tight text-slate-900"].join(" ") %>">Profile</h2>
            <span class="h-px flex-1" style="background-color: <%= accent_color_with_alpha("33") %>;"></span>
          </div>
          <p class="<%= [summary_margin_top_class, body_text_class, relaxed_body_leading_class, "text-slate-700"].join(" ") %>"><%= resume.summary %></p>
        </section>
      <% end %>

      <div class="<%= resume.summary.present? ? section_stack_classes : section_stack_spacing_class(fallback: "space-y-8") %>">
        <% main_sections.each do |section| %>
          <% entries = section_entries(section) %>
          <section>
            <div class="<%= [section_heading_spacing_class, "flex items-center gap-4"].join(" ") %>">
              <h2 class="<%= [section_title_text_class, "font-semibold tracking-tight text-slate-900"].join(" ") %>"><%= section.title %></h2>
              <span class="h-px flex-1" style="background-color: <%= accent_color_with_alpha("33") %>;"></span>
            </div>

            <% if section.section_type == "skills" %>
              <p class="<%= [body_text_class, relaxed_body_leading_class, "text-slate-700"].join(" ") %>"><%= inline_skill_summary(section) %></p>
            <% else %>
              <div class="<%= entry_stack_classes %>">
                <% entries.each do |entry| %>
                  <% subtitle = entry_subtitle(entry) %>
                  <% date_range = date_range_for(entry) %>
                  <% location = entry_location(entry) %>
                  <% highlights = entry_highlights(entry) %>
                  <% url = entry_url(entry) %>
                  <article class="border-b border-slate-200 pb-5">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <h3 class="<%= [entry_title_text_class, "font-semibold text-slate-900"].join(" ") %>"><%= entry_title(entry) %></h3>
                        <% if subtitle.present? %>
                          <p class="<%= ["mt-1", meta_text_class, "text-slate-600"].join(" ") %>"><%= subtitle %></p>
                        <% end %>
                      </div>

                      <% if date_range.present? || location.present? %>
                        <div class="<%= [meta_text_class, "text-slate-500 sm:text-right"].join(" ") %>">
                          <% if date_range.present? %>
                            <div><%= date_range %></div>
                          <% end %>
                          <% if location.present? %>
                            <div class="mt-1"><%= location %></div>
                          <% end %>
                        </div>
                      <% end %>
                    </div>

                    <% entry_body_paragraphs(entry).each do |paragraph| %>
                      <p class="<%= [entry_body_spacing_class, body_text_class, body_leading_class, "text-slate-700"].join(" ") %>"><%= paragraph %></p>
                    <% end %>

                    <% if highlights.any? %>
                      <ul class="<%= [entry_body_spacing_class, body_text_class, body_leading_class, "space-y-2 text-slate-700"].join(" ") %>">
                        <% highlights.each do |highlight| %>
                          <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full" style="background-color: <%= accent_color %>;"></span><span><%= highlight %></span></li>
                        <% end %>
                      </ul>
                    <% end %>

                    <% if url.present? %>
                      <p class="<%= [entry_body_spacing_class, meta_text_class, "text-slate-600"].join(" ") %>"><%= url %></p>
                    <% end %>
                  </article>
                <% end %>
              </div>
            <% end %>
          </section>
        <% end %>
      </div>
    </div>

    <aside class="<%= ["px-6 py-6 sm:px-8 sm:py-8 lg:col-span-1", (sidebar_left? ? "lg:order-1 border-r" : "lg:order-2 border-l")].join(" ") %>" style="background-color: <%= accent_color_with_alpha("15") %>; border-color: <%= accent_color_with_alpha("22") %>;">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em]" style="color: <%= accent_color %>;"><%= template.name %></p>
        <h1 class="<%= ["mt-3", name_text_class, "font-semibold tracking-tight text-slate-900"].join(" ") %>"><%= full_name %></h1>
        <% if resume.headline.present? %>
          <p class="<%= ["mt-2", headline_text_class, "text-slate-600"].join(" ") %>"><%= resume.headline %></p>
        <% end %>
      </div>

      <% if contact_items.any? %>
        <section class="<%= section_margin_top_class(fallback: "mt-8") %>">
          <h2 class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Contact</h2>
          <div class="<%= [section_content_margin_top_class(fallback: "mt-4"), compact_section_stack_classes(fallback: "space-y-3")].join(" ") %>">
            <% contact_items.each do |label, value| %>
              <div>
                <p class="<%= [meta_text_class, "font-medium text-slate-900"].join(" ") %>"><%= label %></p>
                <p class="<%= [body_text_class, "text-slate-700"].join(" ") %>"><%= value %></p>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <% sidebar_sections.each do |section| %>
        <% entries = section_entries(section) %>
        <section class="<%= section_margin_top_class(fallback: "mt-8") %>">
          <h2 class="text-xs font-semibold uppercase tracking-[0.24em]" style="color: <%= accent_color %>;"><%= section.title %></h2>

          <% if section.section_type == "skills" %>
            <div class="<%= [section_content_margin_top_class(fallback: "mt-4"), "flex flex-wrap gap-2"].join(" ") %>">
              <% entries.each do |entry| %>
                <span class="<%= [chip_text_class, "rounded-full border px-3 py-1.5 text-slate-700"].join(" ") %>" style="border-color: <%= accent_color_with_alpha("22") %>; background-color: <%= accent_color_with_alpha("08") %>;">
                  <span class="font-medium text-slate-900"><%= value_for(entry, "name") %></span>
                  <% if value_for(entry, "level").present? %>
                    <span class="text-slate-500">· <%= value_for(entry, "level") %></span>
                  <% end %>
                </span>
              <% end %>
            </div>
          <% else %>
            <div class="<%= [section_content_margin_top_class(fallback: "mt-4"), compact_section_stack_classes(fallback: "space-y-4")].join(" ") %>">
              <% entries.each do |entry| %>
                <% subtitle = entry_subtitle(entry) %>
                <% date_range = date_range_for(entry) %>
                <article>
                  <h3 class="<%= [entry_title_text_class, "font-semibold text-slate-900"].join(" ") %>"><%= entry_title(entry) %></h3>
                  <% if subtitle.present? %>
                    <p class="<%= ["mt-1", meta_text_class, "text-slate-600"].join(" ") %>"><%= subtitle %></p>
                  <% end %>
                  <% if date_range.present? %>
                    <p class="<%= ["mt-1", meta_text_class, "text-slate-500"].join(" ") %>"><%= date_range %></p>
                  <% end %>
                  <% entry_body_paragraphs(entry).each do |paragraph| %>
                    <p class="<%= [entry_body_spacing_class(fallback: "mt-2"), body_text_class, body_leading_class, "text-slate-700"].join(" ") %>"><%= paragraph %></p>
                  <% end %>
                </article>
              <% end %>
            </div>
          <% end %>
        </section>
      <% end %>
    </aside>
  </div>
</div>
