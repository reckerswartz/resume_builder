<div class="mx-auto w-full max-w-3xl rounded-[2rem] bg-white p-8 text-slate-900 shadow-sm sm:p-10">
  <header class="border-b pb-6" style="border-color: <%= accent_color %>33;">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h1 class="text-4xl font-semibold tracking-tight" style="color: <%= accent_color %>;"><%= full_name %></h1>
        <% if resume.headline.present? %>
          <p class="mt-2 text-lg text-slate-600"><%= resume.headline %></p>
        <% end %>
      </div>
      <div class="flex flex-wrap gap-2 text-sm text-slate-600 sm:max-w-xs sm:justify-end">
        <% contact_items.each do |label, value| %>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5"><span class="font-medium text-slate-900"><%= label %>:</span> <%= value %></span>
        <% end %>
      </div>
    </div>

    <% if resume.summary.present? %>
      <p class="mt-5 text-base leading-7 text-slate-700"><%= resume.summary %></p>
    <% end %>
  </header>

  <div class="mt-8 space-y-8">
    <% resume.ordered_sections.each do |section| %>
      <section>
        <div class="mb-4 flex items-center gap-3">
          <span class="h-3 w-3 rounded-full" style="background-color: <%= accent_color %>;"></span>
          <h2 class="text-xl font-semibold tracking-tight text-slate-900"><%= section.title %></h2>
        </div>

        <% if section.section_type == "skills" %>
          <div class="flex flex-wrap gap-2">
            <% section_entries(section).each do |entry| %>
              <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">
                <span class="font-medium text-slate-900"><%= value_for(entry, "name") %></span>
                <% if value_for(entry, "level").present? %>
                  <span class="text-slate-500">· <%= value_for(entry, "level") %></span>
                <% end %>
              </span>
            <% end %>
          </div>
        <% else %>
          <div class="space-y-5">
            <% section_entries(section).each do |entry| %>
              <article class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <h3 class="text-base font-semibold text-slate-900"><%= value_for(entry, "title").presence || value_for(entry, "degree").presence || value_for(entry, "name") %></h3>
                    <p class="mt-1 text-sm text-slate-600"><%= value_for(entry, "organization").presence || value_for(entry, "institution").presence || value_for(entry, "role") %></p>
                  </div>
                  <div class="text-sm text-slate-500 sm:text-right">
                    <div><%= date_range_for(entry) %></div>
                    <% location = value_for(entry, "location") %>
                    <% if location.present? %>
                      <div class="mt-1"><%= location %></div>
                    <% end %>
                  </div>
                </div>

                <% [value_for(entry, "summary"), value_for(entry, "details")].reject(&:blank?).each do |paragraph| %>
                  <p class="mt-3 text-sm leading-6 text-slate-700"><%= paragraph %></p>
                <% end %>

                <% highlights = list_values_for(entry, "highlights") %>
                <% if highlights.any? %>
                  <ul class="mt-3 space-y-2 text-sm leading-6 text-slate-700">
                    <% highlights.each do |highlight| %>
                      <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full" style="background-color: <%= accent_color %>;"></span><span><%= highlight %></span></li>
                    <% end %>
                  </ul>
                <% end %>

                <% if value_for(entry, "url").present? %>
                  <p class="mt-3 text-sm text-slate-600"><%= value_for(entry, "url") %></p>
                <% end %>
              </article>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  </div>
</div>
