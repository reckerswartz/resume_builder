<div class="<%= shell_classes %>">
  <header class="<%= header_padding_class %>">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <span class="inline-flex rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em]" style="border-color: <%= accent_color_with_alpha("22") %>; color: <%= accent_color %>; background-color: <%= accent_color_with_alpha("08") %>;"><%= template.name %></span>
        <h1 class="<%= ["mt-3", name_text_class, "font-semibold tracking-tight text-slate-900"].join(" ") %>"><%= full_name %></h1>
        <% if resume.headline.present? %>
          <p class="<%= ["mt-2", headline_text_class, "text-slate-600"].join(" ") %>"><%= resume.headline %></p>
        <% end %>
      </div>

      <% if contact_items.any? %>
        <div class="flex flex-wrap gap-2 lg:justify-end">
          <% contact_items.each do |_label, value| %>
            <span class="<%= [chip_text_class, "rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-slate-600"].join(" ") %>"><%= value %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if resume.summary.present? %>
      <p class="<%= [summary_margin_top_class, body_text_class, relaxed_body_leading_class, "max-w-3xl text-slate-700"].join(" ") %>"><%= resume.summary %></p>
    <% end %>
  </header>

  <div class="<%= section_stack_classes %>">
    <% visible_sections.each do |section| %>
      <% entries = section_entries(section) %>
      <section>
        <div class="<%= [section_heading_spacing_class, "flex items-center gap-4"].join(" ") %>">
          <h2 class="<%= [section_title_text_class, "font-semibold tracking-tight text-slate-900"].join(" ") %>"><%= section.title %></h2>
          <span class="h-px flex-1" style="background-color: <%= accent_color_with_alpha("20") %>;"></span>
        </div>

        <% if section.section_type == "skills" %>
          <div class="flex flex-wrap gap-2">
            <% entries.each do |entry| %>
              <span class="<%= [chip_text_class, "rounded-full border px-3 py-1.5 text-slate-700"].join(" ") %>" style="border-color: <%= accent_color_with_alpha("22") %>; background-color: <%= accent_color_with_alpha("08") %>;;">
                <span class="font-medium text-slate-900"><%= value_for(entry, "name") %></span>
                <% if value_for(entry, "level").present? %>
                  <span class="text-slate-500">· <%= value_for(entry, "level") %></span>
                <% end %>
              </span>
            <% end %>
          </div>
        <% else %>
          <div class="<%= entry_stack_classes %>">
            <% entries.each do |entry| %>
              <% subtitle = entry_subtitle(entry) %>
              <% date_range = date_range_for(entry) %>
              <% location = entry_location(entry) %>
              <% highlights = entry_highlights(entry) %>
              <% url = entry_url(entry) %>
              <article class="rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm shadow-slate-200/60">
                <div class="flex flex-col gap-1.5 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <h3 class="<%= [entry_title_text_class, "font-semibold text-slate-900"].join(" ") %>"><%= entry_title(entry) %></h3>
                    <% if subtitle.present? %>
                      <p class="<%= ["mt-1", meta_text_class, "text-slate-600"].join(" ") %>"><%= subtitle %></p>
                    <% end %>
                  </div>

                  <% if date_range.present? || location.present? %>
                    <div class="<%= [meta_text_class, "text-slate-500 sm:text-right"].join(" ") %>">
                      <% if date_range.present? %>
                        <div><%= date_range %></div>
                      <% end %>
                      <% if location.present? %>
                        <div class="mt-1"><%= location %></div>
                      <% end %>
                    </div>
                  <% end %>
                </div>

                <% entry_body_paragraphs(entry).each do |paragraph| %>
                  <p class="<%= [entry_body_spacing_class, body_text_class, body_leading_class, "text-slate-700"].join(" ") %>"><%= paragraph %></p>
                <% end %>

                <% if highlights.any? %>
                  <ul class="<%= [entry_body_spacing_class, body_text_class, body_leading_class, "space-y-1.5 text-slate-700"].join(" ") %>">
                    <% highlights.each do |highlight| %>
                      <li class="flex gap-2.5"><span class="mt-1.5 h-1 w-1 shrink-0 rounded-full" style="background-color: <%= accent_color %>;"></span><span><%= highlight %></span></li>
                    <% end %>
                  </ul>
                <% end %>

                <% if url.present? %>
                  <p class="<%= [entry_body_spacing_class, meta_text_class, "text-slate-600"].join(" ") %>"><%= url %></p>
                <% end %>
              </article>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  </div>
</div>
