<div class="mx-auto grid w-full max-w-4xl gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
  <div class="space-y-4">
    <%= render Ui::PageHeaderComponent.new(
      eyebrow: "Welcome back",
      title: "Pick up where you left off.",
      description: "Open your drafts, keep editing, and export when the resume looks right.",
      badges: [
        { label: "Saved drafts", tone: :neutral },
        { label: "Live preview", tone: :neutral }
      ],
      density: :compact
    ) %>

    <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :sm) do %>
      <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>
      <div class="relative space-y-3">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-ink-700/70">After sign in</p>

        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <div class="flex items-start gap-3">
            <%= render Ui::GlyphComponent.new(name: :preview, size: :sm, tone: :soft) %>
            <div>
              <p class="text-sm font-semibold text-ink-950">Return to your drafts</p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80">Keep your content, preview, and template choices in one place.</p>
            </div>
          </div>
        </div>

        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <div class="flex items-start gap-3">
            <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :soft) %>
            <div>
              <p class="text-sm font-semibold text-ink-950">Switch layouts later</p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80">Your resume content stays reusable, so you can refine the presentation whenever you need to.</p>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "relative") do %>
    <div class="absolute -right-8 top-6 h-24 w-24 rounded-full atelier-glow opacity-45"></div>
    <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

    <div class="relative mb-6">
      <span class="atelier-pill">
        <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
        Secure sign in
      </span>
      <h2 class="mt-4 font-serif text-3xl font-semibold tracking-[-0.03em] text-ink-950">Sign in</h2>
      <p class="mt-3 text-sm leading-6 text-ink-700/80">Use the email and password for your workspace.</p>
    </div>

    <%= form_with url: session_path, class: "relative space-y-5" do |form| %>
      <% if @form_error.present? %>
        <div class="<%= ui_inset_panel_classes(tone: :danger) %>">
          <p class="text-sm text-rose-700"><%= @form_error %></p>
        </div>
      <% end %>

      <div>
        <%= form.label :email_address, class: ui_label_classes %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: ui_input_classes %>
      </div>

      <div data-controller="password-field">
        <%= form.label :password, class: ui_label_classes %>
        <div class="relative mt-2">
          <%= form.password_field :password,
            required: true,
            autocomplete: "current-password",
            maxlength: 72,
            class: "#{ui_input_classes.delete_prefix("mt-2 ")} pr-20",
            data: {
              password_field_target: "input",
              action: "keyup->password-field#updateCapsState keydown->password-field#updateCapsState blur->password-field#hideCapsHint"
            } %>
          <button
            type="button"
            class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-medium text-ink-700 transition hover:text-ink-950"
            data-action="password-field#toggle"
            data-password-field-target="toggle"></button>
        </div>
        <p class="mt-2 hidden text-sm text-amber-700" data-password-field-target="capsHint">Caps lock is on.</p>
      </div>

      <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
        <p class="text-sm leading-6 text-ink-700/80">Need help getting back in? Use the email address you signed up with, or request a password reset below.</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <%= form.submit "Sign in", class: ui_button_classes(:primary) %>
        <%= link_to "Forgot password?", new_password_path, class: ui_button_classes(:ghost) %>
      </div>

      <p class="text-sm text-ink-700/70">Need an account? <%= link_to "Create one", new_registration_path, class: "font-medium text-ink-950 underline decoration-canvas-300 underline-offset-4" %></p>
    <% end %>
  <% end %>
</div>
