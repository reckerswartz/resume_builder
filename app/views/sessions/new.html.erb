<div class="mx-auto grid w-full max-w-5xl gap-6 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
  <div class="space-y-4">
    <%= render Ui::PageHeaderComponent.new(
      eyebrow: t("sessions.new.page_header.eyebrow"),
      title: t("sessions.new.page_header.title"),
      description: t("sessions.new.page_header.description"),
      badges: [
        { label: t("sessions.new.page_header.badges.saved_drafts"), tone: :neutral },
        { label: t("sessions.new.page_header.badges.live_preview"), tone: :neutral }
      ],
      actions: [
        { label: t("sessions.new.page_header.actions.create_workspace"), path: new_registration_path, style: :secondary }
      ],
      density: :compact
    ) %>

    <%= render Ui::DashboardPanelComponent.new(
      eyebrow: t("sessions.new.support_panel.eyebrow"),
      title: t("sessions.new.support_panel.title"),
      description: t("sessions.new.support_panel.description"),
      tone: :subtle,
      padding: :md,
      density: :compact
    ) do %>
      <div class="space-y-3">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t("sessions.new.after_sign_in_eyebrow") %></p>

        <%= render "shared/glyph_inset_card", glyph: :preview, title: t("sessions.new.return_to_drafts.title"), description: t("sessions.new.return_to_drafts.description") %>

        <%= render "shared/glyph_inset_card", glyph: :layers, title: t("sessions.new.switch_layouts.title"), description: t("sessions.new.switch_layouts.description") %>

        <%= render "shared/glyph_inset_card", glyph: :spark, title: t("sessions.new.export_when_ready.title"), description: t("sessions.new.export_when_ready.description") %>
      </div>
    <% end %>
  </div>

  <%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "relative") do %>
    <div class="absolute -right-8 top-6 h-24 w-24 rounded-full atelier-glow opacity-45"></div>
    <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

    <div class="relative mb-6">
      <span class="atelier-pill">
        <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
        <%= t("sessions.new.form.pill") %>
      </span>
      <h2 class="mt-4 font-serif text-3xl font-semibold tracking-[-0.03em] text-ink-950"><%= t("sessions.new.form.title") %></h2>
      <p class="mt-3 text-sm leading-6 text-ink-700/80"><%= t("sessions.new.form.description") %></p>
    </div>

    <%= form_with url: session_path, class: "relative space-y-5" do |form| %>
      <% if @form_error.present? %>
        <div class="<%= ui_inset_panel_classes(tone: :danger) %>">
          <p class="text-sm text-rose-700"><%= @form_error %></p>
        </div>
      <% end %>

      <div>
        <%= form.label :email_address, class: ui_label_classes %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: ui_input_classes %>
      </div>

      <div data-controller="password-field">
        <%= form.label :password, class: ui_label_classes %>
        <div class="relative mt-2">
          <%= form.password_field :password,
            required: true,
            autocomplete: "current-password",
            maxlength: 72,
            class: "#{ui_input_classes.delete_prefix("mt-2 ")} pr-20",
            data: {
              password_field_target: "input",
              action: "keyup->password-field#updateCapsState keydown->password-field#updateCapsState blur->password-field#hideCapsHint"
            } %>
          <button
            type="button"
            aria-label="<%= t("sessions.new.form.toggle_password_visibility") %>"
            class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-medium text-ink-700 transition hover:text-ink-950"
            data-action="password-field#toggle"
            data-password-field-target="toggle"></button>
        </div>
        <p class="mt-2 hidden text-sm text-amber-700" data-password-field-target="capsHint"><%= t("sessions.new.form.caps_lock_hint") %></p>
      </div>

      <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
        <p class="text-sm leading-6 text-ink-700/80"><%= t("sessions.new.form.help_text") %></p>
      </div>

      <div class="space-y-3">
        <%= form.submit t("sessions.new.form.submit"), class: "#{ui_button_classes(:primary)} w-full sm:w-auto" %>

        <div class="flex flex-col gap-2 text-sm sm:flex-row sm:items-center sm:justify-between">
          <%= link_to t("sessions.new.form.forgot_password"), new_password_path, class: ui_button_classes(:ghost) %>
          <p class="text-sm leading-6 text-ink-700/70"><%= t("sessions.new.form.need_account") %> <%= link_to t("sessions.new.form.create_one"), new_registration_path, class: ui_button_classes(:ghost) %></p>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
