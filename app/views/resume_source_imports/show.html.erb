<% provider_label = @provider.fetch(:label) %>
<% configured = @provider.fetch(:configured) %>
<% status_label = configured ? t("resumes.resume_source_imports.show.status.configured") : t("resumes.resume_source_imports.show.status.setup_required") %>
<% status_tone = configured ? :neutral : :warning %>
<% return_label = @resume.present? ? t("resumes.resume_source_imports.show.actions.back_to_source_step") : t("resumes.resume_source_imports.show.actions.back_to_resume_setup") %>

<section class="space-y-6 overflow-hidden">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: t("resumes.resume_source_imports.show.page_header.eyebrow"),
    title: t("resumes.resume_source_imports.show.page_header.title", provider: provider_label),
    description: @provider.fetch(:description),
    badges: [
      { label: status_label, tone: status_tone },
      { label: t("resumes.resume_source_imports.show.page_header.safe_scaffold_badge"), tone: :neutral }
    ],
    actions: [
      { label: return_label, path: @return_path, style: :secondary }
    ],
    density: :compact
  ) %>

  <%= render Ui::SurfaceCardComponent.new(padding: :md, extra_classes: "min-w-0 w-full max-w-full") do %>
    <div class="space-y-6 min-w-0">
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,0.7fr)]">
        <div class="space-y-4">
          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t("resumes.resume_source_imports.show.rollout_status.eyebrow") %></p>
            <p class="mt-2 text-base font-medium tracking-tight text-ink-950"><%= @launch_feedback.fetch(:message) %></p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("resumes.resume_source_imports.show.rollout_status.description") %></p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t("resumes.resume_source_imports.show.what_works_now.eyebrow") %></p>
              <ul class="mt-3 space-y-2 text-sm leading-6 text-ink-700/80">
                <li><%= t("resumes.resume_source_imports.show.what_works_now.provider_registry") %></li>
                <li><%= t("resumes.resume_source_imports.show.what_works_now.signed_in_launch") %></li>
                <li><%= t("resumes.resume_source_imports.show.what_works_now.setup_guidance") %></li>
              </ul>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t("resumes.resume_source_imports.show.still_deferred.eyebrow") %></p>
              <ul class="mt-3 space-y-2 text-sm leading-6 text-ink-700/80">
                <li><%= t("resumes.resume_source_imports.show.still_deferred.oauth_handoff") %></li>
                <li><%= t("resumes.resume_source_imports.show.still_deferred.remote_file_chooser") %></li>
                <li><%= t("resumes.resume_source_imports.show.still_deferred.server_pipeline") %></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="<%= ui_inset_panel_classes(tone: :default) %>">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t("resumes.resume_source_imports.show.provider_state.eyebrow") %></p>
                <p class="mt-2 text-base font-medium tracking-tight text-ink-950"><%= provider_label %></p>
              </div>
              <span class="<%= ui_badge_classes(status_tone) %>"><%= status_label %></span>
            </div>

            <dl class="mt-4 space-y-3 text-sm">
              <div>
                <dt class="font-medium text-ink-950"><%= t("resumes.resume_source_imports.show.provider_state.return_destination") %></dt>
                <dd class="mt-1 text-ink-700/80"><%= @return_path %></dd>
              </div>
              <div>
                <dt class="font-medium text-ink-950"><%= t("resumes.resume_source_imports.show.provider_state.resume_context") %></dt>
                <dd class="mt-1 text-ink-700/80"><%= @resume.present? ? @resume.title.presence || t("resumes.resume_source_imports.show.provider_state.existing_draft") : t("resumes.resume_source_imports.show.provider_state.new_resume_setup") %></dd>
              </div>
            </dl>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t("resumes.resume_source_imports.show.required_env_vars") %></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <% @provider.fetch(:required_env_vars).each do |env_var| %>
                <span class="<%= ui_badge_classes(:neutral) %>"><%= env_var %></span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</section>
