<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title><%= @resume.title %></title>
    <%= stylesheet_link_tag :app, media: "all" %>
    <style>
      section { page-break-inside: avoid; }
      article { page-break-inside: avoid; }
      h2 { page-break-after: avoid; }
      h3 { page-break-after: avoid; }
      header { page-break-inside: avoid; }
    </style>
  </head>
  <body style="background: white; color: #0f172a; margin: 0; padding: 24px; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
    <%= yield %>
  </body>
</html>
