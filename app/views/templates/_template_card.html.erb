<% card_state = local_assigns[:card_state] %>
<% template_card = card_state.present? ? card_state.fetch(:template_card) : local_assigns.fetch(:template_card) %>
<% template = template_card.fetch(:template) %>
<% description_text = card_state.present? ? card_state.fetch(:description_text) : template.description.presence || template_card.fetch(:summary) %>
<% preview_template_path = card_state.present? ? card_state.fetch(:preview_template_path) : template_path(id: template) %>
<% use_template_path = card_state.present? ? card_state.fetch(:use_template_path) : (current_user.present? ? new_resume_path(template_id: template.id) : new_registration_path(template_id: template.id)) %>
<% selected_accent_color = card_state.present? ? card_state.fetch(:selected_accent_color) : template_card.fetch(:selected_accent_color) %>
<% accent_variants = card_state.present? ? card_state.fetch(:accent_variants) : template_card.fetch(:accent_variants) %>
<% selected_accent_variant_label = if card_state.present?
  card_state.fetch(:selected_accent_variant_label)
else
  accent_variants.find { |accent_variant| accent_variant.fetch(:accent_color) == selected_accent_color }&.fetch(:label) || accent_variants.first.fetch(:label)
end %>
<% badge_labels = if card_state.present?
  card_state.fetch(:badge_labels)
else
  [
    t(".default_badges.density", density: template_card.fetch(:density_label)),
    t(".default_badges.columns", columns: template_card.fetch(:column_count_label)),
    t(".default_badges.theme", theme: template_card.fetch(:theme_tone_label)),
    t(".default_badges.header", header: template_card.fetch(:header_style_label)),
    t(".default_badges.entries", entries: template_card.fetch(:entry_style_label))
  ]
end %>
<% recommendation_badge_label = card_state.present? ? card_state[:recommendation_badge_label] : nil %>
<% layout_icon_name = template_card.fetch(:sidebar_section_labels).any? ? :layers : :preview %>
<% layout_focus_label = if card_state.present?
  card_state.fetch(:layout_focus_label)
elsif template_card.fetch(:sidebar_section_labels).any?
  t(".layout_focus.sidebar", sections: template_card.fetch(:sidebar_section_labels).to_sentence)
else
  t(".layout_focus.balanced")
end %>
<% html_options = if card_state.present?
  {
    data: {
      template_gallery_target: "card",
      template_id: template.id,
      selected_accent_color: selected_accent_color,
      family: card_state.fetch(:filter_family),
      density: card_state.fetch(:filter_density),
      column_count: card_state.fetch(:filter_column_count),
      theme_tone: card_state.fetch(:filter_theme_tone),
      shell_style: card_state.fetch(:filter_shell_style),
      search_text: card_state.fetch(:search_text),
      sort_name: card_state.fetch(:sort_name),
      sort_family: card_state.fetch(:sort_family),
      sort_density_rank: card_state.fetch(:sort_density_rank),
      sort_recommendation_rank: card_state.fetch(:sort_recommendation_rank)
    }
  }
else
  {}
end %>
<%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "relative h-full overflow-hidden", html_options: html_options) do %>
  <div class="absolute -right-10 top-6 h-24 w-24 rounded-full atelier-glow opacity-40"></div>
  <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

  <div class="relative">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-2">
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: layout_icon_name, size: :xs, tone: :minimal) %>
            <%= template_card.fetch(:family_label) %>
          </span>

          <% if recommendation_badge_label.present? %>
            <span class="<%= ui_badge_classes(:info) %>"><%= recommendation_badge_label %></span>
          <% end %>
        </div>

        <h2 class="mt-4 text-xl font-semibold tracking-tight text-ink-950"><%= template.name %></h2>
        <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= description_text %></p>
      </div>

      <div class="rounded-[1.2rem] border border-canvas-200/80 bg-canvas-100/88 px-3 py-3 text-right shadow-[0_12px_28px_rgba(15,23,42,0.06)]">
        <div class="flex items-center justify-end gap-2">
          <span class="h-3.5 w-3.5 rounded-full border border-black/10" data-template-variant-swatch="true" data-template-id="<%= template.id %>" style="background-color: <%= selected_accent_color %>;"></span>
          <span class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t(".accent_label") %></span>
        </div>
        <p class="mt-2 text-sm font-semibold text-ink-950" data-template-variant-label="true" data-template-id="<%= template.id %>"><%= t(".accent_value", variant: selected_accent_variant_label) %></p>
        <div class="mt-3 flex flex-wrap justify-end gap-2">
          <% accent_variants.each do |accent_variant| %>
            <% accent_variant_selected = accent_variant.fetch(:accent_color) == selected_accent_color %>
            <button
              type="button"
              class="<%= ["inline-flex h-8 w-8 items-center justify-center rounded-full border-2 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-aqua-200/70 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent", (accent_variant_selected ? "border-aqua-200 bg-canvas-50 shadow-[0_12px_28px_rgba(125,211,252,0.2)]" : "border-canvas-200/80 bg-canvas-50/92 hover:border-aqua-200/80 hover:bg-canvas-50")].join(" ") %>"
              data-action="click->template-gallery#selectAccentVariant"
              data-template-variant-button="true"
              data-template-id="<%= template.id %>"
              data-accent-color="<%= accent_variant.fetch(:accent_color) %>"
              data-variant-label="<%= accent_variant.fetch(:label) %>"
              data-accent-label="<%= t(".accent_value", variant: accent_variant.fetch(:label)) %>"
              data-preview-template-path="<%= card_state.present? ? accent_variant.fetch(:preview_template_path) : preview_template_path %>"
              data-use-template-path="<%= card_state.present? ? accent_variant.fetch(:use_template_path) : use_template_path %>"
              data-selected-classes="border-aqua-200 bg-canvas-50 shadow-[0_12px_28px_rgba(125,211,252,0.2)]"
              data-unselected-classes="border-canvas-200/80 bg-canvas-50/92 hover:border-aqua-200/80 hover:bg-canvas-50"
              aria-pressed="<%= accent_variant_selected %>"
              aria-label="<%= t(".accent_swatch_label", variant: accent_variant.fetch(:label)) %>">
              <span class="h-4 w-4 rounded-full border border-black/10" style="background-color: <%= accent_variant.fetch(:accent_color) %>;"></span>
            </button>
          <% end %>
        </div>
      </div>
    </div>

    <div class="mt-5 rounded-[1.75rem] border border-mist-200/80 bg-canvas-100/84 p-3 shadow-[0_16px_36px_rgba(15,23,42,0.06)]">
      <div class="mb-3 flex items-center justify-between gap-3 px-1">
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t(".live_sample_label") %></p>
        <span class="<%= ui_badge_classes(:neutral) %>"><%= template_card.fetch(:short_label) %></span>
      </div>

      <div class="<%= [ui_inset_panel_classes(tone: :default), 'overflow-hidden'].join(' ') %>">
        <%= render "resumes/template_picker_preview", template_card: template_card, card_state: card_state, selected_accent_color: selected_accent_color %>
      </div>
    </div>

    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
        <div class="flex items-start gap-3">
          <%= render Ui::GlyphComponent.new(name: layout_icon_name, size: :sm, tone: :soft) %>
          <div>
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t(".layout_focus_label") %></p>
            <p class="mt-2 text-sm font-semibold text-ink-950"><%= layout_focus_label %></p>
          </div>
        </div>
      </div>

      <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
        <div class="flex items-start gap-3">
          <%= render Ui::GlyphComponent.new(name: :swatches, size: :sm, tone: :soft) %>
          <div>
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t(".shell_style_label") %></p>
            <p class="mt-2 text-sm font-semibold text-ink-950"><%= t(".shell_style_value", shell: template_card.fetch(:shell_style_label)) %></p>
            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".shell_style_description") %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-5 flex flex-wrap gap-2">
      <% badge_labels.each do |badge_label| %>
        <span class="<%= ui_badge_classes(:neutral) %>"><%= badge_label %></span>
      <% end %>
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <%= link_to t(".preview_template"), preview_template_path, class: "#{ui_button_classes(:secondary, size: :sm)} justify-center", data: { template_variant_preview_link: true, template_id: template.id } %>
      <%= link_to t(".use_template"), use_template_path, class: "#{ui_button_classes(:primary, size: :sm)} justify-center", data: { template_variant_use_link: true, template_id: template.id } %>
    </div>

    <% if card_state.present? && card_state[:apply_to_resume_path].present? %>
      <details class="mt-3" data-controller="disclosure">
        <summary class="list-none cursor-pointer">
          <span class="<%= ui_button_classes(:secondary, size: :sm) %> justify-center"><%= t(".apply_to_resume") %></span>
        </summary>

        <%= form_with url: card_state[:apply_to_resume_path], method: :get, local: true, class: "mt-3 grid gap-3" do %>
          <div>
            <%= label_tag "apply_resume_#{template.id}", t(".apply_to_resume_label"), class: "text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70" %>
            <%= select_tag :resume_id, options_for_select(card_state[:apply_resume_options], card_state[:selected_apply_resume_id]), id: "apply_resume_#{template.id}", class: ui_input_classes %>
          </div>

          <%= button_tag t(".apply_to_resume_submit"), type: :submit, class: "#{ui_button_classes(:secondary, size: :sm)} justify-center" %>
        <% end %>
      </details>
    <% end %>
  </div>
<% end %>
