<% template_card = marketplace_template_card(@template, selected_accent_color: @preview_resume.accent_color) %>
<% marketplace_state = template_marketplace_state(templates: [@template], filter_templates: [@template], query: nil, family_filter: nil, density_filter: nil, column_count_filter: nil, theme_tone_filter: nil, shell_style_filter: nil, sort: nil, resume: @recommendation_resume) %>
<% resume_context_params = {} %>
<% resume_intake_params = @recommendation_resume&.intake_details&.slice("experience_level", "student_status") || {} %>
<% selected_accent_color = template_card.fetch(:selected_accent_color) %>
<% selected_accent_variant_label = template_card.fetch(:accent_variants).find { |accent_variant| accent_variant.fetch(:accent_color) == selected_accent_color }&.fetch(:label) || template_card.fetch(:accent_variants).first.fetch(:label) %>
<% resume_context_params[:intake_details] = resume_intake_params if resume_intake_params.present? %>
<% if selected_accent_color.present? && selected_accent_color != @template.render_layout_config.fetch("accent_color") %>
  <% resume_context_params[:settings] = { accent_color: selected_accent_color } %>
<% end %>
<% use_template_path = if current_user.present?
  resume_context_params.present? ? new_resume_path(template_id: @template.id, resume: resume_context_params) : new_resume_path(template_id: @template.id)
else
  resume_context_params.present? ? new_registration_path(template_id: @template.id, resume: resume_context_params) : new_registration_path(template_id: @template.id)
end %>
<% templates_path_with_context = if resume_context_params.present?
  templates_path(resume: resume_context_params)
else
  templates_path
end %>
<% sidebar_summary = if template_card.fetch(:sidebar_section_labels).any?
  t(
    ".sidebar_summary",
    position: t(".sidebar_positions.#{template_card.fetch(:sidebar_position)}", default: template_card.fetch(:sidebar_position).to_s.titleize),
    sections: template_card.fetch(:sidebar_section_labels).to_sentence
  )
else
  t(".balanced_flow")
end %>

<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: t(".page_header.eyebrow"),
    title: @template.name,
    description: @template.description.presence || template_card.fetch(:summary),
    badges: [
      { label: template_card.fetch(:family_label), tone: :neutral },
      { label: t(".page_header.columns_badge", columns: template_card.fetch(:column_count_label)), tone: :neutral },
      { label: t(".page_header.theme_badge", theme: template_card.fetch(:theme_tone_label)), tone: :neutral }
    ],
    actions: [
      { label: t(".page_header.use_template"), path: use_template_path, style: :primary },
      { label: t(".page_header.back_to_templates"), path: templates_path_with_context, style: :secondary }
    ],
    density: :compact
  ) %>

  <div class="grid grid-cols-[minmax(0,1fr)] gap-6 xl:grid-cols-[minmax(0,1fr)_22rem]">
    <div class="space-y-4">
      <%= render Ui::DashboardPanelComponent.new(
        eyebrow: t(".preview_panel.eyebrow"),
        title: t(".preview_panel.title"),
        description: t(".preview_panel.description"),
        padding: :md,
        density: :compact
      ) do %>
        <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :sm, extra_classes: "relative overflow-hidden") do %>
          <div class="absolute -right-12 top-6 h-24 w-24 rounded-full atelier-glow opacity-35"></div>
          <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>

          <div class="relative">
            <div class="rounded-[1.75rem] border border-canvas-200/80 bg-canvas-50/92 p-3 shadow-[0_16px_36px_rgba(15,23,42,0.06)]">
              <%= render ResumeTemplates::ComponentResolver.component_for(@preview_resume) %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <aside class="min-w-0 space-y-4 xl:sticky xl:top-6 xl:self-start">
      <%= render Ui::DashboardPanelComponent.new(
        eyebrow: t(".quick_take.eyebrow"),
        title: t(".quick_take.title"),
        description: t(".quick_take.description"),
        tone: :brand,
        padding: :sm,
        density: :compact
      ) do %>
        <div class="space-y-3">
          <div class="atelier-dark-inset backdrop-blur-sm">
            <div class="flex items-start gap-3">
              <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :hero) %>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/60"><%= t(".quick_take.layout_profile_label") %></p>
                <p class="mt-2 text-sm font-semibold tracking-tight text-white"><%= template_card.fetch(:family_label) %></p>
                <p class="mt-1 text-sm leading-6 text-white/72"><%= template_card.fetch(:summary) %></p>
              </div>
            </div>

            <div class="mt-3 flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(:hero) %>"><%= t(".quick_take.columns_badge", columns: template_card.fetch(:column_count_label)) %></span>
              <span class="<%= ui_badge_classes(:hero) %>"><%= t(".quick_take.theme_badge", theme: template_card.fetch(:theme_tone_label)) %></span>
              <span class="<%= ui_badge_classes(:hero) %>"><%= t(".quick_take.density_badge", density: template_card.fetch(:density_label)) %></span>
            </div>
          </div>

          <div class="flex flex-col gap-2 text-sm">
            <% if marketplace_state.apply_to_resume_available? %>
              <%= form_with url: marketplace_state.apply_to_resume_path_for(@template), method: :get, local: true, class: "space-y-2" do %>
                <div>
                  <%= label_tag "apply_resume_detail", t(".quick_take.apply_to_resume_label"), class: "text-xs font-semibold uppercase tracking-[0.18em] text-white/60" %>
                  <%= select_tag :resume_id, options_for_select(marketplace_state.apply_resume_options, marketplace_state.selected_apply_resume_id), id: "apply_resume_detail", class: ui_input_classes %>
                </div>
                <%= button_tag t(".quick_take.apply_to_resume_submit"), type: :submit, class: "#{ui_button_classes(:hero_secondary)} w-full justify-center" %>
              <% end %>
            <% end %>
            <%= link_to t(".quick_take.browse_all_templates"), templates_path_with_context, class: "#{ui_button_classes(:hero_secondary)} w-full justify-center" %>
          </div>
        </div>
      <% end %>

      <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :md) do %>
        <div class="space-y-4">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :swatches, size: :xs, tone: :minimal) %>
              <%= t(".carry_through.pill") %>
            </span>
            <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= t(".carry_through.title") %></h2>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t(".carry_through.description") %></p>
          </div>

          <div class="space-y-3">
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <div class="flex items-start gap-3">
                <%= render Ui::GlyphComponent.new(name: :swatches, size: :sm, tone: :soft) %>
                <div>
                  <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t(".carry_through.accent_label") %></p>
                  <div class="mt-2 flex items-center gap-3">
                    <span class="h-4 w-4 rounded-full border border-black/10" style="background-color: <%= selected_accent_color %>;"></span>
                    <p class="text-sm font-semibold text-ink-950"><%= t("templates.template_card.accent_value", variant: selected_accent_variant_label) %></p>
                  </div>
                  <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t(".carry_through.accent_description") %></p>
                </div>
              </div>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <div class="flex items-start gap-3">
                <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :soft) %>
                <div>
                  <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t(".carry_through.layout_focus_label") %></p>
                  <p class="mt-2 text-sm font-semibold text-ink-950"><%= sidebar_summary %></p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".carry_through.layout_description") %></p>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </aside>
  </div>
</section>
