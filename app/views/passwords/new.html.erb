<%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "relative mx-auto w-full max-w-2xl") do %>
  <div class="absolute -right-8 top-6 h-24 w-24 rounded-full atelier-glow opacity-45"></div>
  <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

  <div class="relative mb-6">
    <span class="atelier-pill">
      <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
      Account recovery
    </span>
    <h1 class="mt-4 font-serif text-3xl font-semibold tracking-[-0.03em] text-ink-950">Reset your password</h1>
    <p class="mt-3 text-sm leading-6 text-ink-700/80">Enter your email address and we will send you a reset link if an account exists.</p>
  </div>

  <%= form_with url: passwords_path, class: "relative space-y-5" do |form| %>
    <div>
      <%= form.label :email_address, class: ui_label_classes %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: ui_input_classes %>
    </div>

    <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
      <p class="text-sm font-semibold text-ink-950">What happens next</p>
      <p class="mt-2 text-sm leading-6 text-ink-700/80">Use the email address tied to your account. If the message does not arrive right away, check your spam folder or request a fresh link.</p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <%= form.submit "Send reset link", class: ui_button_classes(:primary) %>
      <%= link_to "Back to sign in", new_session_path, class: ui_button_classes(:ghost) %>
    </div>
  <% end %>
<% end %>
