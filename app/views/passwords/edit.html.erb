<%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "relative mx-auto w-full max-w-2xl") do %>
  <div class="absolute -right-8 top-6 h-24 w-24 rounded-full atelier-glow opacity-45"></div>
  <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

  <div class="relative mb-6">
    <span class="atelier-pill">
      <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
      <%= t("passwords.shared.recovery_pill") %>
    </span>
    <h1 class="mt-4 font-serif text-3xl font-semibold tracking-[-0.03em] text-ink-950"><%= t("passwords.edit.title") %></h1>
    <p class="mt-3 text-sm leading-6 text-ink-700/80"><%= t("passwords.edit.description") %></p>
  </div>

  <%= form_with url: password_path(params[:token]), method: :put, class: "relative space-y-5" do |form| %>
    <% if @form_error.present? %>
      <div class="<%= ui_inset_panel_classes(tone: :danger) %>">
        <p class="text-sm text-rose-700"><%= @form_error %></p>
      </div>
    <% end %>

    <div data-controller="password-field">
      <%= form.label :password, class: ui_label_classes %>
      <div class="relative mt-2">
        <%= form.password_field :password,
          required: true,
          autocomplete: "new-password",
          maxlength: 72,
          class: "#{ui_input_classes.delete_prefix("mt-2 ")} pr-20",
          data: {
            password_field_target: "input",
            action: "keyup->password-field#updateCapsState keydown->password-field#updateCapsState blur->password-field#hideCapsHint"
          } %>
        <button
          type="button"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-medium text-ink-700 transition hover:text-ink-950"
          data-action="password-field#toggle"
          data-password-field-target="toggle"></button>
      </div>
      <p class="mt-2 hidden text-sm text-amber-700" data-password-field-target="capsHint"><%= t("passwords.shared.caps_lock_hint") %></p>
    </div>

    <div data-controller="password-field">
      <%= form.label :password_confirmation, class: ui_label_classes %>
      <div class="relative mt-2">
        <%= form.password_field :password_confirmation,
          required: true,
          autocomplete: "new-password",
          maxlength: 72,
          class: "#{ui_input_classes.delete_prefix("mt-2 ")} pr-20",
          data: {
            password_field_target: "input",
            action: "keyup->password-field#updateCapsState keydown->password-field#updateCapsState blur->password-field#hideCapsHint"
          } %>
        <button
          type="button"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-medium text-ink-700 transition hover:text-ink-950"
          data-action="password-field#toggle"
          data-password-field-target="toggle"></button>
      </div>
      <p class="mt-2 hidden text-sm text-amber-700" data-password-field-target="capsHint"><%= t("passwords.shared.caps_lock_hint") %></p>
    </div>

    <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
      <p class="text-sm leading-6 text-ink-700/80"><%= t("passwords.edit.help_text") %></p>
    </div>

    <div class="space-y-3">
      <%= form.submit t("passwords.edit.submit"), class: "#{ui_button_classes(:primary)} w-full sm:w-auto" %>
      <%= link_to t("passwords.edit.request_new_link"), new_password_path, class: ui_button_classes(:ghost) %>
    </div>
  <% end %>
<% end %>
