<section class="space-y-8">
  <div>
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Admin</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900">Dashboard</h1>
    <p class="mt-2 text-sm text-slate-600">Monitor template availability, feature flags, and background job activity.</p>
  </div>

  <div class="grid gap-5 md:grid-cols-3">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Resumes</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= @resumes_count %></p>
    </div>
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-slate-500">Templates</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= @templates_count %></p>
      <p class="mt-2 text-sm text-slate-500"><%= @active_templates_count %> active</p>
    </div>
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-medium text-slate-500">LLM access</p>
      <p class="mt-3 text-3xl font-semibold tracking-tight text-slate-900"><%= @platform_setting.feature_enabled?("llm_access") ? "On" : "Off" %></p>
      <p class="mt-2 text-sm text-slate-500">Resume suggestions: <%= @platform_setting.feature_enabled?("resume_suggestions") ? "enabled" : "disabled" %></p>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.8fr_1.2fr]">
    <div class="space-y-4 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-xl font-semibold tracking-tight text-slate-900">Quick links</h2>
      <div class="flex flex-col gap-3">
        <%= link_to "Manage templates", admin_templates_path, class: "rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900" %>
        <%= link_to "Feature settings", admin_settings_path, class: "rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900" %>
        <%= link_to "Job logs", admin_job_logs_path, class: "rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900" %>
        <%= link_to "Back to resumes", resumes_path, class: "rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900" %>
      </div>
    </div>

    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-3 border-b border-slate-200 pb-4">
        <h2 class="text-xl font-semibold tracking-tight text-slate-900">Recent job activity</h2>
        <%= link_to "View all", admin_job_logs_path, class: "text-sm font-medium text-slate-700 underline decoration-slate-300 underline-offset-4" %>
      </div>

      <% if @recent_job_logs.any? %>
        <div class="mt-4 space-y-3">
          <% @recent_job_logs.each do |job_log| %>
            <%= link_to admin_job_log_path(job_log), class: "flex items-center justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-3 transition hover:border-slate-300 hover:bg-slate-50" do %>
              <div>
                <p class="text-sm font-medium text-slate-900"><%= job_log.job_type %></p>
                <p class="mt-1 text-sm text-slate-500"><%= l(job_log.created_at, format: :short) %></p>
              </div>
              <span class="rounded-full px-3 py-1 text-xs font-medium <%= job_log_status_classes(job_log) %>"><%= job_log.status.humanize %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="mt-4 text-sm text-slate-500">No background jobs have been tracked yet.</p>
      <% end %>
    </div>
  </div>
</section>
