<section class="space-y-6">
  <div>
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Admin</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900">Platform settings</h1>
    <p class="mt-2 text-sm text-slate-600">Control feature availability and shared platform preferences.</p>
  </div>

  <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
    <%= form_with model: @platform_setting, url: admin_settings_path, method: :patch, class: "space-y-8" do |form| %>
      <div>
        <h2 class="text-xl font-semibold tracking-tight text-slate-900">Feature flags</h2>
        <div class="mt-4 space-y-4">
          <% [["llm_access", "Enable LLM access"], ["resume_suggestions", "Enable resume suggestions"], ["autofill_content", "Enable autofill content"]].each do |key, label| %>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
              <%= hidden_field_tag "platform_setting[feature_flags][#{key}]", false %>
              <label class="flex items-center justify-between gap-4">
                <span class="text-sm font-medium text-slate-700"><%= label %></span>
                <%= check_box_tag "platform_setting[feature_flags][#{key}]", true, @platform_setting.feature_flags.fetch(key, false), class: "h-5 w-5 rounded border-slate-300 text-slate-900 focus:ring-slate-400" %>
              </label>
            </div>
          <% end %>
        </div>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <%= label_tag "platform_setting_preferences_default_template_slug", "Default template slug", class: "text-sm font-medium text-slate-700" %>
          <%= text_field_tag "platform_setting[preferences][default_template_slug]", @platform_setting.preferences.fetch("default_template_slug", "modern"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
        </div>

        <div>
          <%= label_tag "platform_setting_preferences_support_email", "Support email", class: "text-sm font-medium text-slate-700" %>
          <%= email_field_tag "platform_setting[preferences][support_email]", @platform_setting.preferences.fetch("support_email", "support@example.com"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
        </div>
      </div>

      <div class="flex justify-end">
        <%= form.submit "Save settings", class: "inline-flex justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-700" %>
      </div>
    <% end %>
  </div>
</section>
