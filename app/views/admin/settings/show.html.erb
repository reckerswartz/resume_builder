<% page_state = admin_settings_page_state(
     platform_setting: @platform_setting,
     llm_models: @llm_models,
     text_llm_models: @text_llm_models,
     vision_llm_models: @vision_llm_models,
     llm_assignment_model_ids: @llm_assignment_model_ids,
     llm_providers_count: @llm_providers_count
   ) %>

<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(**page_state.page_header_attributes) %>

  <%= form_with model: @platform_setting, url: admin_settings_path, method: :patch, class: "grid gap-6 xl:grid-cols-[16rem_minmax(0,1fr)] min-w-0 w-full max-w-full" do |form| %>
    <% if @platform_setting.errors.any? %>
      <div class="xl:col-span-2 <%= ui_inset_panel_classes(tone: :danger) %>">
        <%= @platform_setting.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <aside class="space-y-4 min-w-0 w-full max-w-full xl:sticky xl:top-6 xl:self-start">
      <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
        <div class="space-y-4">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
              <%= t("admin.settings.show.navigation.eyebrow") %>
            </span>
            <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= t("admin.settings.show.navigation.title") %></h2>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("admin.settings.show.navigation.description") %></p>
          </div>

          <div class="space-y-3">
            <% page_state.hub_sections.each do |section| %>
              <%= render Ui::SectionLinkCardComponent.new(
                label: section.fetch(:label),
                caption: section.fetch(:caption),
                path: "##{section.fetch(:id)}"
              ) %>
            <% end %>
          </div>

          <div class="flex flex-wrap gap-2">
            <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.settings.show.navigation.badges.enabled", enabled: page_state.enabled_feature_count, total: page_state.feature_flags.size) %></span>
            <span class="<%= ui_badge_classes(page_state.workflow_ready_count == 2 ? :success : :warning) %>"><%= t("admin.settings.show.navigation.badges.workflows_assigned", count: page_state.workflow_ready_count) %></span>
            <span class="<%= ui_badge_classes(page_state.configured_cloud_import_provider_count == page_state.cloud_import_provider_states.size ? :success : :warning) %>"><%= t("admin.settings.show.navigation.badges.connectors_configured", configured: page_state.configured_cloud_import_provider_count, total: page_state.cloud_import_provider_states.size) %></span>
          </div>
        </div>
      <% end %>
    </aside>

    <div class="space-y-6 min-w-0 w-full max-w-full">
      <%= render Ui::DashboardPanelComponent.new(
        eyebrow: t("admin.settings.show.summary.eyebrow"),
        title: t("admin.settings.show.summary.title"),
        description: t("admin.settings.show.summary.description"),
        padding: :sm,
        density: :compact
      ) do %>
        <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-3' ].join(' ') %>">
          <div class="flex flex-wrap gap-2">
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
              <%= t("admin.settings.show.summary.readiness_badge") %>
            </span>
            <span class="<%= ui_badge_classes(page_state.save_posture_ready? ? :success : :warning) %>"><%= page_state.save_posture_ready? ? t("admin.settings.show.summary.save_posture.ready") : t("admin.settings.show.summary.save_posture.follow_up") %></span>
            <span class="<%= ui_badge_classes(page_state.workflow_ready_count == 2 ? :success : :warning) %>"><%= t("admin.settings.show.navigation.badges.workflows_assigned", count: page_state.workflow_ready_count) %></span>
            <span class="<%= ui_badge_classes(page_state.configured_cloud_import_provider_count == page_state.cloud_import_provider_states.size ? :success : :warning) %>"><%= t("admin.settings.show.navigation.badges.connectors_configured", configured: page_state.configured_cloud_import_provider_count, total: page_state.cloud_import_provider_states.size) %></span>
          </div>

          <p class="text-sm leading-6 text-ink-700/80"><%= t("admin.settings.show.summary.guidance_registry_changes") %></p>
          <p class="text-sm leading-6 text-ink-700/80"><%= t("admin.settings.show.summary.guidance_save_posture") %></p>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t("admin.settings.show.sections.feature_access.title"),
        anchor: "feature-access",
        eyebrow: t("admin.settings.show.sections.feature_access.eyebrow"),
        description: t("admin.settings.show.sections.feature_access.description"),
        badges: [
          { label: t("admin.settings.show.sections.feature_access.badges.enabled", enabled: page_state.enabled_feature_count, total: page_state.feature_flags.size), tone: page_state.enabled_feature_count.positive? ? :success : :neutral }
        ]
      ) do %>
        <div class="space-y-4">
          <% page_state.feature_flags.each do |flag| %>
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <%= hidden_field_tag "platform_setting[feature_flags][#{flag.fetch(:key)}]", false %>
              <label class="flex items-start justify-between gap-4">
                <span>
                  <span class="block text-sm font-medium text-ink-950"><%= flag.fetch(:label) %></span>
                  <span class="mt-1 block text-sm text-ink-700/80"><%= flag.fetch(:description) %></span>
                </span>

                <span class="flex items-center gap-3">
                  <span class="<%= ui_badge_classes(flag.fetch(:enabled) ? :success : :neutral) %>"><%= flag.fetch(:enabled) ? t("admin.settings.show.sections.feature_access.toggle_status.on") : t("admin.settings.show.sections.feature_access.toggle_status.off") %></span>
                  <%= check_box_tag "platform_setting[feature_flags][#{flag.fetch(:key)}]", true, flag.fetch(:enabled), class: ui_checkbox_classes %>
                </span>
              </label>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t("admin.settings.show.sections.platform_defaults.title"),
        anchor: "platform-defaults",
        eyebrow: t("admin.settings.show.sections.platform_defaults.eyebrow"),
        description: t("admin.settings.show.sections.platform_defaults.description"),
        badges: [
          { label: page_state.default_template_slug, tone: :neutral },
          { label: page_state.support_email.present? ? t("admin.settings.show.sections.platform_defaults.badges.support_email_set") : t("admin.settings.show.sections.platform_defaults.badges.support_email_needed"), tone: page_state.support_email.present? ? :success : :warning }
        ]
      ) do %>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <%= label_tag "platform_setting_preferences_default_template_slug", t("admin.settings.show.sections.platform_defaults.fields.default_template_slug"), class: ui_label_classes %>
            <%= text_field_tag "platform_setting[preferences][default_template_slug]", page_state.default_template_slug, class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "platform_setting_preferences_support_email", t("admin.settings.show.sections.platform_defaults.fields.support_email"), class: ui_label_classes %>
            <%= email_field_tag "platform_setting[preferences][support_email]", page_state.support_email, class: ui_input_classes %>
          </div>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t("admin.settings.show.sections.cloud_import_connectors.title"),
        anchor: "cloud-import-connectors",
        eyebrow: t("admin.settings.show.sections.cloud_import_connectors.eyebrow"),
        description: t("admin.settings.show.sections.cloud_import_connectors.description"),
        badges: [
          { label: t("admin.settings.show.sections.cloud_import_connectors.badges.configured", configured: page_state.configured_cloud_import_provider_count, total: page_state.cloud_import_provider_states.size), tone: page_state.configured_cloud_import_provider_count == page_state.cloud_import_provider_states.size ? :success : :warning },
          { label: t("admin.settings.show.sections.cloud_import_connectors.badges.safe_scaffold"), tone: :neutral }
        ]
      ) do %>
        <div class="grid gap-4 xl:grid-cols-2">
          <% page_state.cloud_import_provider_states.each do |provider| %>
            <div class="<%= [ ui_inset_panel_classes(tone: :default), 'space-y-4' ].join(' ') %>">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-medium text-ink-950"><%= provider.fetch(:label) %></p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= provider.fetch(:description) %></p>
                </div>

                <span class="<%= ui_badge_classes(provider.fetch(:status_tone)) %>"><%= provider.fetch(:status_label) %></span>
              </div>

              <p class="text-sm leading-6 text-ink-700/80"><%= provider.fetch(:message) %></p>

              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.settings.show.sections.cloud_import_connectors.required_env_vars") %></p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <% provider.fetch(:required_env_vars).each do |env_var| %>
                    <span class="<%= ui_badge_classes(:neutral) %>"><%= env_var %></span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t("admin.settings.show.sections.llm_orchestration.title"),
        anchor: "llm-orchestration",
        eyebrow: t("admin.settings.show.sections.llm_orchestration.eyebrow"),
        description: t("admin.settings.show.sections.llm_orchestration.description"),
        badges: [
          { label: t("admin.settings.show.sections.llm_orchestration.badges.providers", count: page_state.llm_providers_count), tone: :neutral },
          { label: t("admin.settings.show.sections.llm_orchestration.badges.models", count: page_state.llm_models.count), tone: :neutral }
        ]
      ) do %>
        <% if page_state.llm_models.any? %>
          <div class="grid gap-4 lg:grid-cols-2">
            <%= render Ui::WidgetCardComponent.new(
              eyebrow: t("admin.settings.show.sections.llm_orchestration.widgets.text_registry.eyebrow"),
              title: page_state.text_primary_model&.name || t("admin.settings.show.sections.llm_orchestration.widgets.text_registry.title_fallback"),
              description: t("admin.settings.show.sections.llm_orchestration.widgets.text_registry.description", count: page_state.text_llm_models.count),
              badge: t("admin.settings.show.sections.llm_orchestration.widgets.text_registry.badge", count: page_state.text_verification_model_ids.size),
              badge_classes: ui_badge_classes(page_state.text_verification_model_ids.any? ? :success : :neutral),
              title_size: :base
            ) %>

            <%= render Ui::WidgetCardComponent.new(
              eyebrow: t("admin.settings.show.sections.llm_orchestration.widgets.vision_registry.eyebrow"),
              title: page_state.vision_primary_model&.name || t("admin.settings.show.sections.llm_orchestration.widgets.vision_registry.title_fallback"),
              description: t("admin.settings.show.sections.llm_orchestration.widgets.vision_registry.description", count: page_state.vision_llm_models.count),
              badge: t("admin.settings.show.sections.llm_orchestration.widgets.vision_registry.badge", count: page_state.vision_verification_model_ids.size),
              badge_classes: ui_badge_classes(page_state.vision_verification_model_ids.any? ? :success : :neutral),
              title_size: :base
            ) %>
          </div>

          <div class="mt-5 grid gap-5 xl:grid-cols-2">
            <%= render Ui::DashboardPanelComponent.new(
              eyebrow: t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.eyebrow"),
              title: page_state.text_primary_model&.name || t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.title_fallback"),
              description: t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.description"),
              action_label: t("admin.settings.show.sections.llm_orchestration.panels.manage_models"),
              action_path: admin_llm_models_path,
              action_style: :secondary,
              padding: :sm,
              density: :compact
            ) do %>
              <div class="space-y-4">
                <%= render Ui::ReportRowComponent.new(
                  title: t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.current_primary_model.title"),
                  subtitle: page_state.text_primary_model.present? ? settings_llm_model_option_summary(page_state.text_primary_model) : t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.current_primary_model.subtitle_fallback"),
                  badge: page_state.text_primary_model.present? ? page_state.text_primary_model.name : t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.current_primary_model.badge_fallback"),
                  badge_classes: ui_badge_classes(page_state.text_primary_model.present? ? :success : :neutral)
                ) %>

                <%= render Ui::ReportRowComponent.new(
                  title: t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.verification_coverage.title"),
                  subtitle: page_state.text_verification_models.any? ? t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.verification_coverage.subtitle", count: page_state.text_verification_models.size) : t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.verification_coverage.subtitle_none"),
                  badges: page_state.text_verification_models.any? ? page_state.text_verification_models.first(3).map { |llm_model| { label: llm_model.name, classes: ui_badge_classes(:neutral) } } + (page_state.text_verification_models.size > 3 ? [ { label: t("admin.settings.show.sections.llm_orchestration.panels.more_badge", count: page_state.text_verification_models.size - 3), classes: ui_badge_classes(:neutral) } ] : []) : [ { label: t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.verification_coverage.no_verifiers"), classes: ui_badge_classes(:neutral) } ]
                ) %>

                <div>
                  <%= label_tag "llm_role_assignments_text_generation", t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.fields.primary_model"), class: ui_label_classes %>
                  <%= select_tag "llm_role_assignments[text_generation][]", options_for_select([[t("admin.settings.show.sections.llm_orchestration.panels.no_model_selected"), ""]] + llm_model_options_for_select(page_state.text_llm_models), page_state.text_generation_model_id), class: ui_input_classes %>
                </div>

                <div>
                  <%= hidden_field_tag "llm_role_assignments[text_verification][]", "" %>
                  <details class="group">
                    <summary class="cursor-pointer list-none <%= ui_inset_panel_classes(tone: :subtle) %> flex items-center justify-between gap-3">
                      <span class="text-sm font-medium text-ink-700/80"><%= t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.fields.verification_models") %></span>
                      <span class="flex items-center gap-2">
                        <span class="<%= ui_badge_classes(page_state.text_verification_model_ids.any? ? :success : :neutral) %>"><%= t("admin.settings.show.sections.llm_orchestration.panels.text_workflow.fields.verification_disclosure_summary", count: page_state.text_verification_model_ids.size) %></span>
                      </span>
                    </summary>
                    <div class="mt-3 space-y-3">
                      <% page_state.text_llm_models.each do |llm_model| %>
                        <% selected = page_state.text_verification_model_ids.include?(llm_model.id) %>
                        <div class="<%= ui_inset_panel_classes(tone: selected ? :success : :subtle) %>">
                          <label class="flex items-start justify-between gap-4">
                            <span>
                              <span class="block text-sm font-medium text-ink-950"><%= llm_model.name %></span>
                              <span class="mt-1 block text-sm text-ink-700/80"><%= settings_llm_model_option_summary(llm_model) %></span>
                              <% if settings_llm_model_option_meta(llm_model).present? %>
                                <span class="mt-1 block text-xs text-ink-700/60"><%= settings_llm_model_option_meta(llm_model) %></span>
                              <% end %>
                            </span>
                            <span class="flex items-center gap-3">
                              <span class="<%= ui_badge_classes(selected ? :success : :neutral) %>"><%= selected ? t("admin.settings.show.sections.llm_orchestration.panels.option_status.selected") : t("admin.settings.show.sections.llm_orchestration.panels.option_status.optional") %></span>
                              <%= check_box_tag "llm_role_assignments[text_verification][]", llm_model.id, selected, class: "mt-1 #{ui_checkbox_classes}" %>
                            </span>
                          </label>
                        </div>
                      <% end %>
                    </div>
                  </details>
                </div>
              </div>
            <% end %>

            <%= render Ui::DashboardPanelComponent.new(
              eyebrow: t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.eyebrow"),
              title: page_state.vision_primary_model&.name || t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.title_fallback"),
              description: t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.description"),
              action_label: t("admin.settings.show.sections.llm_orchestration.panels.manage_models"),
              action_path: admin_llm_models_path,
              action_style: :secondary,
              padding: :sm,
              density: :compact
            ) do %>
              <div class="space-y-4">
                <%= render Ui::ReportRowComponent.new(
                  title: t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.current_primary_model.title"),
                  subtitle: page_state.vision_primary_model.present? ? settings_llm_model_option_summary(page_state.vision_primary_model) : t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.current_primary_model.subtitle_fallback"),
                  badge: page_state.vision_primary_model.present? ? page_state.vision_primary_model.name : t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.current_primary_model.badge_fallback"),
                  badge_classes: ui_badge_classes(page_state.vision_primary_model.present? ? :success : :neutral)
                ) %>

                <%= render Ui::ReportRowComponent.new(
                  title: t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.verification_coverage.title"),
                  subtitle: page_state.vision_verification_models.any? ? t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.verification_coverage.subtitle", count: page_state.vision_verification_models.size) : t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.verification_coverage.subtitle_none"),
                  badges: page_state.vision_verification_models.any? ? page_state.vision_verification_models.first(3).map { |llm_model| { label: llm_model.name, classes: ui_badge_classes(:neutral) } } + (page_state.vision_verification_models.size > 3 ? [ { label: t("admin.settings.show.sections.llm_orchestration.panels.more_badge", count: page_state.vision_verification_models.size - 3), classes: ui_badge_classes(:neutral) } ] : []) : [ { label: t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.verification_coverage.no_verifiers"), classes: ui_badge_classes(:neutral) } ]
                ) %>

                <div>
                  <%= label_tag "llm_role_assignments_vision_generation", t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.fields.primary_model"), class: ui_label_classes %>
                  <%= select_tag "llm_role_assignments[vision_generation][]", options_for_select([[t("admin.settings.show.sections.llm_orchestration.panels.no_model_selected"), ""]] + llm_model_options_for_select(page_state.vision_llm_models), page_state.vision_generation_model_id), class: ui_input_classes %>
                </div>

                <div>
                  <%= hidden_field_tag "llm_role_assignments[vision_verification][]", "" %>
                  <details class="group">
                    <summary class="cursor-pointer list-none <%= ui_inset_panel_classes(tone: :subtle) %> flex items-center justify-between gap-3">
                      <span class="text-sm font-medium text-ink-700/80"><%= t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.fields.verification_models") %></span>
                      <span class="flex items-center gap-2">
                        <span class="<%= ui_badge_classes(page_state.vision_verification_model_ids.any? ? :success : :neutral) %>"><%= t("admin.settings.show.sections.llm_orchestration.panels.vision_workflow.fields.verification_disclosure_summary", count: page_state.vision_verification_model_ids.size) %></span>
                      </span>
                    </summary>
                    <div class="mt-3 space-y-3">
                      <% page_state.vision_llm_models.each do |llm_model| %>
                        <% selected = page_state.vision_verification_model_ids.include?(llm_model.id) %>
                        <div class="<%= ui_inset_panel_classes(tone: selected ? :success : :subtle) %>">
                          <label class="flex items-start justify-between gap-4">
                            <span>
                              <span class="block text-sm font-medium text-ink-950"><%= llm_model.name %></span>
                              <span class="mt-1 block text-sm text-ink-700/80"><%= settings_llm_model_option_summary(llm_model) %></span>
                              <% if settings_llm_model_option_meta(llm_model).present? %>
                                <span class="mt-1 block text-xs text-ink-700/60"><%= settings_llm_model_option_meta(llm_model) %></span>
                              <% end %>
                            </span>
                            <span class="flex items-center gap-3">
                              <span class="<%= ui_badge_classes(selected ? :success : :neutral) %>"><%= selected ? t("admin.settings.show.sections.llm_orchestration.panels.option_status.selected") : t("admin.settings.show.sections.llm_orchestration.panels.option_status.optional") %></span>
                              <%= check_box_tag "llm_role_assignments[vision_verification][]", llm_model.id, selected, class: "mt-1 #{ui_checkbox_classes}" %>
                            </span>
                          </label>
                        </div>
                      <% end %>
                    </div>
                  </details>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <%= render Ui::WidgetCardComponent.new(
            eyebrow: t("admin.settings.show.sections.llm_orchestration.panels.empty_state.eyebrow"),
            title: t("admin.settings.show.sections.llm_orchestration.panels.empty_state.title"),
            description: t("admin.settings.show.sections.llm_orchestration.panels.empty_state.description"),
            badge: t("admin.settings.show.sections.llm_orchestration.panels.empty_state.badge"),
            badge_classes: ui_badge_classes(:warning),
            title_size: :base
          ) do %>
            <div class="flex flex-wrap gap-2">
              <%= link_to t("admin.settings.show.sections.llm_orchestration.panels.empty_state.actions.manage_providers"), admin_llm_providers_path, class: ui_button_classes(:secondary, size: :sm) %>
              <%= link_to t("admin.settings.show.sections.llm_orchestration.panels.empty_state.actions.manage_models"), admin_llm_models_path, class: ui_button_classes(:primary, size: :sm) %>
            </div>
          <% end %>
        <% end %>
      <% end %>

      <%= render Ui::StickyActionBarComponent.new(
        title: t("admin.settings.show.sticky_action_bar.title"),
        description: t("admin.settings.show.sticky_action_bar.description"),
        density: :compact
      ) do %>
        <span class="<%= ui_badge_classes(page_state.save_posture_ready? ? :success : :warning) %>"><%= page_state.save_posture_ready? ? t("admin.settings.show.sticky_action_bar.badges.save_posture.ready") : t("admin.settings.show.sticky_action_bar.badges.save_posture.follow_up") %></span>
        <span class="<%= ui_badge_classes(page_state.workflow_ready_count == 2 ? :success : :warning) %>"><%= t("admin.settings.show.sticky_action_bar.badges.workflows_assigned", count: page_state.workflow_ready_count) %></span>
        <span class="<%= ui_badge_classes(page_state.configured_cloud_import_provider_count == page_state.cloud_import_provider_states.size ? :success : :warning) %>"><%= t("admin.settings.show.sticky_action_bar.badges.connectors_configured", configured: page_state.configured_cloud_import_provider_count, total: page_state.cloud_import_provider_states.size) %></span>
        <%= link_to t("admin.settings.show.sticky_action_bar.actions.manage_providers"), admin_llm_providers_path, class: ui_button_classes(:secondary, size: :sm) %>
        <%= link_to t("admin.settings.show.sticky_action_bar.actions.manage_models"), admin_llm_models_path, class: ui_button_classes(:secondary, size: :sm) %>
        <%= form.submit t("admin.settings.show.sticky_action_bar.actions.save_settings"), class: ui_button_classes(:primary) %>
      <% end %>
    </div>
  <% end %>
</section>
