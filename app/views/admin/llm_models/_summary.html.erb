<% ready_count = llm_model_summary.fetch(:ready_count) %>
<% assigned_count = llm_model_summary.fetch(:assigned_count) %>
<% attention_count = llm_model_summary.fetch(:attention_count) %>
<% synced_count = llm_model_summary.fetch(:synced_count) %>
<% active_filter_count = [query.presence, status_filter.presence, capability_filter.presence].compact.count %>

<div class="mb-4 space-y-4">
  <%= render Ui::DashboardPanelComponent.new(
    eyebrow: t("admin.llm_models.index.summary.panel.eyebrow"),
    title: t("admin.llm_models.index.summary.panel.title"),
    description: active_filter_count.positive? ? t("admin.llm_models.index.summary.panel.description.filtered", count: total_count) : t("admin.llm_models.index.summary.panel.description.unfiltered"),
    action_label: active_filter_count.positive? ? t("admin.llm_models.index.summary.panel.actions.clear_filters") : t("admin.llm_models.index.summary.panel.actions.platform_settings"),
    action_path: active_filter_count.positive? ? admin_llm_models_path : admin_settings_path,
    action_style: :secondary,
    padding: :sm,
    density: :compact
  ) do %>
    <div class="flex flex-wrap gap-2">
      <% if query.present? %>
        <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.llm_models.index.summary.panel.filter_badges.query", query: query) %></span>
      <% end %>
      <% if status_filter.present? %>
        <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.llm_models.index.summary.panel.filter_badges.status", status: status_filter.humanize) %></span>
      <% end %>
      <% if capability_filter.present? %>
        <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.llm_models.index.summary.panel.filter_badges.capability", capability: capability_filter.humanize) %></span>
      <% end %>
      <% if active_filter_count.zero? %>
        <p class="w-full text-sm leading-6 text-ink-700/80"><%= t("admin.llm_models.index.summary.panel.guidance") %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("admin.llm_models.index.summary.cards.matches.eyebrow"),
      title: total_count.to_s,
      description: t("admin.llm_models.index.summary.cards.matches.description"),
      badge: t("admin.llm_models.index.summary.cards.matches.badge", count: llm_models.size),
      badge_classes: ui_badge_classes(:neutral),
      title_size: :base
    ) %>

    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("admin.llm_models.index.summary.cards.ready.eyebrow"),
      title: ready_count.to_s,
      description: t("admin.llm_models.index.summary.cards.ready.description"),
      tone: ready_count.positive? ? :success : :subtle,
      badge: ready_count.positive? ? t("admin.llm_models.index.summary.cards.ready.badges.ready") : t("admin.llm_models.index.summary.cards.ready.badges.empty"),
      badge_classes: ui_badge_classes(ready_count.positive? ? :success : :neutral),
      title_size: :base
    ) %>

    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("admin.llm_models.index.summary.cards.assigned.eyebrow"),
      title: assigned_count.to_s,
      description: t("admin.llm_models.index.summary.cards.assigned.description"),
      tone: assigned_count.positive? ? :success : :subtle,
      badge: assigned_count.positive? ? t("admin.llm_models.index.summary.cards.assigned.badges.assigned") : t("admin.llm_models.index.summary.cards.assigned.badges.unassigned"),
      badge_classes: ui_badge_classes(assigned_count.positive? ? :success : :neutral),
      title_size: :base
    ) %>

    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("admin.llm_models.index.summary.cards.attention.eyebrow"),
      title: attention_count.to_s,
      description: t("admin.llm_models.index.summary.cards.attention.description"),
      tone: attention_count.positive? ? :default : :subtle,
      badge: synced_count.positive? ? t("admin.llm_models.index.summary.cards.attention.badges.synced", count: synced_count) : t("admin.llm_models.index.summary.cards.attention.badges.pending"),
      badge_classes: ui_badge_classes(attention_count.positive? ? :warning : :success),
      title_size: :base
    ) %>
  </div>
</div>
