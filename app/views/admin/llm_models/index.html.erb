<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: t("admin.llm_models.index.page_header.eyebrow"),
    title: t("admin.llm_models.index.page_header.title"),
    description: t("admin.llm_models.index.page_header.description"),
    density: :compact,
    actions: [
      { label: t("admin.llm_models.index.page_header.actions.platform_settings"), path: admin_settings_path, style: :secondary },
      { label: t("admin.llm_models.index.page_header.actions.manage_providers"), path: admin_llm_providers_path, style: :secondary },
      { label: t("admin.llm_models.index.page_header.actions.new_model"), path: new_admin_llm_model_path, style: :primary }
    ]
  ) %>

  <%= render partial: "shared/admin_async_table", locals: {
    frame_id: "admin_llm_models_table",
    filter_keys: %i[query status capability],
    filter_partial: "admin/llm_models/filters",
    filter_locals: {
      query: @query,
      status_filter: @status_filter,
      capability_filter: @capability_filter,
      sort: @sort,
      direction: @direction,
      total_count: @total_count
    },
    before_table_partial: "admin/llm_models/summary",
    before_table_locals: {
      llm_models: @llm_models,
      llm_model_summary: @llm_model_summary,
      total_count: @total_count,
      query: @query,
      status_filter: @status_filter,
      capability_filter: @capability_filter
    },
    table_partial: "admin/llm_models/table",
    table_locals: {
      llm_models: @llm_models,
      sort: @sort,
      direction: @direction
    },
    current_page: @current_page,
    total_pages: @total_pages,
    pagination_base_path: admin_llm_models_path
  } %>
</section>
