<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
  <%= render Ui::MetricCardComponent.new(
    label: "Jobs in scope",
    value: job_log_stats.total,
    description: "#{pluralize(job_log_stats.completed, "completed job")} with the current filters."
  ) %>

  <%= render Ui::MetricCardComponent.new(
    label: "Failure rate",
    value: number_to_percentage(job_log_stats.failure_rate, precision: 1),
    description: "#{pluralize(job_log_stats.failed, "failed job")} out of #{pluralize(job_log_stats.completed, "completed job")}."
  ) %>

  <%= render Ui::MetricCardComponent.new(
    label: "Average runtime",
    value: job_duration_label(job_log_stats.average_duration_seconds),
    description: "Based on jobs that recorded a finish duration."
  ) %>

  <%= render Ui::MetricCardComponent.new(
    label: "Throughput",
    value: throughput_label(job_log_stats.completed_last_hour),
    description: "#{pluralize(job_log_stats.stale_running, "stale running job")} need attention."
  ) %>
</div>

<div class="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
  <%= render Ui::DashboardPanelComponent.new(
    eyebrow: "Direct lookup",
    title: "Paste an Active Job ID",
    description: "Use the search box below to jump straight to the job you pushed for later debugging.",
    padding: :sm,
    density: :compact
  ) do %>
    <div class="flex items-start justify-between gap-4">
      <div></div>
      <% if exact_match_job_log %>
        <span class="<%= ui_badge_classes(job_log_status_badge_tone(exact_match_job_log)) %>"><%= exact_match_job_log.status.humanize %></span>
      <% end %>
    </div>

    <% if exact_match_job_log %>
      <div class="mt-4 <%= ui_inset_panel_classes(tone: :success) %>">
        <p class="text-sm font-medium text-ink-950"><%= exact_match_job_log.job_type %></p>
        <p class="mt-1 break-all text-sm text-ink-700/80"><%= exact_match_job_log.active_job_id %></p>
        <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-ink-700/80">
          <span>Queue: <%= exact_match_job_log.queue_name %></span>
          <span>Created: <%= l(exact_match_job_log.created_at, format: :short) %></span>
          <%= link_to "Open detail", admin_job_log_path(exact_match_job_log), class: ui_button_classes(:secondary, size: :sm), data: { turbo_frame: "_top" } %>
        </div>
      </div>
    <% elsif query.present? %>
      <div class="mt-4">
        <%= render Ui::EmptyStateComponent.new(
          description: "No exact `active_job_id` matched `#{query}`. Broad search results are listed below.",
          padding: :sm,
          tone: :subtle,
          align: :left
        ) %>
      </div>
    <% else %>
      <div class="mt-4">
        <%= render Ui::EmptyStateComponent.new(
          description: "Paste an `active_job_id` into the search box to find a single execution quickly.",
          padding: :sm,
          tone: :subtle,
          align: :left
        ) %>
      </div>
    <% end %>
  <% end %>

  <%= render Ui::DashboardPanelComponent.new(
    eyebrow: "Queue runtime",
    title: "Solid Queue overview",
    description: "Inspect backlog, running work, failures, and worker health before drilling into a specific execution.",
    padding: :sm,
    density: :compact
  ) do %>
    <div class="flex items-start justify-between gap-4">
      <div></div>
      <% unless queue_overview.unavailable? %>
        <span class="<%= ui_badge_classes(queue_state_badge_tone(queue_overview.failed.positive? ? :failed : :running)) %>"><%= queue_overview.backlog %> backlog</span>
      <% end %>
    </div>

    <% if queue_overview.unavailable? %>
      <div class="mt-4">
        <%= render Ui::EmptyStateComponent.new(
          description: queue_overview.error_message,
          padding: :sm,
          tone: :subtle,
          align: :left
        ) %>
      </div>
    <% else %>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <%= render Ui::WidgetCardComponent.new(
          eyebrow: "Backlog",
          title: queue_overview.backlog,
          description: "#{queue_overview.queued} ready, #{queue_overview.scheduled} scheduled, #{queue_overview.blocked} blocked",
          tone: queue_overview.backlog.positive? ? :subtle : :success,
          padding: :sm
        ) %>
        <%= render Ui::WidgetCardComponent.new(
          eyebrow: "Running now",
          title: queue_overview.running,
          description: "#{pluralize(queue_overview.processes, "worker process")} connected.",
          tone: queue_overview.running.positive? ? :subtle : :success,
          padding: :sm
        ) %>
        <%= render Ui::WidgetCardComponent.new(
          eyebrow: "Queue failures",
          title: queue_overview.failed,
          description: "Solid Queue failed execution rows waiting for retry or cleanup.",
          tone: queue_overview.failed.positive? ? :default : :success,
          padding: :sm
        ) %>
        <%= render Ui::WidgetCardComponent.new(
          eyebrow: "Worker health",
          title: "#{queue_overview.processes - queue_overview.stale_processes}/#{queue_overview.processes}",
          description: "#{pluralize(queue_overview.stale_processes, "stale worker")} missed recent heartbeats.",
          tone: queue_overview.stale_processes.positive? ? :default : :success,
          padding: :sm
        ) %>
      </div>
    <% end %>
  <% end %>
</div>
