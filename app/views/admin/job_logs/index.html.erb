<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: "Admin",
    title: "Job logs",
    description: "Review background jobs, queue health, and failures.",
    density: :compact,
    badges: [
      { label: throughput_label(@job_log_stats.completed_last_hour), tone: :neutral },
      { label: pluralize(@job_log_stats.stale_running, "stale running job"), tone: @job_log_stats.stale_running.positive? ? :warning : :neutral }
    ]
  ) %>

  <%= render partial: "shared/admin_async_table", locals: {
    frame_id: "admin_job_logs_table",
    filter_keys: %i[query status],
    before_table_partial: "admin/job_logs/frame_panels",
    before_table_locals: {
      job_log_stats: @job_log_stats,
      queue_overview: @queue_overview,
      exact_match_job_log: @exact_match_job_log,
      query: @query
    },
    filter_partial: "admin/job_logs/filters",
    filter_locals: {
      query: @query,
      status_filter: @status_filter,
      sort: @sort,
      direction: @direction,
      total_count: @total_count
    },
    table_partial: "admin/job_logs/table",
    table_locals: {
      job_logs: @job_logs,
      sort: @sort,
      direction: @direction
    },
    current_page: @current_page,
    total_pages: @total_pages,
    pagination_base_path: admin_job_logs_path
  } %>
</section>
