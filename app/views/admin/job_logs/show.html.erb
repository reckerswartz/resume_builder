<% related_error_state = job_log_related_error_state(@job_log) %>
<% related_error_reference = related_error_state.reference %>
<% related_error_log = related_error_state.error_log %>
<% runtime_state = job_log_runtime_state(@job_log, @queue_snapshot) %>
<% runtime_label = runtime_state.label %>
<% runtime_tone = runtime_state.tone %>
<% runtime_description = runtime_state.description %>
<% control_state = job_log_control_state(@job_log, @queue_snapshot) %>
<% control_actions = [] %>
<% if control_state.retry_available? %>
  <% control_actions << {
       label: t(".actions.retry"),
       path: retry_admin_job_log_path(@job_log),
       style: :secondary,
       method: :post,
       confirm: t(".actions.retry_confirm")
     } %>
<% end %>
<% if control_state.requeue_available? %>
  <% control_actions << {
       label: control_state.requeue_label,
       path: requeue_admin_job_log_path(@job_log),
       style: :primary,
       method: :post,
       confirm: control_state.requeue_confirm
     } %>
<% end %>
<% if control_state.discard_available? %>
  <% control_actions << {
       label: t(".actions.discard"),
       path: discard_admin_job_log_path(@job_log),
       style: :danger,
       method: :post,
       confirm: control_state.discard_confirm
     } %>
<% end %>
<% section_links = [
     { id: "queue-controls", label: t(".navigation.sections.follow_up.label"), caption: t(".navigation.sections.follow_up.caption") },
     { id: "runtime-snapshot", label: t(".navigation.sections.live_queue.label"), caption: t(".navigation.sections.live_queue.caption") },
     { id: "captured-payloads", label: t(".navigation.sections.payloads.label"), caption: t(".navigation.sections.payloads.caption") }
   ] %>
<% runtime_items = [] %>
<% if @job_log.stale? %>
  <% runtime_items << {
       label: t(".triage.items.stale_running.label"),
       detail: t(".triage.items.stale_running.detail"),
       tone: :warning
     } %>
<% end %>
<% if @queue_snapshot.unavailable? %>
  <% runtime_items << {
       label: t(".triage.items.queue_unavailable"),
       detail: runtime_description,
       tone: :neutral
     } %>
<% elsif !@queue_snapshot.found? %>
  <% runtime_items << {
       label: t(".triage.items.queue_missing"),
       detail: runtime_description,
       tone: :neutral
     } %>
<% elsif @queue_snapshot.orphaned_claimed? %>
  <% runtime_items << {
       label: t(".triage.items.orphaned_running"),
       detail: runtime_description,
       tone: :warning
     } %>
<% elsif @queue_snapshot.retryable? && @job_log.failed? %>
  <% runtime_items << {
       label: t(".triage.items.retryable_failed.label"),
       detail: t(".triage.items.retryable_failed.detail"),
       tone: :warning
     } %>
<% else %>
  <% runtime_items << {
       label: t(".triage.items.live_queue_available"),
       detail: runtime_description,
       tone: :success
     } %>
<% end %>
<% if related_error_log.present? %>
  <% runtime_items << {
       label: t(".triage.items.related_error_available.label"),
       detail: t(".triage.items.related_error_available.detail", reference_id: related_error_log.reference_id),
       tone: :neutral
     } %>
<% elsif related_error_reference.present? %>
  <% runtime_items << {
       label: t(".triage.items.related_error_reference.label"),
       detail: t(".triage.items.related_error_reference.detail", reference_id: related_error_reference),
       tone: :neutral
     } %>
<% end %>
<% triage_tone = if runtime_items.any? { |item| item.fetch(:tone, :neutral) == :warning }
     :warning
   elsif runtime_items.any? { |item| item.fetch(:tone, :neutral) != :success }
     :neutral
   else
     :success
   end %>
<% triage_title = case triage_tone
  when :warning
    t(".triage.titles.warning")
  when :neutral
    t(".triage.titles.neutral")
  else
    t(".triage.titles.success")
  end %>

<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: t(".page_header.eyebrow"),
    title: @job_log.job_type,
    description: t(".page_header.description"),
    badges: [
      { label: @job_log.status.humanize, tone: job_log_status_badge_tone(@job_log) },
      { label: runtime_label, tone: runtime_tone },
      (@job_log.stale? ? { label: t(".page_header.badges.stale_running"), tone: :warning } : nil),
      { label: job_duration_label(@job_log.duration_seconds), tone: :neutral }
    ].compact,
    actions: [
      { label: t(".page_header.actions.back"), path: admin_job_logs_path, style: :secondary },
      (related_error_log.present? ? { label: t(".page_header.actions.open_related_error"), path: admin_error_log_path(related_error_log), style: :secondary } : nil),
      { label: t(".page_header.actions.error_logs"), path: admin_error_logs_path, style: :secondary }
    ].compact,
    density: :compact
  ) %>

  <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
    <div class="space-y-4">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
            <%= t(".triage.pill") %>
          </span>
          <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= t(".triage.title") %></h2>
          <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t(".triage.description") %></p>
        </div>

        <span class="<%= ui_badge_classes(triage_tone) %>"><%= triage_title %></span>
      </div>

      <div class="flex flex-wrap gap-2">
        <span class="<%= ui_badge_classes(job_log_status_badge_tone(@job_log)) %>"><%= @job_log.status.humanize %></span>
        <span class="<%= ui_badge_classes(runtime_tone) %>"><%= runtime_label %></span>
        <span class="<%= ui_badge_classes(control_actions.any? ? :warning : :neutral) %>"><%= control_actions.any? ? t(".triage.badges.safe_action_count", count: control_actions.size) : t(".triage.badges.read_only") %></span>
        <span class="<%= ui_badge_classes(related_error_log.present? ? :success : :neutral) %>"><%= related_error_log.present? ? t(".triage.badges.related_error") : related_error_reference.present? ? t(".triage.badges.error_reference") : t(".triage.badges.no_related_error") %></span>
      </div>

      <div class="space-y-3">
        <% runtime_items.each do |item| %>
          <div class="<%= ui_inset_panel_classes(tone: item.fetch(:tone, :neutral) == :success ? :success : item.fetch(:tone, :neutral) == :warning ? :default : :subtle) %>">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-sm font-medium text-ink-950"><%= item.fetch(:label) %></p>
                <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= item.fetch(:detail) %></p>
              </div>

              <span class="<%= ui_badge_classes(item.fetch(:tone, :neutral)) %>">
                <%= item.fetch(:tone) == :success ? t(".triage.badges.ready") : item.fetch(:tone) == :warning ? t(".triage.badges.attention") : t(".triage.badges.follow_up") %>
              </span>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex flex-wrap gap-2">
        <% control_actions.each do |action| %>
          <%= link_to action.fetch(:label), action.fetch(:path), class: ui_button_classes(action.fetch(:style), size: :sm), data: { turbo_method: action.fetch(:method), turbo_confirm: action.fetch(:confirm) }.compact %>
        <% end %>
        <% if related_error_log.present? %>
          <%= link_to t(".page_header.actions.open_related_error"), admin_error_log_path(related_error_log), class: ui_button_classes(:secondary, size: :sm) %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid gap-6 xl:grid-cols-[16rem_minmax(0,1fr)]">
    <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
      <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
        <div class="space-y-4">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
              <%= t(".navigation.pill") %>
            </span>
            <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= t(".navigation.title") %></h2>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t(".navigation.description") %></p>
          </div>

          <div class="space-y-3">
            <% section_links.each do |section| %>
              <%= render Ui::SectionLinkCardComponent.new(
                label: section.fetch(:label),
                caption: section.fetch(:caption),
                path: "##{section.fetch(:id)}"
              ) %>
            <% end %>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: related_error_log.present? ? :success : :subtle) %>">
            <p class="text-sm font-medium text-ink-950"><%= t(".navigation.related_error.title") %></p>
            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= related_error_state.description %></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(related_error_log.present? ? :success : :neutral) %>"><%= related_error_log&.reference_id || related_error_reference || t(".navigation.related_error.missing_reference") %></span>
            </div>
          </div>

          <div class="flex flex-wrap gap-2">
            <%= link_to t(".page_header.actions.error_logs"), admin_error_logs_path, class: ui_button_classes(:secondary, size: :sm) %>
          </div>
        </div>
      <% end %>
    </aside>

    <div class="space-y-6">
      <%= render Ui::SettingsSectionComponent.new(
        title: t(".follow_up_section.title"),
        anchor: "queue-controls",
        eyebrow: t(".follow_up_section.eyebrow"),
        description: t(".follow_up_section.description"),
        badges: [
          { label: @job_log.status.humanize, tone: job_log_status_badge_tone(@job_log) },
          { label: runtime_label, tone: runtime_tone }
        ]
      ) do %>
        <div class="space-y-4">
          <div class="<%= ui_inset_panel_classes(tone: control_actions.any? ? :default : :subtle) %>">
            <p class="text-sm font-medium text-ink-950"><%= t(".follow_up_section.summary.title") %></p>
            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= control_state.summary %></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(control_actions.any? ? :warning : :neutral) %>"><%= control_actions.any? ? t(".follow_up_section.summary.safe_action_count", count: control_actions.size) : t(".follow_up_section.summary.no_safe_action") %></span>
              <span class="<%= ui_badge_classes(related_error_reference.present? ? :warning : :neutral) %>"><%= related_error_reference.present? ? t(".follow_up_section.summary.error_reference_recorded") : t(".follow_up_section.summary.no_error_reference") %></span>
            </div>
          </div>

          <div class="space-y-3">
            <% runtime_items.each do |item| %>
              <div class="<%= ui_inset_panel_classes(tone: item.fetch(:tone, :neutral) == :success ? :success : item.fetch(:tone, :neutral) == :warning ? :default : :subtle) %>">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="text-sm font-medium text-ink-950"><%= item.fetch(:label) %></p>
                    <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= item.fetch(:detail) %></p>
                  </div>

                  <span class="<%= ui_badge_classes(item.fetch(:tone, :neutral)) %>">
                    <%= item.fetch(:tone) == :success ? t(".triage.badges.ready") : item.fetch(:tone) == :warning ? t(".triage.badges.attention") : t(".triage.badges.follow_up") %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>

          <% unless control_actions.any? %>
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-950"><%= t(".follow_up_section.empty_state.title") %></p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".follow_up_section.empty_state.description") %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t(".live_queue_section.title"),
        anchor: "runtime-snapshot",
        eyebrow: t(".live_queue_section.eyebrow"),
        description: t(".live_queue_section.description"),
        badges: [
          { label: @job_log.stale? ? t(".page_header.badges.stale_running") : @job_log.status.humanize, tone: @job_log.stale? ? :warning : job_log_status_badge_tone(@job_log) },
          { label: runtime_label, tone: runtime_tone }
        ]
      ) do %>
        <div class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            <div class="<%= ui_inset_panel_classes(tone: runtime_tone == :success ? :success : runtime_tone == :warning || runtime_tone == :danger ? :default : :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.cards.status") %></p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(runtime_tone) %>"><%= runtime_label %></span>
                <span class="text-sm leading-6 text-ink-700/80"><%= runtime_description %></span>
              </div>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.cards.job_reference") %></p>
              <p class="mt-2 break-all text-sm text-ink-950"><%= @job_log.active_job_id.presence || "N/A" %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.cards.duration") %></p>
              <p class="mt-2 text-sm text-ink-950"><%= job_duration_label(@job_log.duration_seconds) %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.cards.queue_name") %></p>
              <p class="mt-2 text-sm text-ink-950"><%= @job_log.queue_name %></p>
            </div>

            <div class="<%= [ui_inset_panel_classes(tone: related_error_log.present? ? :success : :subtle), 'sm:col-span-2'].join(' ') %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.cards.related_error_reference") %></p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(related_error_log.present? ? :success : :neutral) %>"><%= related_error_reference || t(".live_queue_section.cards.none") %></span>
                <% if related_error_log.present? %>
                  <%= link_to t(".page_header.actions.open_related_error"), admin_error_log_path(related_error_log), class: ui_button_classes(:secondary, size: :sm) %>
                <% else %>
                  <span class="text-sm leading-6 text-ink-700/80"><%= related_error_reference.present? ? t(".live_queue_section.cards.no_matching_error") : t(".live_queue_section.cards.no_related_error") %></span>
                <% end %>
              </div>
            </div>
          </div>

          <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92">
            <summary class="cursor-pointer px-5 py-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-950"><%= t(".live_queue_section.details.title") %></p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".live_queue_section.details.description") %></p>
                </div>

                <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".live_queue_section.details.badge") %></span>
              </div>
            </summary>

            <div class="border-t border-canvas-200/80 px-5 py-5">
              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                  <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.details.fields.created_at") %></p>
                  <p class="mt-2 text-sm text-ink-950"><%= l(@job_log.created_at, format: :long) %></p>
                </div>

                <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                  <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.details.fields.started_at") %></p>
                  <p class="mt-2 text-sm text-ink-950"><%= @job_log.started_at ? l(@job_log.started_at, format: :long) : "N/A" %></p>
                </div>

                <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                  <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.details.fields.finished_at") %></p>
                  <p class="mt-2 text-sm text-ink-950"><%= @job_log.finished_at ? l(@job_log.finished_at, format: :long) : "N/A" %></p>
                </div>

                <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                  <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.details.fields.queue_record") %></p>
                  <p class="mt-2 text-sm text-ink-950"><%= @queue_snapshot.job&.id || "N/A" %></p>
                </div>

                <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                  <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.details.fields.worker_process") %></p>
                  <p class="mt-2 text-sm text-ink-950"><%= runtime_state.worker_label %></p>
                </div>

                <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                  <p class="text-sm font-medium text-ink-700/80"><%= t(".live_queue_section.details.fields.last_heartbeat") %></p>
                  <p class="mt-2 text-sm text-ink-950"><%= @queue_snapshot.process&.last_heartbeat_at ? l(@queue_snapshot.process.last_heartbeat_at, format: :long) : "N/A" %></p>
                </div>
              </div>
            </div>
          </details>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t(".payloads_section.title"),
        anchor: "captured-payloads",
        eyebrow: t(".payloads_section.eyebrow"),
        description: t(".payloads_section.description"),
        badges: [
          { label: @queue_snapshot.available && @queue_snapshot.found? ? t(".payloads_section.badges.queue_details_available") : t(".payloads_section.badges.log_payload_only"), tone: @queue_snapshot.available && @queue_snapshot.found? ? :success : :neutral },
          { label: related_error_reference.present? ? t(".payloads_section.badges.error_reference_recorded") : t(".payloads_section.badges.no_error_reference"), tone: related_error_reference.present? ? :warning : :neutral }
        ]
      ) do %>
        <div class="min-w-0 space-y-4">
          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-950"><%= t(".payloads_section.intro.title") %></p>
            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".payloads_section.intro.description") %></p>
          </div>

          <% if @queue_snapshot.available && @queue_snapshot.found? %>
            <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92">
              <summary class="cursor-pointer px-5 py-4">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p class="text-sm font-medium text-ink-950"><%= t(".payloads_section.queue_record.title") %></p>
                    <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".payloads_section.queue_record.description") %></p>
                  </div>

                  <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".payloads_section.queue_record.badge") %></span>
                </div>
              </summary>

              <div class="border-t border-canvas-200/80 px-5 py-5">
                <%= render Ui::CodeBlockComponent.new(
                  title: t(".payloads_section.queue_record.code_block_title"),
                  description: t(".payloads_section.queue_record.description"),
                  body: formatted_debug_payload(@queue_snapshot.job.attributes.slice("id", "active_job_id", "class_name", "queue_name", "priority", "scheduled_at", "finished_at", "concurrency_key", "created_at", "updated_at").merge("arguments" => @queue_snapshot.job.arguments))
                ) %>
              </div>
            </details>
          <% end %>

          <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92">
            <summary class="cursor-pointer px-5 py-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-950"><%= t(".payloads_section.application_payloads.title") %></p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".payloads_section.application_payloads.description") %></p>
                </div>

                <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".payloads_section.application_payloads.badge") %></span>
              </div>
            </summary>

            <div class="border-t border-canvas-200/80 px-5 py-5">
              <div class="space-y-4">
                <%= render Ui::CodeBlockComponent.new(
                  title: t(".payloads_section.application_payloads.input_title"),
                  description: t(".payloads_section.application_payloads.input_description"),
                  body: formatted_debug_payload(@job_log.input)
                ) %>

                <%= render Ui::CodeBlockComponent.new(
                  title: t(".payloads_section.application_payloads.output_title"),
                  description: t(".payloads_section.application_payloads.output_description"),
                  body: formatted_debug_payload(@job_log.output)
                ) %>

                <%= render Ui::CodeBlockComponent.new(
                  title: t(".payloads_section.application_payloads.errors_title"),
                  description: t(".payloads_section.application_payloads.errors_description"),
                  body: formatted_debug_payload(@job_log.error_details),
                  tone: @job_log.failed? ? :danger : :default
                ) %>
              </div>
            </div>
          </details>

          <% if @queue_snapshot.failed_execution.present? || @queue_snapshot.process.present? %>
            <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92">
              <summary class="cursor-pointer px-5 py-4">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p class="text-sm font-medium text-ink-950"><%= t(".payloads_section.deep_queue_details.title") %></p>
                    <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".payloads_section.deep_queue_details.description") %></p>
                  </div>

                  <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".payloads_section.deep_queue_details.badge") %></span>
                </div>
              </summary>

              <div class="border-t border-canvas-200/80 px-5 py-5">
                <div class="space-y-4">
                  <% if @queue_snapshot.failed_execution.present? %>
                    <%= render Ui::CodeBlockComponent.new(
                      title: t(".payloads_section.deep_queue_details.failure_title"),
                      description: t(".payloads_section.deep_queue_details.failure_description"),
                      body: formatted_debug_payload(@queue_snapshot.failed_execution.error),
                      tone: :danger
                    ) %>
                  <% end %>

                  <% if @queue_snapshot.process.present? %>
                    <%= render Ui::CodeBlockComponent.new(
                      title: t(".payloads_section.deep_queue_details.worker_title"),
                      description: t(".payloads_section.deep_queue_details.worker_description"),
                      body: formatted_debug_payload(@queue_snapshot.process.attributes.slice("id", "kind", "name", "hostname", "pid", "supervisor_id", "last_heartbeat_at", "created_at").merge("metadata" => @queue_snapshot.process.metadata))
                    ) %>
                  <% end %>
                </div>
              </div>
            </details>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
