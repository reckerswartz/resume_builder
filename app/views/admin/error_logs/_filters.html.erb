<%= form_with url: admin_error_logs_path, method: :get, class: "border-b border-canvas-200/80 bg-canvas-100/84 px-6 py-5", data: { controller: "autosave" } do |form| %>
  <%= form.hidden_field :sort, value: sort %>
  <%= form.hidden_field :direction, value: direction %>

  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-ink-700/70"><%= t("admin.error_logs.index.filters.eyebrow") %></p>
        <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("admin.error_logs.index.filters.description") %></p>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <% if query.present? || source_filter.present? %>
          <%= link_to t("admin.error_logs.index.filters.actions.clear_filters"), admin_error_logs_path, class: ui_button_classes(:secondary, size: :sm) %>
        <% end %>
        <%= form.submit t("admin.error_logs.index.filters.actions.apply"), class: ui_button_classes(:primary, size: :sm) %>
      </div>
    </div>

    <div class="grid flex-1 gap-3 md:grid-cols-[minmax(0,1fr)_14rem_auto] xl:items-end">
      <div class="space-y-2">
        <%= form.label :query, t("admin.error_logs.index.filters.fields.query_label"), class: ui_label_classes %>
        <%= form.search_field :query, value: query, placeholder: t("admin.error_logs.index.filters.fields.query_placeholder"), class: ui_input_classes, data: { action: "input->autosave#queue search->autosave#queue" } %>
      </div>

      <div class="space-y-2">
        <%= form.label :source, t("admin.error_logs.index.filters.fields.source_label"), class: ui_label_classes %>
        <%= form.select :source, options_for_select([[t("admin.error_logs.index.filters.fields.all_sources"), ""]] + ErrorLog.sources.keys.map { |source| [source.humanize, source] }, source_filter), {}, class: ui_input_classes, data: { action: "change->autosave#queue" } %>
      </div>

      <div class="pb-1 text-left md:text-right">
        <p class="text-sm text-ink-700/70"><%= pluralize(total_count, "error log") %></p>
      </div>
    </div>
  </div>
<% end %>
