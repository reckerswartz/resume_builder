<% related_job_log = error_log_related_job_log(@error_log) %>
<% request_summary = error_log_request_summary(@error_log) %>
<% primary_reference_label = error_log_primary_reference_label(@error_log) %>
<% primary_reference_description = error_log_primary_reference_description(@error_log) %>
<% section_links = [
     { id: "incident-summary", label: t(".navigation.sections.incident_summary.label"), caption: t(".navigation.sections.incident_summary.caption") },
     { id: "captured-context", label: t(".navigation.sections.captured_context.label"), caption: t(".navigation.sections.captured_context.caption") },
     { id: "backtrace", label: t(".navigation.sections.backtrace.label"), caption: t(".navigation.sections.backtrace.caption") }
   ] %>

<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: t(".page_header.eyebrow"),
    title: @error_log.reference_id,
    description: t(".page_header.description"),
    badges: [
      { label: error_log_source_label(@error_log), tone: error_log_source_badge_tone(@error_log) },
      (related_job_log.present? ? { label: t(".page_header.badges.related_job"), tone: :success } : nil),
      (@error_log.backtrace_lines.any? ? { label: pluralize(@error_log.backtrace_lines.size, "frame"), tone: :neutral } : { label: t(".page_header.badges.no_backtrace"), tone: :neutral }),
      { label: error_log_duration_label(@error_log), tone: :neutral }
    ].compact,
    actions: [
      { label: t(".page_header.actions.back"), path: admin_error_logs_path, style: :secondary },
      (related_job_log.present? ? { label: t(".page_header.actions.open_related_job"), path: admin_job_log_path(related_job_log), style: :secondary } : nil),
      (@error_log.job? ? { label: t(".page_header.actions.job_logs"), path: admin_job_logs_path, style: :secondary } : nil)
    ].compact,
    density: :compact
  ) %>

  <div class="grid gap-6 xl:grid-cols-[16rem_minmax(0,1fr)]">
    <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
      <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
        <div class="space-y-4">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
              <%= t(".navigation.pill") %>
            </span>
            <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= t(".navigation.title") %></h2>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t(".navigation.description") %></p>
          </div>

          <div class="space-y-3">
            <% section_links.each do |section| %>
              <%= render Ui::SectionLinkCardComponent.new(
                label: section.fetch(:label),
                caption: section.fetch(:caption),
                path: "##{section.fetch(:id)}"
              ) %>
            <% end %>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: related_job_log.present? ? :success : :subtle) %>">
            <p class="text-sm font-medium text-ink-950"><%= t(".navigation.correlation.title") %></p>
            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= primary_reference_description %></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(related_job_log.present? ? :success : :neutral) %>"><%= primary_reference_label %></span>
            </div>
          </div>

          <div class="flex flex-wrap gap-2">
            <% if related_job_log.present? %>
              <%= link_to t(".page_header.actions.open_related_job"), admin_job_log_path(related_job_log), class: ui_button_classes(:secondary, size: :sm) %>
            <% else %>
              <%= link_to t(".page_header.actions.back"), admin_error_logs_path, class: ui_button_classes(:secondary, size: :sm) %>
            <% end %>
          </div>
        </div>
      <% end %>
    </aside>

    <div class="space-y-6">
      <%= render Ui::SettingsSectionComponent.new(
        title: t(".incident_summary.title"),
        anchor: "incident-summary",
        eyebrow: t(".incident_summary.eyebrow"),
        description: t(".incident_summary.description"),
        badges: [
          { label: error_log_source_label(@error_log), tone: error_log_source_badge_tone(@error_log) },
          { label: related_job_log.present? ? t(".incident_summary.badges.related_job") : t(".incident_summary.badges.standalone"), tone: related_job_log.present? ? :success : :neutral }
        ]
      ) do %>
        <div class="space-y-4">
          <div class="<%= ui_inset_panel_classes(tone: :danger, padding: :lg) %>">
            <p class="text-sm font-medium text-rose-700"><%= t(".triage.message_title") %></p>
            <p class="mt-2 text-sm text-rose-900"><%= @error_log.message %></p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".incident_summary.cards.error_class") %></p>
              <p class="mt-2 break-all text-sm text-ink-950"><%= @error_log.error_class %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".incident_summary.cards.source") %></p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(error_log_source_badge_tone(@error_log)) %>"><%= error_log_source_label(@error_log) %></span>
                <span class="text-sm leading-6 text-ink-700/80"><%= error_log_source_description(@error_log) %></span>
              </div>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".incident_summary.cards.occurred_at") %></p>
              <p class="mt-2 text-sm text-ink-950"><%= l(@error_log.occurred_at, format: :long) %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".incident_summary.cards.duration") %></p>
              <p class="mt-2 text-sm text-ink-950"><%= error_log_duration_label(@error_log) %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= @error_log.job? ? t(".incident_summary.cards.job_reference") : t(".incident_summary.cards.request_reference") %></p>
              <p class="mt-2 break-all text-sm text-ink-950"><%= primary_reference_label %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".incident_summary.cards.correlation_summary") %></p>
              <p class="mt-2 text-sm leading-6 text-ink-950"><%= primary_reference_description %></p>
            </div>
          </div>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t(".captured_context.title"),
        anchor: "captured-context",
        eyebrow: t(".captured_context.eyebrow"),
        description: t(".captured_context.description"),
        badges: [
          { label: @error_log.job? ? t(".captured_context.badges.job_context") : t(".captured_context.badges.request_context"), tone: error_log_source_badge_tone(@error_log) },
          { label: related_job_log.present? ? t(".captured_context.badges.job_log_available") : t(".captured_context.badges.no_related_job_log"), tone: related_job_log.present? ? :success : :neutral }
        ]
      ) do %>
        <div class="space-y-4 min-w-0">
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".captured_context.cards.request_path") %></p>
              <p class="mt-2 break-all text-sm text-ink-950"><%= request_summary || "N/A" %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".captured_context.cards.user_id") %></p>
              <p class="mt-2 text-sm text-ink-950"><%= @error_log.context["user_id"].presence || "N/A" %></p>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: related_job_log.present? ? :success : :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80"><%= t(".captured_context.cards.related_job") %></p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(related_job_log.present? ? :success : :neutral) %>"><%= error_log_related_job_label(@error_log) %></span>
                <% if related_job_log.present? %>
                  <%= link_to t(".page_header.actions.open_related_job"), admin_job_log_path(related_job_log), class: ui_button_classes(:secondary, size: :sm) %>
                <% end %>
              </div>
            </div>
          </div>

          <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92">
            <summary class="cursor-pointer px-5 py-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-950"><%= t(".captured_context.details.title") %></p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".captured_context.details.description") %></p>
                </div>

                <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".captured_context.details.badge") %></span>
              </div>
            </summary>

            <div class="border-t border-canvas-200/80 px-5 py-5">
              <%= render Ui::CodeBlockComponent.new(
                title: t(".captured_context.details.code_block_title"),
                description: t(".captured_context.details.code_block_description"),
                body: JSON.pretty_generate(@error_log.context),
                wrap: true
              ) %>
            </div>
          </details>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t(".backtrace.title"),
        anchor: "backtrace",
        eyebrow: t(".backtrace.eyebrow"),
        description: t(".backtrace.description"),
        badges: [
          { label: @error_log.backtrace_lines.any? ? pluralize(@error_log.backtrace_lines.size, "frame") : t(".backtrace.badges.no_backtrace"), tone: @error_log.backtrace_lines.any? ? :success : :neutral },
          { label: error_log_duration_label(@error_log), tone: :neutral }
        ]
      ) do %>
        <div class="min-w-0 space-y-4">
          <% if @error_log.backtrace_lines.any? %>
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-950"><%= t(".backtrace.available.title") %></p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".backtrace.available.description") %></p>
            </div>

            <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92">
              <summary class="cursor-pointer px-5 py-4">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p class="text-sm font-medium text-ink-950"><%= t(".backtrace.available.detail_title") %></p>
                    <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".backtrace.available.detail_description") %></p>
                  </div>

                  <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".backtrace.available.badge") %></span>
                </div>
              </summary>

              <div class="border-t border-canvas-200/80 px-5 py-5">
                <%= render Ui::CodeBlockComponent.new(
                  title: t(".backtrace.available.detail_title"),
                  description: t(".backtrace.available.detail_description"),
                  body: @error_log.backtrace_lines.join("\n"),
                  wrap: true,
                  tone: :default
                ) %>
              </div>
            </details>
          <% else %>
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-950"><%= t(".backtrace.empty.title") %></p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".backtrace.empty.description") %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
