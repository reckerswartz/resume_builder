<% backtrace_count = error_log_stats.fetch(:with_backtrace_count) %>
<% total_count = error_log_stats.fetch(:total) %>
<% source_scope_label = source_filter.present? ? source_filter.humanize : t("admin.error_logs.index.panels.source_scope_all") %>

<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
  <%= render Ui::MetricCardComponent.new(
    label: t("admin.error_logs.index.panels.metrics.errors_in_scope.label"),
    value: total_count,
    description: t("admin.error_logs.index.panels.metrics.errors_in_scope.description")
  ) %>

  <%= render Ui::MetricCardComponent.new(
    label: t("admin.error_logs.index.panels.metrics.request_issues.label"),
    value: error_log_stats.fetch(:request_count),
    description: t("admin.error_logs.index.panels.metrics.request_issues.description")
  ) %>

  <%= render Ui::MetricCardComponent.new(
    label: t("admin.error_logs.index.panels.metrics.job_issues.label"),
    value: error_log_stats.fetch(:job_count),
    description: t("admin.error_logs.index.panels.metrics.job_issues.description")
  ) %>

  <%= render Ui::MetricCardComponent.new(
    label: t("admin.error_logs.index.panels.metrics.backtrace_coverage.label"),
    value: "#{backtrace_count}/#{total_count}",
    description: total_count.positive? ? t("admin.error_logs.index.panels.metrics.backtrace_coverage.description") : t("admin.error_logs.index.panels.metrics.backtrace_coverage.empty")
  ) %>
</div>

<div class="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
  <%= render Ui::SurfaceCardComponent.new(padding: :md) do %>
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-ink-700/70"><%= t("admin.error_logs.index.panels.correlation.eyebrow") %></p>
        <h2 class="mt-2 text-xl font-semibold tracking-tight text-ink-950"><%= t("admin.error_logs.index.panels.correlation.title") %></h2>
        <p class="mt-2 text-sm text-ink-700/80"><%= t("admin.error_logs.index.panels.correlation.description") %></p>
      </div>
      <span class="<%= ui_badge_classes(:neutral) %>"><%= source_scope_label %></span>
    </div>

    <% if query.present? %>
      <div class="mt-4 <%= ui_inset_panel_classes(tone: :success) %>">
        <p class="text-sm font-medium text-ink-950"><%= t("admin.error_logs.index.panels.correlation.current_query_title") %></p>
        <p class="mt-1 break-all text-sm text-ink-700/80"><%= query %></p>
        <p class="mt-3 text-sm text-ink-700/80"><%= t("admin.error_logs.index.panels.correlation.current_query_description") %></p>
      </div>
    <% else %>
      <div class="mt-4">
        <%= render Ui::EmptyStateComponent.new(
          description: t("admin.error_logs.index.panels.correlation.empty_state"),
          padding: :sm,
          tone: :subtle,
          align: :left
        ) %>
      </div>
    <% end %>
  <% end %>

  <%= render Ui::SurfaceCardComponent.new(padding: :md) do %>
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-ink-700/70"><%= t("admin.error_logs.index.panels.source_mix.eyebrow") %></p>
        <h2 class="mt-2 text-xl font-semibold tracking-tight text-ink-950"><%= t("admin.error_logs.index.panels.source_mix.title") %></h2>
        <p class="mt-2 text-sm text-ink-700/80"><%= t("admin.error_logs.index.panels.source_mix.description") %></p>
      </div>
      <span class="<%= ui_badge_classes(:neutral) %>"><%= pluralize(total_count, "log") %></span>
    </div>

    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <%= render Ui::WidgetCardComponent.new(
        eyebrow: t("admin.error_logs.index.panels.source_mix.request_context.eyebrow"),
        title: error_log_stats.fetch(:request_count),
        description: t("admin.error_logs.index.panels.source_mix.request_context.description"),
        tone: error_log_stats.fetch(:request_count).positive? ? :subtle : :success,
        padding: :sm,
        title_size: :base
      ) %>

      <%= render Ui::WidgetCardComponent.new(
        eyebrow: t("admin.error_logs.index.panels.source_mix.job_context.eyebrow"),
        title: error_log_stats.fetch(:job_count),
        description: t("admin.error_logs.index.panels.source_mix.job_context.description"),
        tone: error_log_stats.fetch(:job_count).positive? ? :subtle : :success,
        padding: :sm,
        title_size: :base
      ) %>
    </div>
  <% end %>
</div>
