<% provider_sections = [
     { id: "provider-identity", label: "Provider identity", caption: "Name, slug, and adapter" },
     { id: "connection-credentials", label: "Connection & credentials", caption: "Endpoint, API key reference, and timeout" },
     { id: "activation", label: "Activation", caption: "Live request eligibility and sync behavior" }
   ] %>
<% sync_message = llm_provider.persisted? ? "Saving changes will attempt a fresh catalog sync so model availability stays aligned with the provider." : "Creating the provider will attempt the first catalog sync immediately after save." %>
<% credential_guidance = if llm_provider.nvidia_build?
     "Use an environment variable such as NVIDIA_API_KEY when possible so credentials stay out of the database and rotate cleanly."
   else
     "Ollama typically does not require an API key reference, but the endpoint and timeout still shape local request behavior."
   end %>

<%= form_with model: [:admin, llm_provider], class: "grid gap-6 xl:grid-cols-[16rem_minmax(0,1fr)]" do |form| %>
  <% if llm_provider.errors.any? %>
    <div class="xl:col-span-2 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
      <%= llm_provider.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
    <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
      <div class="space-y-4">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
            Provider setup
          </span>
          <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= llm_provider.persisted? ? "Update runtime details" : "Register a provider" %></h2>
          <p class="mt-2 text-sm leading-6 text-ink-700/80">Work through identity, endpoint, credentials, and activation before saving this provider.</p>
        </div>

        <div class="space-y-3">
          <% provider_sections.each do |section| %>
            <%= render Ui::SectionLinkCardComponent.new(
              label: section.fetch(:label),
              caption: section.fetch(:caption),
              path: "##{section.fetch(:id)}"
            ) %>
          <% end %>
        </div>

        <div class="<%= ui_inset_panel_classes(tone: llm_provider.nvidia_build? ? :default : :subtle) %>">
          <p class="text-sm font-medium text-ink-950">Credential guidance</p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= credential_guidance %></p>

          <% if llm_provider.api_key_reference_type == "direct_token" %>
            <p class="mt-3 text-sm text-ink-700/80">Stored token: <span class="font-medium text-ink-950"><%= llm_provider.masked_api_key_reference %></span></p>
          <% elsif llm_provider.nvidia_build? && llm_provider.api_key_reference.present? && llm_provider.api_key.blank? %>
            <p class="mt-3 text-sm text-amber-700">The current environment cannot resolve <%= llm_provider.api_key_reference %> yet.</p>
          <% end %>
        </div>

        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <p class="text-sm font-medium text-ink-950">Sync behavior</p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= sync_message %></p>
        </div>

        <div class="flex flex-wrap gap-2">
          <% if llm_provider.persisted? %>
            <%= link_to "View provider", admin_llm_provider_path(llm_provider), class: ui_button_classes(:secondary, size: :sm) %>
          <% else %>
            <%= link_to "Back to providers", admin_llm_providers_path, class: ui_button_classes(:secondary, size: :sm) %>
          <% end %>
        </div>
      </div>
    <% end %>
  </aside>

  <div class="space-y-6">
    <%= render Ui::SettingsSectionComponent.new(
      title: "Provider identity",
      anchor: "provider-identity",
      eyebrow: "Core details",
      description: "Register the provider name, slug, and adapter that determine how models are discovered and routed.",
      badges: [
        { label: llm_provider_adapter_label(llm_provider), tone: :neutral },
        { label: llm_provider.persisted? ? "Saved record" : "New record", tone: llm_provider.persisted? ? :success : :neutral }
      ]
    ) do %>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <%= form.label :name, class: ui_label_classes %>
          <%= form.text_field :name, class: ui_input_classes %>
        </div>

        <div>
          <%= form.label :slug, class: ui_label_classes %>
          <%= form.text_field :slug, class: ui_input_classes %>
        </div>

        <div>
          <%= form.label :adapter, class: ui_label_classes %>
          <%= form.select :adapter, options_for_select([["Ollama", "ollama"], ["NVIDIA Build", "nvidia_build"]], llm_provider.adapter), {}, class: ui_input_classes %>
        </div>
      </div>
    <% end %>

    <%= render Ui::SettingsSectionComponent.new(
      title: "Connection & credentials",
      anchor: "connection-credentials",
      eyebrow: "Runtime settings",
      description: "Configure the provider endpoint, credential reference, and timeout used for sync and live requests.",
      badges: [
        { label: llm_provider_credential_status_label(llm_provider), tone: llm_provider_credential_status_tone(llm_provider) }
      ]
    ) do %>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <%= form.label :base_url, class: ui_label_classes %>
          <%= form.url_field :base_url, class: ui_input_classes %>
        </div>

        <div>
          <%= label_tag "llm_provider_request_timeout_seconds", "Request timeout (seconds)", class: ui_label_classes %>
          <%= number_field_tag "llm_provider[request_timeout_seconds]", llm_provider.request_timeout_seconds, min: 5, step: 1, class: ui_input_classes %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :api_key_env_var, "API key reference", class: ui_label_classes %>
          <%= form.text_field :api_key_env_var, value: llm_provider.api_key_reference_field_value, placeholder: (llm_provider.nvidia_build? ? "NVIDIA_API_KEY" : nil), class: ui_input_classes %>
          <p class="mt-2 text-sm leading-6 text-ink-700/80">Use an environment variable name when possible. Saving the provider will try to sync its model catalog automatically.</p>

          <% if llm_provider.nvidia_build? %>
            <div class="mt-3 <%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-950">Preferred security posture</p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80">Reference an environment variable such as NVIDIA_API_KEY so request authentication stays outside the database.</p>
            </div>
          <% end %>

          <% if llm_provider.api_key_reference_type == "direct_token" %>
            <p class="mt-3 text-sm leading-6 text-ink-700/80">A direct token is already stored and masked below. Leave this field blank to keep it unchanged.</p>
            <p class="mt-1 text-xs font-medium uppercase tracking-[0.18em] text-ink-700/60"><%= llm_provider.masked_api_key_reference %></p>
          <% elsif llm_provider.nvidia_build? && llm_provider.api_key_reference.present? && llm_provider.api_key.blank? %>
            <p class="mt-3 text-sm text-amber-700">The current environment cannot resolve <%= llm_provider.api_key_reference %> yet, so sync and live requests will fail until it is available.</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= render Ui::SettingsSectionComponent.new(
      title: "Activation",
      anchor: "activation",
      eyebrow: "Request eligibility",
      description: "Control whether this provider is eligible for live model requests and automatic catalog sync.",
      badges: [
        { label: llm_provider.active? ? "Active" : "Inactive", tone: llm_provider.active? ? :success : :neutral },
        { label: llm_provider_request_badge_label(llm_provider), tone: llm_provider_request_status_tone(llm_provider) }
      ]
    ) do %>
      <div class="space-y-4">
        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <label class="flex items-start justify-between gap-4">
            <span>
              <span class="block text-sm font-medium text-ink-950">Active provider</span>
              <span class="mt-1 block text-sm leading-6 text-ink-700/80">Inactive providers stay registered but their models are not selected for live requests.</span>
            </span>
            <%= form.check_box :active, class: ui_checkbox_classes %>
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="<%= ui_inset_panel_classes(tone: llm_provider.configured_for_requests? ? :success : :default) %>">
            <p class="text-sm font-medium text-ink-700/80">Request readiness</p>
            <div class="mt-2 flex flex-wrap items-center gap-2">
              <span class="<%= ui_badge_classes(llm_provider_request_status_tone(llm_provider)) %>"><%= llm_provider_request_badge_label(llm_provider) %></span>
              <span class="text-sm text-ink-700/80"><%= llm_provider_request_status_label(llm_provider) %></span>
            </div>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/80">Catalog sync on save</p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= sync_message %></p>
          </div>
        </div>
      </div>
    <% end %>

    <%= render Ui::StickyActionBarComponent.new(
      title: llm_provider.persisted? ? "Save provider" : "Create provider",
      description: sync_message,
      density: :compact
    ) do %>
      <% if llm_provider.persisted? %>
        <%= link_to "View provider", admin_llm_provider_path(llm_provider), class: ui_button_classes(:secondary, size: :sm) %>
      <% else %>
        <%= link_to "Back to providers", admin_llm_providers_path, class: ui_button_classes(:secondary, size: :sm) %>
      <% end %>
      <%= form.submit(llm_provider.persisted? ? "Save provider" : "Create provider", class: ui_button_classes(:primary)) %>
    <% end %>
  </div>
<% end %>
