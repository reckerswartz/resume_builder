<% active_count = template_summary.fetch(:active_count) %>
<% family_count = template_summary.fetch(:family_count) %>
<% card_shell_count = template_summary.fetch(:card_shell_count) %>
<% sidebar_layout_count = template_summary.fetch(:sidebar_layout_count) %>
<% active_filter_count = [query.presence, status_filter.presence].compact.count %>
<% copy_scope = "admin.templates.index.summary" %>

<div class="mb-4 space-y-4">
  <%= render Ui::DashboardPanelComponent.new(
    eyebrow: t("#{copy_scope}.panel.eyebrow"),
    title: t("#{copy_scope}.panel.title"),
    description: active_filter_count.positive? ? t("#{copy_scope}.panel.description.filtered", count: total_count) : t("#{copy_scope}.panel.description.unfiltered"),
    action_label: active_filter_count.positive? ? t("#{copy_scope}.panel.actions.clear_filters") : t("#{copy_scope}.panel.actions.template_gallery"),
    action_path: active_filter_count.positive? ? admin_templates_path : templates_path,
    action_style: :secondary
  ) do %>
    <div class="space-y-3">
      <div class="flex flex-wrap gap-2">
        <% if query.present? %>
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("#{copy_scope}.panel.filter_badges.query", query:) %></span>
        <% end %>
        <% if status_filter.present? %>
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("#{copy_scope}.panel.filter_badges.status", status: status_filter.humanize) %></span>
        <% end %>
      </div>

      <% if active_filter_count.zero? %>
        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <div class="flex items-start gap-3">
            <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :soft) %>
            <div>
              <p class="text-sm font-semibold text-ink-950"><%= t("#{copy_scope}.panel.guidance.title") %></p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("#{copy_scope}.panel.guidance.description") %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("#{copy_scope}.cards.matches.eyebrow"),
      title: total_count.to_s,
      description: t("#{copy_scope}.cards.matches.description"),
      badge: t("#{copy_scope}.cards.matches.badge", count: templates.size),
      badge_classes: ui_badge_classes(:neutral),
      title_size: :base
    ) %>

    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("#{copy_scope}.cards.user_visible.eyebrow"),
      title: active_count.to_s,
      description: t("#{copy_scope}.cards.user_visible.description"),
      badge: active_count.positive? ? t("#{copy_scope}.cards.user_visible.badges.live") : t("#{copy_scope}.cards.user_visible.badges.hidden"),
      badge_classes: ui_badge_classes(active_count.positive? ? :success : :neutral),
      title_size: :base
    ) %>

    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("#{copy_scope}.cards.layout_families.eyebrow"),
      title: family_count.to_s,
      description: t("#{copy_scope}.cards.layout_families.description"),
      badge: card_shell_count.positive? ? t("#{copy_scope}.cards.layout_families.badge_card_shells", count: card_shell_count) : t("#{copy_scope}.cards.layout_families.badge_flat_only"),
      badge_classes: ui_badge_classes(:neutral),
      title_size: :base
    ) %>

    <%= render Ui::WidgetCardComponent.new(
      eyebrow: t("#{copy_scope}.cards.sidebar_layouts.eyebrow"),
      title: sidebar_layout_count.to_s,
      description: t("#{copy_scope}.cards.sidebar_layouts.description"),
      badge: sidebar_layout_count.positive? ? t("#{copy_scope}.cards.sidebar_layouts.badges.varied") : t("#{copy_scope}.cards.sidebar_layouts.badges.single_column"),
      badge_classes: ui_badge_classes(sidebar_layout_count.positive? ? :success : :neutral),
      title_size: :base
    ) %>
  </div>
</div>
