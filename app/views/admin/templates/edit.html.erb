<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: "Admin",
    title: "Edit template",
    description: "Adjust the shared template configuration used by preview and export rendering.",
    density: :compact,
    badges: [
      { label: "Shared renderer", tone: :neutral },
      { label: "Update flow", tone: :neutral }
    ],
    actions: [
      { label: "View template", path: admin_template_path(@template), style: :secondary }
    ]
  ) %>

  <%= render "form", template: @template %>
</section>
