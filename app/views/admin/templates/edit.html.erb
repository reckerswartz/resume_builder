<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: "Admin",
    title: "Edit template",
    description: "Update the layout defaults and gallery visibility for this template.",
    density: :compact,
    actions: [
      { label: "View template", path: admin_template_path(@template), style: :secondary }
    ]
  ) %>

  <%= render "form", template: @template %>
</section>
