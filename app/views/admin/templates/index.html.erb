<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: "Admin",
    title: "Templates",
    description: "Manage the layouts used by the shared preview and PDF export pipeline.",
    density: :compact,
    badges: [
      { label: "Shared renderer", tone: :neutral },
      { label: "Admin controls", tone: :neutral }
    ],
    actions: [
      { label: "Template gallery", path: templates_path, style: :secondary },
      { label: "New template", path: new_admin_template_path, style: :primary }
    ]
  ) %>

  <%= render partial: "shared/admin_async_table", locals: {
    frame_id: "admin_templates_table",
    filter_keys: %i[query status],
    filter_partial: "admin/templates/filters",
    filter_locals: {
      query: @query,
      status_filter: @status_filter,
      sort: @sort,
      direction: @direction,
      total_count: @total_count
    },
    before_table_partial: "admin/templates/summary",
    before_table_locals: {
      templates: @templates,
      total_count: @total_count,
      query: @query,
      status_filter: @status_filter
    },
    table_partial: "admin/templates/table",
    table_locals: {
      templates: @templates,
      sort: @sort,
      direction: @direction
    },
    current_page: @current_page,
    total_pages: @total_pages,
    pagination_base_path: admin_templates_path
  } %>
</section>
