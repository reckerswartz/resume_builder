<% layout_metadata = template_layout_metadata(template) %>
<% preview_resume = template_preview_resume(template) %>
<% template_card = layout_metadata.merge(template: template, preview_resume: preview_resume) %>
<% template_sections = [
     { id: "template-identity", label: "Template identity", caption: "Name, slug, and description" },
     { id: "layout-system", label: "Layout system", caption: "Family, typography, density, and accent" },
     { id: "availability-preview", label: "Availability & preview", caption: "Visibility, activation, and sample rendering" }
   ] %>
<% save_message = template.persisted? ? "Saving changes updates the shared preview and PDF export renderer for future resume sessions that use this template." : "Creating the template registers it for admin review and, if active, user selection in the template gallery." %>
<% preview_guidance = "Changes to family, font scale, density, columns, theme tone, and accent color update the shared preview after save." %>

<%= form_with model: [:admin, template], class: "grid gap-6 xl:grid-cols-[16rem_minmax(0,1fr)]" do |form| %>
  <% layout_config = template.normalized_layout_config %>
  <% if template.errors.any? %>
    <div class="xl:col-span-2 <%= ui_inset_panel_classes(tone: :danger) %>">
      <%= template.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
    <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
      <div class="space-y-4">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
            Template setup
          </span>
          <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= template.persisted? ? "Update template profile" : "Create a template" %></h2>
          <p class="mt-2 text-sm leading-6 text-ink-700/80">Work through identity, layout settings, and visibility before saving this template.</p>
        </div>

        <div class="space-y-3">
          <% template_sections.each do |section| %>
            <%= render Ui::SectionLinkCardComponent.new(
              label: section.fetch(:label),
              caption: section.fetch(:caption),
              path: "##{section.fetch(:id)}"
            ) %>
          <% end %>
        </div>

        <div class="<%= ui_inset_panel_classes(tone: template.active? ? :success : :subtle) %>">
          <p class="text-sm font-medium text-ink-950">Visibility</p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= template_visibility_description(template) %></p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="<%= ui_badge_classes(template_visibility_tone(template)) %>"><%= template_visibility_label(template) %></span>
            <span class="<%= ui_badge_classes(template_status_badge_tone(template)) %>"><%= template_status_label(template) %></span>
          </div>
        </div>

        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <p class="text-sm font-medium text-ink-950">Preview behavior</p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= preview_guidance %></p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="<%= ui_badge_classes(:neutral) %>"><%= layout_metadata.fetch(:family_label) %></span>
            <span class="<%= ui_badge_classes(:neutral) %>">Density: <%= layout_metadata.fetch(:density_label) %></span>
          </div>
        </div>

        <div class="flex flex-wrap gap-2">
          <% if template.persisted? %>
            <%= link_to "View template", admin_template_path(template), class: ui_button_classes(:secondary, size: :sm) %>
          <% else %>
            <%= link_to "Back to templates", admin_templates_path, class: ui_button_classes(:secondary, size: :sm) %>
          <% end %>
        </div>
      </div>
    <% end %>
  </aside>

  <div class="space-y-6">
    <%= render Ui::SettingsSectionComponent.new(
      title: "Template identity",
      anchor: "template-identity",
      eyebrow: "Core details",
      description: "Register the admin-facing name, slug, and description used to manage this template.",
      badges: [
        { label: template.persisted? ? "Saved record" : "New record", tone: template.persisted? ? :success : :neutral },
        { label: layout_metadata.fetch(:family_label), tone: :neutral }
      ]
    ) do %>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <%= form.label :name, class: ui_label_classes %>
          <%= form.text_field :name, class: ui_input_classes %>
        </div>

        <div>
          <%= form.label :slug, class: ui_label_classes %>
          <%= form.text_field :slug, class: ui_input_classes %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :description, class: ui_label_classes %>
          <%= form.text_area :description, rows: 4, class: ui_input_classes %>
          <p class="mt-2 text-sm text-ink-700/80">Descriptions help admin review and clarify when a template belongs in the gallery.</p>
        </div>
      </div>
    <% end %>

    <%= render Ui::SettingsSectionComponent.new(
      title: "Layout system",
      anchor: "layout-system",
      eyebrow: "Rendering configuration",
      description: "Adjust the family, typography, density, and accent settings that shape the shared preview and export output.",
      badges: [
        { label: layout_metadata.fetch(:shell_style_label), tone: :neutral },
        { label: layout_metadata.fetch(:entry_style_label), tone: :neutral }
      ]
    ) do %>
      <div class="space-y-4">
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <%= label_tag "template_layout_config_family", "Family", class: ui_label_classes %>
            <%= select_tag "template[layout_config][family]", options_for_select(ResumeTemplates::Catalog.family_options, template.layout_family), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_font_scale", "Font scale", class: ui_label_classes %>
            <%= select_tag "template[layout_config][font_scale]", options_for_select(ResumeTemplates::Catalog.font_scale_options, layout_config.fetch("font_scale")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_density", "Density", class: ui_label_classes %>
            <%= select_tag "template[layout_config][density]", options_for_select(ResumeTemplates::Catalog.density_options, layout_config.fetch("density")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_column_count", "Columns", class: ui_label_classes %>
            <%= select_tag "template[layout_config][column_count]", options_for_select(ResumeTemplates::Catalog.column_count_options, layout_config.fetch("column_count")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_theme_tone", "Theme tone", class: ui_label_classes %>
            <%= select_tag "template[layout_config][theme_tone]", options_for_select(ResumeTemplates::Catalog.theme_tone_options, layout_config.fetch("theme_tone")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_accent_color", "Accent color", class: ui_label_classes %>
            <%= color_field_tag "template[layout_config][accent_color]", layout_config.fetch("accent_color"), class: "mt-2 block h-12 w-full rounded-2xl border border-canvas-200/80 bg-canvas-50/92 px-2 py-2 shadow-sm focus:border-ink-700 focus:outline-none focus:ring-2 focus:ring-canvas-200" %>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70">Layout focus</p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= template_layout_focus_summary(template) %></p>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70">Current profile</p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:summary) %></p>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70">Columns</p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:column_count_label) %></p>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70">Theme tone</p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:theme_tone_label) %></p>
          </div>

          <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92 sm:col-span-2">
            <summary class="cursor-pointer px-5 py-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-950">Advanced layout metadata</p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80">Lower-priority planning flags that do not need to stay open during normal template editing.</p>
                </div>

                <span class="<%= ui_badge_classes(:neutral) %>">Optional</span>
              </div>
            </summary>

            <div class="border-t border-canvas-200/80 px-5 py-5">
              <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                <%= hidden_field_tag "template[layout_config][supports_headshot]", false %>
                <label class="flex items-start justify-between gap-4">
                  <span>
                    <span class="block text-sm font-medium text-ink-950">Headshot metadata</span>
                    <span class="mt-1 block text-sm leading-6 text-ink-700/80">Enable this only when the template renderer honestly supports an uploaded resume headshot. Disabled templates keep their non-photo identity treatment.</span>
                  </span>

                  <span class="flex items-center gap-3">
                    <span class="<%= ui_badge_classes(template_headshot_metadata_tone(template)) %>"><%= template_headshot_metadata_label(template) %></span>
                    <%= check_box_tag "template[layout_config][supports_headshot]", true, layout_config.fetch("supports_headshot"), class: "mt-1 #{ui_checkbox_classes}" %>
                  </span>
                </label>
              </div>
            </div>
          </details>
        </div>
      </div>
    <% end %>

    <%= render Ui::SettingsSectionComponent.new(
      title: "Availability & preview",
      anchor: "availability-preview",
      eyebrow: "User exposure",
      description: "Control gallery visibility and review the current shared preview before saving.",
      badges: [
        { label: template_visibility_label(template), tone: template_visibility_tone(template) },
        { label: template_status_label(template), tone: template_status_badge_tone(template) }
      ]
    ) do %>
      <div class="space-y-4">
        <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'sm:col-span-2'].join(' ') %>">
          <label class="flex items-start justify-between gap-4">
            <span>
              <span class="block text-sm font-medium text-ink-950">Active template</span>
              <span class="mt-1 block text-sm leading-6 text-ink-700/80">Inactive templates remain stored for admin review and existing resumes, but non-admin users will not see them in the gallery.</span>
            </span>
            <%= form.check_box :active, class: ui_checkbox_classes %>
          </label>
        </div>

        <div class="grid gap-4 xl:grid-cols-[0.9fr_1.1fr]">
          <div class="space-y-4">
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/70">Visibility summary</p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(template_visibility_tone(template)) %>"><%= template_visibility_label(template) %></span>
                <span class="text-sm leading-6 text-ink-700/80"><%= template_visibility_description(template) %></span>
              </div>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <div class="flex items-start gap-3">
                <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :soft) %>
                <div>
                  <p class="text-sm font-medium text-ink-950">Save behavior</p>
                  <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= save_message %></p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <%= render Ui::DashboardPanelComponent.new(
              eyebrow: "Shared preview",
              title: "Current renderer sample",
              description: "This miniature preview reflects the current normalized layout config for the template record.",
              padding: :sm
            ) do %>
              <div class="relative overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92 p-3 shadow-[0_14px_32px_rgba(15,23,42,0.06)]">
                <div class="absolute -right-10 top-4 h-20 w-20 rounded-full atelier-glow opacity-30"></div>
                <div class="relative">
                  <%= render "resumes/template_picker_preview", template_card: template_card %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%= render Ui::StickyActionBarComponent.new(
      title: template.persisted? ? "Save template" : "Create template",
      description: save_message,
      density: :compact
    ) do %>
      <% if template.persisted? %>
        <%= link_to "View template", admin_template_path(template), class: ui_button_classes(:secondary, size: :sm) %>
      <% else %>
        <%= link_to "Back to templates", admin_templates_path, class: ui_button_classes(:secondary, size: :sm) %>
      <% end %>
      <%= form.submit(template.persisted? ? "Save template" : "Create template", class: ui_button_classes(:primary)) %>
    <% end %>
  </div>
<% end %>
