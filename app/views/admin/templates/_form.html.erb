<div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
  <%= form_with model: [:admin, template], class: "space-y-6" do |form| %>
    <% if template.errors.any? %>
      <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
        <%= template.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :name, class: "text-sm font-medium text-slate-700" %>
        <%= form.text_field :name, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div>
        <%= form.label :slug, class: "text-sm font-medium text-slate-700" %>
        <%= form.text_field :slug, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :description, class: "text-sm font-medium text-slate-700" %>
        <%= form.text_area :description, rows: 4, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div>
        <%= label_tag "template_layout_config_variant", "Variant", class: "text-sm font-medium text-slate-700" %>
        <%= select_tag "template[layout_config][variant]", options_for_select([["Modern", "modern"], ["Classic", "classic"]], template.layout_config.fetch("variant", "modern")), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div>
        <%= label_tag "template_layout_config_font_scale", "Font scale", class: "text-sm font-medium text-slate-700" %>
        <%= select_tag "template[layout_config][font_scale]", options_for_select([["Small", "sm"], ["Base", "base"], ["Large", "lg"]], template.layout_config.fetch("font_scale", "base")), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div>
        <%= label_tag "template_layout_config_accent_color", "Accent color", class: "text-sm font-medium text-slate-700" %>
        <%= color_field_tag "template[layout_config][accent_color]", template.layout_config.fetch("accent_color", "#0F172A"), class: "mt-2 block h-12 w-full rounded-2xl border border-slate-300 bg-white px-2 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 sm:col-span-2">
        <label class="flex items-center justify-between gap-4">
          <span>
            <span class="block text-sm font-medium text-slate-700">Active template</span>
            <span class="mt-1 block text-sm text-slate-500">Inactive templates remain stored but will not be the default choice for non-admin users.</span>
          </span>
          <%= form.check_box :active, class: "h-5 w-5 rounded border-slate-300 text-slate-900 focus:ring-slate-400" %>
        </label>
      </div>
    </div>

    <div class="flex justify-end">
      <%= form.submit(template.persisted? ? "Save template" : "Create template", class: "inline-flex justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-700") %>
    </div>
  <% end %>
</div>
