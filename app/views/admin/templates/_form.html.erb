<% profile_state = template_profile_state(template) %>
<% layout_metadata = template_layout_metadata(template) %>
<% template_card = template_cards_for_builder(selected_template: template, templates: [template]).first %>
<% copy_scope = "admin.templates.form" %>
<% template_sections = [
     { id: "template-identity", label: t("#{copy_scope}.navigation.sections.template_identity.label"), caption: t("#{copy_scope}.navigation.sections.template_identity.caption") },
     { id: "layout-system", label: t("#{copy_scope}.navigation.sections.layout_system.label"), caption: t("#{copy_scope}.navigation.sections.layout_system.caption") },
     { id: "availability-preview", label: t("#{copy_scope}.navigation.sections.availability_preview.label"), caption: t("#{copy_scope}.navigation.sections.availability_preview.caption") }
   ] %>
<% save_message = template.persisted? ? t("#{copy_scope}.save_messages.update") : t("#{copy_scope}.save_messages.create") %>
<% preview_guidance = t("#{copy_scope}.side_panels.preview_description") %>

<%= form_with model: [:admin, template], class: "grid gap-6 xl:grid-cols-[16rem_minmax(0,1fr)] min-w-0 w-full max-w-full overflow-hidden" do |form| %>
  <% layout_config = template.normalized_layout_config %>
  <% if template.errors.any? %>
    <div class="xl:col-span-2 <%= ui_inset_panel_classes(tone: :danger) %>">
      <%= template.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
    <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
      <div class="space-y-4">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
            <%= t("#{copy_scope}.navigation.pill") %>
          </span>
          <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= template.persisted? ? t("#{copy_scope}.navigation.title.edit") : t("#{copy_scope}.navigation.title.new") %></h2>
          <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("#{copy_scope}.navigation.description") %></p>
        </div>

        <div class="space-y-3">
          <% template_sections.each do |section| %>
            <%= render Ui::SectionLinkCardComponent.new(
              label: section.fetch(:label),
              caption: section.fetch(:caption),
              path: "##{section.fetch(:id)}"
            ) %>
          <% end %>
        </div>

        <div class="<%= ui_inset_panel_classes(tone: template.active? ? :success : :subtle) %>">
          <p class="text-sm font-medium text-ink-950"><%= t("#{copy_scope}.side_panels.visibility_title") %></p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= template_visibility_description(template) %></p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="<%= ui_badge_classes(template_visibility_tone(template)) %>"><%= template_visibility_label(template) %></span>
            <span class="<%= ui_badge_classes(template_status_badge_tone(template)) %>"><%= template_status_label(template) %></span>
          </div>
        </div>

        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <p class="text-sm font-medium text-ink-950"><%= t("#{copy_scope}.side_panels.preview_title") %></p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= preview_guidance %></p>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="<%= ui_badge_classes(:neutral) %>"><%= layout_metadata.fetch(:family_label) %></span>
            <span class="<%= ui_badge_classes(:neutral) %>">Density: <%= layout_metadata.fetch(:density_label) %></span>
          </div>
        </div>

        <div class="flex flex-wrap gap-2">
          <% if template.persisted? %>
            <%= link_to t("#{copy_scope}.actions.view_template"), admin_template_path(template), class: ui_button_classes(:secondary, size: :sm) %>
          <% else %>
            <%= link_to t("#{copy_scope}.actions.back_to_templates"), admin_templates_path, class: ui_button_classes(:secondary, size: :sm) %>
          <% end %>
        </div>
      </div>
    <% end %>
  </aside>

  <div class="space-y-6">
    <%= render Ui::SettingsSectionComponent.new(
      title: t("#{copy_scope}.sections.template_identity.title"),
      anchor: "template-identity",
      eyebrow: t("#{copy_scope}.sections.template_identity.eyebrow"),
      description: t("#{copy_scope}.sections.template_identity.description"),
      badges: [
        { label: template.persisted? ? t("#{copy_scope}.sections.template_identity.badges.saved_record") : t("#{copy_scope}.sections.template_identity.badges.new_record"), tone: template.persisted? ? :success : :neutral },
        { label: layout_metadata.fetch(:family_label), tone: :neutral }
      ]
    ) do %>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <%= form.label :name, class: ui_label_classes %>
          <%= form.text_field :name, class: ui_input_classes %>
        </div>

        <div>
          <%= form.label :slug, class: ui_label_classes %>
          <%= form.text_field :slug, class: ui_input_classes %>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :description, class: ui_label_classes %>
          <%= form.text_area :description, rows: 4, class: ui_input_classes %>
          <p class="mt-2 text-sm text-ink-700/80"><%= t("#{copy_scope}.sections.template_identity.description_help") %></p>
        </div>
      </div>
    <% end %>

    <%= render Ui::SettingsSectionComponent.new(
      title: t("#{copy_scope}.sections.layout_system.title"),
      anchor: "layout-system",
      eyebrow: t("#{copy_scope}.sections.layout_system.eyebrow"),
      description: t("#{copy_scope}.sections.layout_system.description"),
      badges: [
        { label: layout_metadata.fetch(:shell_style_label), tone: :neutral },
        { label: layout_metadata.fetch(:entry_style_label), tone: :neutral }
      ]
    ) do %>
      <div class="space-y-4">
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <%= label_tag "template_layout_config_family", t("#{copy_scope}.sections.layout_system.labels.family"), class: ui_label_classes %>
            <%= select_tag "template[layout_config][family]", options_for_select(ResumeTemplates::Catalog.family_options, template.layout_family), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_font_scale", t("#{copy_scope}.sections.layout_system.labels.font_scale"), class: ui_label_classes %>
            <%= select_tag "template[layout_config][font_scale]", options_for_select(ResumeTemplates::Catalog.font_scale_options, layout_config.fetch("font_scale")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_density", t("#{copy_scope}.sections.layout_system.labels.density"), class: ui_label_classes %>
            <%= select_tag "template[layout_config][density]", options_for_select(ResumeTemplates::Catalog.density_options, layout_config.fetch("density")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_column_count", t("#{copy_scope}.sections.layout_system.labels.columns"), class: ui_label_classes %>
            <%= select_tag "template[layout_config][column_count]", options_for_select(ResumeTemplates::Catalog.column_count_options, layout_config.fetch("column_count")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_theme_tone", t("#{copy_scope}.sections.layout_system.labels.theme_tone"), class: ui_label_classes %>
            <%= select_tag "template[layout_config][theme_tone]", options_for_select(ResumeTemplates::Catalog.theme_tone_options, layout_config.fetch("theme_tone")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "template_layout_config_accent_color", t("#{copy_scope}.sections.layout_system.labels.accent_color"), class: ui_label_classes %>
            <%= color_field_tag "template[layout_config][accent_color]", layout_config.fetch("accent_color"), class: "mt-2 block h-12 w-full rounded-2xl border border-canvas-200/80 bg-canvas-50/92 px-2 py-2 shadow-sm focus:border-ink-700 focus:outline-none focus:ring-2 focus:ring-canvas-200" %>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70"><%= t("#{copy_scope}.sections.layout_system.cards.layout_focus") %></p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= template_layout_focus_summary(template) %></p>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70"><%= t("#{copy_scope}.sections.layout_system.cards.current_profile") %></p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:summary) %></p>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70"><%= t("#{copy_scope}.sections.layout_system.cards.columns") %></p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:column_count_label) %></p>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/70"><%= t("#{copy_scope}.sections.layout_system.cards.theme_tone") %></p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:theme_tone_label) %></p>
          </div>

          <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92 sm:col-span-2">
            <summary class="cursor-pointer px-5 py-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-950"><%= t("#{copy_scope}.sections.layout_system.advanced_details.title") %></p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("#{copy_scope}.sections.layout_system.advanced_details.description") %></p>
                </div>

                <span class="<%= ui_badge_classes(:neutral) %>"><%= t("#{copy_scope}.sections.layout_system.advanced_details.badge") %></span>
              </div>
            </summary>

            <div class="border-t border-canvas-200/80 px-5 py-5">
              <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                <%= hidden_field_tag "template[layout_config][supports_headshot]", false %>
                <label class="flex items-start justify-between gap-4">
                  <span>
                    <span class="block text-sm font-medium text-ink-950"><%= t("#{copy_scope}.sections.layout_system.advanced_details.photo_support.title") %></span>
                    <span class="mt-1 block text-sm leading-6 text-ink-700/80"><%= t("#{copy_scope}.sections.layout_system.advanced_details.photo_support.description") %></span>
                  </span>

                  <span class="flex items-center gap-3">
                    <span class="<%= ui_badge_classes(template_headshot_metadata_tone(template)) %>"><%= template_headshot_metadata_label(template) %></span>
                    <%= check_box_tag "template[layout_config][supports_headshot]", true, layout_config.fetch("supports_headshot"), class: "mt-1 #{ui_checkbox_classes}" %>
                  </span>
                </label>
              </div>
            </div>
          </details>
        </div>
      </div>
    <% end %>

    <%= render Ui::SettingsSectionComponent.new(
      title: t("#{copy_scope}.sections.availability_preview.title"),
      anchor: "availability-preview",
      eyebrow: t("#{copy_scope}.sections.availability_preview.eyebrow"),
      description: t("#{copy_scope}.sections.availability_preview.description"),
      badges: [
        { label: template_visibility_label(template), tone: template_visibility_tone(template) },
        { label: template_status_label(template), tone: template_status_badge_tone(template) }
      ]
    ) do %>
      <div class="space-y-4">
        <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'sm:col-span-2'].join(' ') %>">
          <label class="flex items-start justify-between gap-4">
            <span>
              <span class="block text-sm font-medium text-ink-950"><%= t("#{copy_scope}.sections.availability_preview.active_template.title") %></span>
              <span class="mt-1 block text-sm leading-6 text-ink-700/80"><%= t("#{copy_scope}.sections.availability_preview.active_template.description") %></span>
            </span>
            <%= form.check_box :active, class: ui_checkbox_classes %>
          </label>
        </div>

        <div class="grid gap-4 xl:grid-cols-[0.9fr_1.1fr]">
          <div class="space-y-4">
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/70"><%= t("#{copy_scope}.sections.availability_preview.visibility_summary") %></p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(template_visibility_tone(template)) %>"><%= template_visibility_label(template) %></span>
                <span class="text-sm leading-6 text-ink-700/80"><%= template_visibility_description(template) %></span>
              </div>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <div class="flex items-start gap-3">
                <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :soft) %>
                <div>
                  <p class="text-sm font-medium text-ink-950"><%= t("#{copy_scope}.sections.availability_preview.save_behavior_title") %></p>
                  <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= save_message %></p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <%= render Ui::DashboardPanelComponent.new(
              eyebrow: t("#{copy_scope}.sections.availability_preview.preview_panel.eyebrow"),
              title: t("#{copy_scope}.sections.availability_preview.preview_panel.title"),
              description: t("#{copy_scope}.sections.availability_preview.preview_panel.description"),
              padding: :sm
            ) do %>
              <div class="relative overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92 p-3 shadow-[0_14px_32px_rgba(15,23,42,0.06)]">
                <div class="absolute -right-10 top-4 h-20 w-20 rounded-full atelier-glow opacity-30"></div>
                <div class="relative">
                  <%= render "resumes/template_picker_preview", template_card: template_card %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%= render Ui::StickyActionBarComponent.new(
      title: template.persisted? ? t("#{copy_scope}.actions.save_template") : t("#{copy_scope}.actions.create_template"),
      description: save_message,
      density: :compact
    ) do %>
      <% if template.persisted? %>
        <%= link_to t("#{copy_scope}.actions.view_template"), admin_template_path(template), class: ui_button_classes(:secondary, size: :sm) %>
      <% else %>
        <%= link_to t("#{copy_scope}.actions.back_to_templates"), admin_templates_path, class: ui_button_classes(:secondary, size: :sm) %>
      <% end %>
      <%= form.submit(template.persisted? ? t("#{copy_scope}.actions.save_template") : t("#{copy_scope}.actions.create_template"), class: ui_button_classes(:primary)) %>
    <% end %>
  </div>
<% end %>
