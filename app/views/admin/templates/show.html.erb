<% layout_metadata = template_layout_metadata(@template) %>
<% preview_resume = template_preview_resume(@template) %>
<% artifact_review_counts = template_artifact_review_counts(@template) %>
<% artifact_review_groups = template_artifact_review_groups(@template) %>
<% artifact_review_tone = template_artifact_review_tone(@template) %>
<% current_implementation = template_current_implementation(@template) %>
<% draft_candidates = template_candidate_implementations(@template) %>
<% validation_runs = template_recent_validation_runs(@template) %>
<% section_links = [
     { id: "shared-preview", label: t("admin.templates.show.navigation.sections.shared_preview.label"), caption: t("admin.templates.show.navigation.sections.shared_preview.caption") },
     { id: "layout-profile", label: t("admin.templates.show.navigation.sections.layout_profile.label"), caption: t("admin.templates.show.navigation.sections.layout_profile.caption") },
     { id: "artifact-review", label: t("admin.templates.show.navigation.sections.artifact_review.label"), caption: t("admin.templates.show.navigation.sections.artifact_review.caption") },
     { id: "implementation-validation", label: t("admin.templates.show.navigation.sections.implementation_validation.label"), caption: t("admin.templates.show.navigation.sections.implementation_validation.caption") },
     { id: "configuration", label: t("admin.templates.show.navigation.sections.configuration.label"), caption: t("admin.templates.show.navigation.sections.configuration.caption") }
   ] %>
<% review_items = [
     {
       label: "Gallery visibility",
       detail: template_visibility_description(@template),
       tone: @template.active? ? :success : :neutral
     },
     {
       label: "Template description",
       detail: @template.description.present? ? "Description is available for admin review and gallery guidance." : "Add a short description so admin review and gallery decisions stay easy to scan.",
       tone: @template.description.present? ? :success : :neutral
     },
     {
       label: "Shared preview",
       detail: "The live sample below uses the same renderer path as the builder preview and PDF export pipeline.",
       tone: :success
     },
     {
       label: t("admin.templates.show.summary.review_items.artifact_coverage.label"),
       detail: template_artifact_review_detail(@template),
       tone: artifact_review_tone == :success ? :success : :neutral
     }
   ] %>
<% review_tone = if !@template.active?
     :neutral
   elsif @template.description.present?
     :success
   else
     :neutral
   end %>
<% review_title = if !@template.active?
     "Hidden from the gallery"
   elsif @template.description.present?
     "Ready for gallery review"
   else
     "Ready, with small follow-up"
   end %>

<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(
    eyebrow: "Template",
    title: @template.name,
    description: @template.description.presence || layout_metadata.fetch(:summary),
    badges: [
      { label: layout_metadata.fetch(:family_label), tone: :neutral },
      { label: template_status_label(@template), tone: template_status_badge_tone(@template) },
      { label: template_visibility_label(@template), tone: template_visibility_tone(@template) },
      { label: "Density: #{layout_metadata.fetch(:density_label)}", tone: :neutral }
    ],
    actions: [
      { label: "Back to templates", path: admin_templates_path, style: :secondary },
      { label: "Template gallery", path: templates_path, style: :secondary },
      (@template.active? ? { label: "Use in new resume", path: new_resume_path(template_id: @template.id), style: :secondary } : nil),
      { label: "Edit template", path: edit_admin_template_path(@template), style: :primary }
    ].compact,
    density: :compact
  ) %>

  <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
    <div class="space-y-4">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :shield, size: :xs, tone: :minimal) %>
            Review summary
          </span>
          <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950">Review this template</h2>
          <p class="mt-2 text-sm leading-6 text-ink-700/80">Check gallery visibility and the shared preview first, then open layout detail or raw config only when you need deeper reference.</p>
        </div>

        <span class="<%= ui_badge_classes(review_tone) %>"><%= review_title %></span>
      </div>

      <div class="flex flex-wrap gap-2">
        <span class="<%= ui_badge_classes(template_visibility_tone(@template)) %>"><%= template_visibility_label(@template) %></span>
        <span class="<%= ui_badge_classes(template_status_badge_tone(@template)) %>"><%= template_status_label(@template) %></span>
        <span class="<%= ui_badge_classes(:neutral) %>">Columns: <%= layout_metadata.fetch(:column_count_label) %></span>
        <span class="<%= ui_badge_classes(:neutral) %>">Theme tone: <%= layout_metadata.fetch(:theme_tone_label) %></span>
        <span class="<%= ui_badge_classes(artifact_review_counts.fetch(:source_artifacts).positive? ? :success : :warning) %>"><%= t("admin.templates.show.artifact_review.badges.sources", count: artifact_review_counts.fetch(:source_artifacts)) %></span>
        <span class="<%= ui_badge_classes(template_artifact_review_implementation_badge_tone(@template)) %>"><%= template_artifact_review_implementation_badge_label(@template) %></span>
        <% if draft_candidates.any? %>
          <span class="<%= ui_badge_classes(:info) %>"><%= t("admin.templates.show.implementation_validation.badges.draft_candidates", count: draft_candidates.size) %></span>
        <% end %>
      </div>

      <div class="space-y-3">
        <% review_items.each do |item| %>
          <div class="<%= ui_inset_panel_classes(tone: item.fetch(:tone, :neutral) == :success ? :success : :default) %>">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-sm font-medium text-ink-950"><%= item.fetch(:label) %></p>
                <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= item.fetch(:detail) %></p>
              </div>

              <span class="<%= ui_badge_classes(item.fetch(:tone, :neutral)) %>"><%= item.fetch(:tone) == :success ? "Ready" : "Follow-up" %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid gap-6 xl:grid-cols-[16rem_minmax(0,1fr)]">
    <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
      <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :lg) do %>
        <div class="space-y-4">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
              Template sections
            </span>
            <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950">Jump to details</h2>
            <p class="mt-2 text-sm leading-6 text-ink-700/80">Move between the live preview, lifecycle review, and stored config without re-scanning the whole page.</p>
          </div>

          <div class="space-y-3">
            <% section_links.each do |section| %>
              <%= render Ui::SectionLinkCardComponent.new(
                label: section.fetch(:label),
                caption: section.fetch(:caption),
                path: "##{section.fetch(:id)}"
              ) %>
            <% end %>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: @template.active? ? :success : :subtle) %>">
            <p class="text-sm font-medium text-ink-950">Visibility</p>
            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= template_visibility_description(@template) %></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(template_visibility_tone(@template)) %>"><%= template_visibility_label(@template) %></span>
              <span class="<%= ui_badge_classes(template_status_badge_tone(@template)) %>"><%= template_status_label(@template) %></span>
            </div>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: artifact_review_tone == :success ? :success : :subtle) %>">
            <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.artifact_review.title") %></p>
            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= template_artifact_review_detail(@template) %></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(artifact_review_counts.fetch(:source_artifacts).positive? ? :success : :warning) %>"><%= t("admin.templates.show.artifact_review.badges.sources", count: artifact_review_counts.fetch(:source_artifacts)) %></span>
              <span class="<%= ui_badge_classes(template_artifact_review_implementation_badge_tone(@template)) %>"><%= template_artifact_review_implementation_badge_label(@template) %></span>
              <span class="<%= ui_badge_classes(validation_runs.any? ? :info : :neutral) %>"><%= t("admin.templates.show.artifact_review.badges.validation_runs", count: artifact_review_counts.fetch(:validation_runs)) %></span>
            </div>
            <% if artifact_review_counts.fetch(:source_artifacts).positive? %>
              <div class="mt-3">
                <%= button_to t("admin.templates.show.implementation_validation.implementation_card.actions.create_candidate"), admin_template_implementation_candidates_path(@template), form_class: "inline-flex", class: ui_button_classes(:secondary, size: :sm) %>
              </div>
            <% end %>
          </div>

          <div class="flex flex-wrap gap-2">
            <%= link_to "Template gallery", templates_path, class: ui_button_classes(:secondary, size: :sm) %>
            <% if @template.active? %>
              <%= link_to "Use in new resume", new_resume_path(template_id: @template.id), class: ui_button_classes(:secondary, size: :sm) %>
            <% end %>
          </div>
        </div>
      <% end %>
    </aside>

    <div class="space-y-6">
      <%= render Ui::SettingsSectionComponent.new(
        title: "Shared preview",
        anchor: "shared-preview",
        eyebrow: "Live sample",
        description: "This sample uses the same server-rendered template component path as the editor preview and PDF export pipeline.",
        badges: [
          { label: layout_metadata.fetch(:family_label), tone: :neutral },
          { label: template_visibility_label(@template), tone: template_visibility_tone(@template) }
        ]
      ) do %>
        <div class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="<%= ui_inset_panel_classes(tone: @template.active? ? :success : :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80">Gallery visibility</p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(template_visibility_tone(@template)) %>"><%= template_visibility_label(@template) %></span>
                <span class="text-sm leading-6 text-ink-700/80"><%= template_visibility_description(@template) %></span>
              </div>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/80">Layout focus</p>
              <p class="mt-2 text-base font-medium text-ink-950"><%= template_layout_focus_summary(@template) %></p>
              <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:summary) %></p>
            </div>
          </div>

          <div class="flex items-center justify-between gap-3 border-b border-canvas-200/80 pb-4">
            <div>
              <span class="atelier-pill">
                <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
                Live sample
              </span>
              <p class="mt-3 text-sm leading-6 text-ink-700/80">Preview the actual renderer output before making configuration changes.</p>
            </div>

            <div class="flex flex-wrap gap-2">
              <% if @template.active? %>
                <%= link_to "Use in new resume", new_resume_path(template_id: @template.id), class: ui_button_classes(:primary, size: :sm) %>
              <% end %>
              <%= link_to "Template gallery", templates_path, class: ui_button_classes(:secondary, size: :sm) %>
            </div>
          </div>

          <div class="relative overflow-hidden rounded-[1.75rem] border border-canvas-200/80 bg-canvas-50/92 p-4 shadow-[0_16px_36px_rgba(15,23,42,0.06)] sm:p-6">
            <div class="absolute -right-12 top-6 h-24 w-24 rounded-full atelier-glow opacity-35"></div>
            <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

            <div class="relative">
              <%= render ResumeTemplates::ComponentResolver.component_for(preview_resume) %>
            </div>
          </div>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: "Layout profile",
        anchor: "layout-profile",
        eyebrow: "Template metadata",
        description: "Inspect the normalized layout values that shape the shared preview and export presentation for this template.",
        badges: [
          { label: layout_metadata.fetch(:family_label), tone: :neutral },
          { label: layout_metadata.fetch(:shell_style_label), tone: :neutral }
        ]
      ) do %>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'sm:col-span-2'].join(' ') %>">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <p class="text-sm font-medium text-ink-700/80">Layout summary</p>
                <p class="mt-2 text-base font-medium text-ink-950"><%= template_layout_focus_summary(@template) %></p>
                <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= layout_metadata.fetch(:summary) %></p>
              </div>

              <div class="flex flex-wrap gap-2">
                <span class="<%= ui_badge_classes(:neutral) %>">Slug: <%= @template.slug %></span>
                <span class="<%= ui_badge_classes(:neutral) %>">Density: <%= layout_metadata.fetch(:density_label) %></span>
                <span class="<%= ui_badge_classes(:neutral) %>">Columns: <%= layout_metadata.fetch(:column_count_label) %></span>
                <span class="<%= ui_badge_classes(:neutral) %>">Font scale: <%= layout_metadata.fetch(:font_scale_label) %></span>
                <span class="<%= ui_badge_classes(:neutral) %>">Theme tone: <%= layout_metadata.fetch(:theme_tone_label) %></span>
              </div>
            </div>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/80">Shell profile</p>
            <p class="mt-2 text-base font-medium text-ink-950"><%= layout_metadata.fetch(:shell_style_label) %></p>
            <p class="mt-2 text-sm leading-6 text-ink-700/80">Header <%= layout_metadata.fetch(:header_style_label) %> · Entries <%= layout_metadata.fetch(:entry_style_label) %></p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(:neutral) %>">Section headings: <%= layout_metadata.fetch(:section_heading_style_label) %></span>
              <span class="<%= ui_badge_classes(:neutral) %>">Skills: <%= layout_metadata.fetch(:skill_style_label) %></span>
            </div>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <p class="text-sm font-medium text-ink-700/80">Accent system</p>
            <div class="mt-2 flex items-center gap-3">
              <span class="h-8 w-8 rounded-full border border-canvas-200/80" style="background-color: <%= layout_metadata.fetch(:accent_color) %>;"></span>
              <span class="text-base font-medium text-ink-950"><%= layout_metadata.fetch(:accent_color) %></span>
            </div>
            <p class="mt-2 text-sm leading-6 text-ink-700/80">Preview accent</p>
          </div>

          <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'sm:col-span-2'].join(' ') %>">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-sm font-medium text-ink-700/80">Headshot metadata</p>
                <p class="mt-2 text-base font-medium text-ink-950"><%= template_headshot_metadata_label(@template) %></p>
                <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= template_headshot_metadata_description(@template) %></p>
              </div>

              <span class="<%= ui_badge_classes(template_headshot_metadata_tone(@template)) %>"><%= template_headshot_metadata_label(@template) %></span>
            </div>
          </div>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t("admin.templates.show.artifact_review.title"),
        anchor: "artifact-review",
        eyebrow: t("admin.templates.show.artifact_review.eyebrow"),
        description: t("admin.templates.show.artifact_review.description"),
        badges: [
          { label: t("admin.templates.show.artifact_review.badges.sources", count: artifact_review_counts.fetch(:source_artifacts)), tone: artifact_review_counts.fetch(:source_artifacts).positive? ? :success : :warning },
          { label: template_artifact_review_implementation_badge_label(@template), tone: template_artifact_review_implementation_badge_tone(@template) },
          { label: t("admin.templates.show.artifact_review.badges.validation_runs", count: artifact_review_counts.fetch(:validation_runs)), tone: validation_runs.any? ? :info : :neutral }
        ]
      ) do %>
        <div class="space-y-4">
          <div class="<%= ui_inset_panel_classes(tone: artifact_review_tone == :success ? :success : :subtle) %>">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <p class="text-sm font-medium text-ink-950"><%= template_artifact_review_title(@template) %></p>
                <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= template_artifact_review_detail(@template) %></p>
              </div>

              <div class="flex flex-wrap gap-2">
                <span class="<%= ui_badge_classes(artifact_review_counts.fetch(:source_artifacts).positive? ? :success : :warning) %>"><%= t("admin.templates.show.artifact_review.badges.sources", count: artifact_review_counts.fetch(:source_artifacts)) %></span>
                <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.templates.show.artifact_review.badges.documentation_notes", count: artifact_review_counts.fetch(:documentation_artifacts)) %></span>
                <span class="<%= ui_badge_classes(validation_runs.any? ? :info : :neutral) %>"><%= t("admin.templates.show.artifact_review.badges.validation_artifacts", count: artifact_review_counts.fetch(:validation_artifacts)) %></span>
              </div>
            </div>
          </div>

          <div class="grid gap-4 xl:grid-cols-2">
            <% artifact_review_groups.each do |group| %>
              <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :md) do %>
                <div class="space-y-4">
                  <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                    <div>
                      <p class="text-sm font-medium text-ink-950"><%= group.fetch(:title) %></p>
                      <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= group.fetch(:description) %></p>
                    </div>

                    <span class="<%= ui_badge_classes(group.fetch(:tone, :neutral)) %>"><%= group.fetch(:count_label) %></span>
                  </div>

                  <% if group.fetch(:artifacts).any? %>
                    <div class="space-y-3">
                      <% group.fetch(:artifacts).each do |artifact| %>
                        <% attachment_summary = template_artifact_attachment_summary(artifact) %>
                        <div class="<%= ui_inset_panel_classes(tone: group.fetch(:key) == :source_artifacts ? :success : :default) %>">
                          <div class="space-y-4">
                            <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                              <div class="min-w-0">
                                <p class="text-sm font-medium text-ink-950"><%= artifact.fetch(:name) %></p>
                                <% if artifact[:description].present? %>
                                  <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= artifact[:description] %></p>
                                <% end %>
                              </div>

                              <div class="flex flex-wrap gap-2">
                                <span class="<%= ui_badge_classes(:neutral) %>"><%= template_artifact_type_label(artifact.fetch(:artifact_type)) %></span>
                                <% if template_artifact_role_label(artifact).present? %>
                                  <span class="<%= ui_badge_classes(:neutral) %>"><%= template_artifact_role_label(artifact) %></span>
                                <% end %>
                                <% if artifact[:has_attachment] %>
                                  <span class="<%= ui_badge_classes(:info) %>"><%= t("admin.templates.show.fields.attachment") %></span>
                                <% end %>
                              </div>
                            </div>

                            <% if group.fetch(:key) == :source_artifacts %>
                              <div class="flex flex-wrap gap-2">
                                <%= button_to t("admin.templates.show.artifact_review.actions.create_candidate"), admin_template_implementation_candidates_path(@template), params: { source_artifact_id: artifact.fetch(:id) }, form_class: "inline-flex", class: ui_button_classes(:secondary, size: :sm) %>
                              </div>
                            <% end %>

                            <div class="grid gap-3 sm:grid-cols-2">
                              <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.identifier") %></p>
                                <p class="mt-1 break-all text-sm leading-6 text-ink-950"><%= artifact.fetch(:identifier) %></p>
                              </div>

                              <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.source_signature") %></p>
                                <p class="mt-1 break-all text-sm leading-6 text-ink-950"><%= artifact.fetch(:source_signature) %></p>
                              </div>

                              <% if artifact[:source_url].present? %>
                                <div class="sm:col-span-2">
                                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.source_url") %></p>
                                  <p class="mt-1 break-all text-sm leading-6">
                                    <%= link_to artifact[:source_url], artifact[:source_url], target: "_blank", rel: "noreferrer", class: "text-ink-900 underline decoration-canvas-300 underline-offset-4 hover:text-ink-950" %>
                                  </p>
                                </div>
                              <% end %>

                              <% if artifact[:parent_identifier].present? %>
                                <div>
                                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.parent_artifact") %></p>
                                  <p class="mt-1 break-all text-sm leading-6 text-ink-950"><%= artifact[:parent_identifier] %></p>
                                </div>
                              <% end %>

                              <% if attachment_summary.present? %>
                                <div>
                                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.attachment") %></p>
                                  <p class="mt-1 text-sm leading-6 text-ink-950"><%= attachment_summary %></p>
                                </div>
                              <% end %>
                            </div>

                            <% if artifact[:metadata].present? %>
                              <details class="overflow-hidden rounded-[1.25rem] border border-canvas-200/80 bg-canvas-50/92">
                                <summary class="cursor-pointer px-4 py-4">
                                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                    <div>
                                      <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.fields.metadata") %></p>
                                      <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= attachment_summary.presence || group.fetch(:description) %></p>
                                    </div>

                                    <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.templates.show.fields.reference_only") %></span>
                                  </div>
                                </summary>

                                <div class="border-t border-canvas-200/80 px-4 py-4">
                                  <%= render Ui::CodeBlockComponent.new(
                                    title: t("admin.templates.show.fields.metadata"),
                                    description: group.fetch(:description),
                                    body: JSON.pretty_generate(artifact.fetch(:metadata)),
                                    wrap: true
                                  ) %>
                                </div>
                              </details>
                            <% end %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <%= render Ui::EmptyStateComponent.new(
                      title: group.fetch(:empty_title),
                      description: group.fetch(:empty_description),
                      padding: :sm,
                      tone: :subtle,
                      align: :left,
                      title_size: :sm
                    ) %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: t("admin.templates.show.implementation_validation.title"),
        anchor: "implementation-validation",
        eyebrow: t("admin.templates.show.implementation_validation.eyebrow"),
        description: t("admin.templates.show.implementation_validation.description"),
        badges: [
          {
            label: current_implementation.present? ? template_lifecycle_status_label(current_implementation.fetch(:status, nil)) : t("admin.templates.show.implementation_validation.badges.no_implementation"),
            tone: current_implementation.present? ? template_implementation_status_tone(current_implementation.fetch(:status, nil)) : :neutral
          },
          (draft_candidates.any? ? {
            label: t("admin.templates.show.implementation_validation.badges.draft_candidates", count: draft_candidates.size),
            tone: :info
          } : nil),
          {
            label: t("admin.templates.show.implementation_validation.badges.validation_runs", count: validation_runs.size),
            tone: validation_runs.any? ? :info : :neutral
          }
        ].compact
      ) do %>
        <div class="space-y-4">
          <div class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
          <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :md) do %>
            <div class="space-y-4">
              <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.implementation_validation.implementation_card.title") %></p>
                  <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("admin.templates.show.implementation_validation.implementation_card.description") %></p>
                </div>

                <% if artifact_review_counts.fetch(:source_artifacts).positive? %>
                  <%= button_to t("admin.templates.show.implementation_validation.implementation_card.actions.create_candidate"), admin_template_implementation_candidates_path(@template), form_class: "inline-flex", class: ui_button_classes(:secondary, size: :sm) %>
                <% end %>
              </div>

              <% if current_implementation.present? %>
                <div class="<%= ui_inset_panel_classes(tone: template_implementation_status_tone(current_implementation.fetch(:status, nil)) == :success ? :success : :subtle) %>">
                  <div class="space-y-4">
                    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                      <div>
                        <p class="text-base font-medium text-ink-950"><%= current_implementation.fetch(:name) %></p>
                        <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= current_implementation.fetch(:identifier) %></p>
                      </div>

                      <div class="flex flex-wrap gap-2">
                        <span class="<%= ui_badge_classes(template_implementation_status_tone(current_implementation.fetch(:status, nil))) %>"><%= template_lifecycle_status_label(current_implementation.fetch(:status, nil)) %></span>
                        <span class="<%= ui_badge_classes(:neutral) %>"><%= current_implementation.fetch(:renderer_family).to_s.tr("_", " ").titleize %></span>
                        <% if current_implementation[:source_artifact_identifier].present? %>
                          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.templates.show.fields.source_artifact") %>: <%= current_implementation[:source_artifact_identifier] %></span>
                        <% end %>
                      </div>
                    </div>

                    <% if current_implementation[:metadata].present? %>
                      <p class="text-sm leading-6 text-ink-700/80"><%= current_implementation.fetch(:metadata).map { |key, value| "#{key.to_s.tr('_', ' ').titleize}: #{value}" }.join(" · ") %></p>
                    <% end %>

                    <details class="overflow-hidden rounded-[1.25rem] border border-canvas-200/80 bg-canvas-50/92">
                      <summary class="cursor-pointer px-4 py-4">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                          <div>
                            <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.implementation_validation.implementation_card.render_profile_title") %></p>
                            <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("admin.templates.show.implementation_validation.implementation_card.render_profile_description") %></p>
                          </div>

                          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.templates.show.implementation_validation.implementation_card.reference_badge") %></span>
                        </div>
                      </summary>

                      <div class="border-t border-canvas-200/80 px-4 py-4">
                        <%= render Ui::CodeBlockComponent.new(
                          title: t("admin.templates.show.implementation_validation.implementation_card.render_profile_title"),
                          description: t("admin.templates.show.implementation_validation.implementation_card.render_profile_description"),
                          body: JSON.pretty_generate(current_implementation.fetch(:render_profile)),
                          wrap: true
                        ) %>
                      </div>
                    </details>
                  </div>
                </div>
              <% else %>
                <%= render Ui::EmptyStateComponent.new(
                  title: t("admin.templates.show.implementation_validation.implementation_card.empty_title"),
                  description: t("admin.templates.show.implementation_validation.implementation_card.empty_description"),
                  padding: :sm,
                  tone: :subtle,
                  align: :left,
                  title_size: :sm
                ) %>
              <% end %>
            </div>
          <% end %>

          <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :md) do %>
            <div class="space-y-4">
              <div>
                <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.implementation_validation.validation_runs.title") %></p>
                <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("admin.templates.show.implementation_validation.validation_runs.description") %></p>
              </div>

              <% if validation_runs.any? %>
                <div class="space-y-3">
                  <% validation_runs.each do |run| %>
                    <div class="<%= ui_inset_panel_classes(tone: template_validation_status_tone(run.fetch(:status, nil)) == :success ? :success : :default) %>">
                      <div class="space-y-3">
                        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                          <div>
                            <p class="text-sm font-medium text-ink-950"><%= template_lifecycle_status_label(run.fetch(:validation_type, nil)) %></p>
                            <% summary = template_validation_run_metric_summary(run) %>
                            <% if summary.present? %>
                              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= summary %></p>
                            <% end %>
                          </div>

                          <span class="<%= ui_badge_classes(template_validation_status_tone(run.fetch(:status, nil))) %>"><%= template_lifecycle_status_label(run.fetch(:status, nil)) %></span>
                        </div>

                        <div class="grid gap-3 sm:grid-cols-2">
                          <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.identifier") %></p>
                            <p class="mt-1 break-all text-sm leading-6 text-ink-950"><%= run.fetch(:identifier) %></p>
                          </div>

                          <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.validator") %></p>
                            <p class="mt-1 text-sm leading-6 text-ink-950"><%= run[:validator_name].presence || t("admin.templates.show.fields.not_recorded") %></p>
                          </div>

                          <% if run[:template_implementation_name].present? %>
                            <div>
                              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.implementation") %></p>
                              <p class="mt-1 text-sm leading-6 text-ink-950"><%= [run[:template_implementation_name], run[:template_implementation_identifier]].compact.join(" · ") %></p>
                            </div>
                          <% end %>

                          <% if run[:validated_at].present? %>
                            <div>
                              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("admin.templates.show.fields.validated_at") %></p>
                              <p class="mt-1 text-sm leading-6 text-ink-950"><%= I18n.l(run[:validated_at], format: :long) %></p>
                            </div>
                          <% end %>

                          <% if run[:metadata].present? || run[:metrics].present? %>
                            <details class="overflow-hidden rounded-[1.25rem] border border-canvas-200/80 bg-canvas-50/92 sm:col-span-2">
                              <summary class="cursor-pointer px-4 py-4">
                                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                  <div>
                                    <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.implementation_validation.validation_runs.metadata_title") %></p>
                                    <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("admin.templates.show.implementation_validation.validation_runs.metadata_description") %></p>
                                  </div>

                                  <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.templates.show.fields.reference_only") %></span>
                                </div>
                              </summary>

                              <div class="border-t border-canvas-200/80 px-4 py-4">
                                <%= render Ui::CodeBlockComponent.new(
                                  title: t("admin.templates.show.implementation_validation.validation_runs.metadata_title"),
                                  description: t("admin.templates.show.implementation_validation.validation_runs.metadata_description"),
                                  body: JSON.pretty_generate({ metrics: run.fetch(:metrics), metadata: run.fetch(:metadata) }),
                                  wrap: true
                                ) %>
                              </div>
                            </details>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <%= render Ui::EmptyStateComponent.new(
                  title: t("admin.templates.show.implementation_validation.validation_runs.empty_title"),
                  description: t("admin.templates.show.implementation_validation.validation_runs.empty_description"),
                  padding: :sm,
                  tone: :subtle,
                  align: :left,
                  title_size: :sm
                ) %>
              <% end %>
            </div>
          <% end %>
          </div>

          <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :md) do %>
            <div class="space-y-4">
              <div>
                <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.implementation_validation.draft_candidates.title") %></p>
                <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("admin.templates.show.implementation_validation.draft_candidates.description") %></p>
              </div>

              <% if draft_candidates.any? %>
                <div class="space-y-3">
                  <% draft_candidates.each do |candidate| %>
                    <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
                      <div class="space-y-4">
                        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                          <div>
                            <p class="text-sm font-medium text-ink-950"><%= candidate.fetch(:name) %></p>
                            <% summary = template_candidate_summary(candidate) %>
                            <% if summary.present? %>
                              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= summary %></p>
                            <% end %>
                          </div>

                          <div class="flex flex-wrap gap-2">
                            <span class="<%= ui_badge_classes(:info) %>"><%= template_lifecycle_status_label(candidate.fetch(:status, nil)) %></span>
                            <span class="<%= ui_badge_classes(:neutral) %>"><%= candidate.fetch(:renderer_family).to_s.tr("_", " ").titleize %></span>
                          </div>
                        </div>

                        <% if candidate[:notes].present? %>
                          <p class="text-sm leading-6 text-ink-700/80"><%= candidate[:notes] %></p>
                        <% end %>

                        <div class="<%= ui_inset_panel_classes(tone: template_candidate_latest_validation_tone(candidate)) %>">
                          <div class="space-y-3">
                            <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                              <div>
                                <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.implementation_validation.draft_candidates.validation.title") %></p>
                                <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= template_candidate_latest_validation_label(candidate) %></p>
                              </div>

                              <span class="<%= ui_badge_classes(template_candidate_latest_validation_tone(candidate)) %>"><%= pluralize(candidate[:validation_runs_count], "run") %></span>
                            </div>

                            <p class="text-sm leading-6 text-ink-700/80"><%= template_candidate_promotion_message(candidate) %></p>

                            <div class="flex flex-wrap gap-2">
                              <%= button_to t("admin.templates.show.implementation_validation.draft_candidates.actions.record_pass"), admin_template_implementation_validation_runs_path(@template, candidate.fetch(:id)), params: { validation_run: { validation_type: "manual_review", status: "passed" } }, form_class: "inline-flex", class: ui_button_classes(:secondary, size: :sm) %>
                              <%= button_to t("admin.templates.show.implementation_validation.draft_candidates.actions.record_follow_up"), admin_template_implementation_validation_runs_path(@template, candidate.fetch(:id)), params: { validation_run: { validation_type: "manual_review", status: "needs_review" } }, form_class: "inline-flex", class: ui_button_classes(:secondary, size: :sm) %>
                              <% if candidate[:promotion_ready] %>
                                <%= button_to t("admin.templates.show.implementation_validation.draft_candidates.actions.promote"), admin_template_implementation_promotion_path(@template, candidate.fetch(:id)), form_class: "inline-flex", class: ui_button_classes(:primary, size: :sm) %>
                              <% end %>
                            </div>
                          </div>
                        </div>

                        <% if candidate[:metadata].present? %>
                          <p class="text-sm leading-6 text-ink-700/80"><%= candidate.fetch(:metadata).map { |key, value| "#{key.to_s.tr('_', ' ').titleize}: #{value}" }.join(" · ") %></p>
                        <% end %>

                        <details class="overflow-hidden rounded-[1.25rem] border border-canvas-200/80 bg-canvas-50/92">
                          <summary class="cursor-pointer px-4 py-4">
                            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                              <div>
                                <p class="text-sm font-medium text-ink-950"><%= t("admin.templates.show.implementation_validation.draft_candidates.render_profile_title") %></p>
                                <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("admin.templates.show.implementation_validation.draft_candidates.render_profile_description") %></p>
                              </div>

                              <span class="<%= ui_badge_classes(:neutral) %>"><%= t("admin.templates.show.fields.reference_only") %></span>
                            </div>
                          </summary>

                          <div class="border-t border-canvas-200/80 px-4 py-4">
                            <%= render Ui::CodeBlockComponent.new(
                              title: t("admin.templates.show.implementation_validation.draft_candidates.render_profile_title"),
                              description: t("admin.templates.show.implementation_validation.draft_candidates.render_profile_description"),
                              body: JSON.pretty_generate(candidate.fetch(:render_profile)),
                              wrap: true
                            ) %>
                          </div>
                        </details>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <%= render Ui::EmptyStateComponent.new(
                  title: t("admin.templates.show.implementation_validation.draft_candidates.empty_title"),
                  description: t("admin.templates.show.implementation_validation.draft_candidates.empty_description"),
                  padding: :sm,
                  tone: :subtle,
                  align: :left,
                  title_size: :sm
                ) %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= render Ui::SettingsSectionComponent.new(
        title: "Configuration",
        anchor: "configuration",
        eyebrow: "Activation & config",
        description: "Review who can see this template and open raw layout config only when you need reference detail.",
        badges: [
          { label: template_visibility_label(@template), tone: template_visibility_tone(@template) },
          { label: template_status_label(@template), tone: template_status_badge_tone(@template) }
        ]
      ) do %>
        <div class="grid gap-4 xl:grid-cols-[0.9fr_1.1fr]">
          <div class="space-y-4">
            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <p class="text-sm font-medium text-ink-700/70">Template visibility</p>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <span class="<%= ui_badge_classes(template_visibility_tone(@template)) %>"><%= template_visibility_label(@template) %></span>
                <span class="text-sm text-ink-700/80"><%= template_visibility_description(@template) %></span>
              </div>
            </div>

            <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
              <div class="flex items-start gap-3">
                <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :soft) %>
                <div>
                  <p class="text-sm font-medium text-ink-950">Next step</p>
                  <p class="mt-2 text-sm leading-6 text-ink-700/80">Use the edit flow to adjust the family, typography, density, and accent settings, then confirm the shared preview still matches the intended layout direction.</p>
                </div>
              </div>
            </div>

            <div class="flex flex-wrap gap-2">
              <%= link_to "Edit template", edit_admin_template_path(@template), class: ui_button_classes(:primary, size: :sm) %>
              <% if @template.active? %>
                <%= link_to "Use in new resume", new_resume_path(template_id: @template.id), class: ui_button_classes(:secondary, size: :sm) %>
              <% end %>
              <%= button_to "Delete template", admin_template_path(@template), method: :delete, form_class: "inline-flex", class: ui_button_classes(:danger, size: :sm) %>
            </div>
          </div>

          <details class="overflow-hidden rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92">
            <summary class="cursor-pointer px-5 py-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-950">Raw layout config</p>
                  <p class="mt-1 text-sm leading-6 text-ink-700/80">Stored values are normalized through the template catalog when the record is saved.</p>
                </div>

                <span class="<%= ui_badge_classes(:neutral) %>">Reference only</span>
              </div>
            </summary>

            <div class="border-t border-canvas-200/80 px-5 py-5">
              <%= render Ui::CodeBlockComponent.new(
                title: "Raw layout config",
                description: "Stored values are normalized through the template catalog when the record is saved.",
                body: JSON.pretty_generate(@template.layout_config)
              ) %>
            </div>
          </details>
        </div>
      <% end %>
    </div>
  </div>
</section>
