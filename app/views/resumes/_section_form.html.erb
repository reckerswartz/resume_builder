<% allowed_section_types = local_assigns.fetch(:allowed_section_types, nil) %>

<%= render Ui::DashboardPanelComponent.new(
  title: "Add section",
  description: "Create a new section and then add entries to it without leaving the guided workspace.",
  padding: :sm
) do %>
  <div class="space-y-4">
    <div class="flex flex-wrap gap-2">
      <span class="atelier-pill">
        <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
        Section setup
      </span>
      <span class="<%= ui_badge_classes(:neutral) %>">White-canvas add flow</span>
    </div>

    <%= form_with model: [resume, Section.new], url: resume_sections_path(resume, **resume_builder_step_params), class: "grid gap-4 sm:grid-cols-[1fr_200px_auto] sm:items-end" do |form| %>
      <div>
        <%= form.label :title, class: ui_label_classes %>
        <%= form.text_field :title, placeholder: "Awards", class: ui_input_classes %>
      </div>

      <div>
        <%= form.label :section_type, "Type", class: ui_label_classes %>
        <%= form.select :section_type, options_for_select(section_type_options_for_builder(only: allowed_section_types)), {}, class: ui_input_classes %>
      </div>

      <div>
        <%= form.submit "Add section", class: ui_button_classes(:primary) %>
      </div>
    <% end %>
  </div>
<% end %>
