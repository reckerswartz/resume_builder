<% preview_state = local_assigns.fetch(:preview_state) { resume_builder_preview_state(resume) } %>
<% preview_page_action = preview_state.preview_page_action %>

<%= turbo_frame_tag dom_id(resume, :preview) do %>
  <div class="space-y-4 xl:sticky xl:top-6">
    <%= render Ui::DashboardPanelComponent.new(**preview_state.panel_attributes) do %>
      <div class="flex flex-wrap gap-2">
        <% preview_state.badges.each do |badge| %>
          <span class="<%= ui_badge_classes(badge.fetch(:tone, :neutral)) %>"><%= badge.fetch(:label) %></span>
        <% end %>
      </div>

      <div class="mt-4 space-y-4">
        <div class="flex flex-col gap-3 border-b border-canvas-200/80 pb-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
              <%= t("resumes.preview.live_sample") %>
            </span>
            <p class="mt-3 text-sm leading-6 text-ink-700/80"><%= t("resumes.preview.description") %></p>
          </div>

          <div>
            <%= link_to preview_page_action.fetch(:label), preview_page_action.fetch(:path), class: ui_button_classes(preview_page_action.fetch(:style), size: preview_page_action.fetch(:size)), **preview_page_action.fetch(:options, {}) %>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <%= render Ui::WidgetCardComponent.new(**preview_state.sync_card_attributes) %>

          <%= render "resumes/export_status_panel", resume: resume, context: :preview, export_status_state: preview_state.export_status_state %>
        </div>

        <div class="relative overflow-hidden rounded-[1.75rem] border border-canvas-200/80 bg-canvas-50/92 p-4 shadow-[0_16px_36px_rgba(15,23,42,0.06)] sm:p-6">
          <div class="absolute -right-12 top-6 h-24 w-24 rounded-full atelier-glow opacity-35"></div>
          <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

          <div class="relative">
            <%= render ResumeTemplates::ComponentResolver.component_for(resume) %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
