<%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "mx-auto w-full max-w-5xl") do %>
  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem]">
    <div class="space-y-6">
      <div class="space-y-3">
        <span class="atelier-pill">Step 2</span>
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold tracking-tight text-ink-950">Are you a student?</h2>
          <p class="text-sm leading-6 text-ink-700/80">This helps us keep the setup flow flexible for early-career resumes without forcing every draft down the same path.</p>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        <% start_flow_state.student_options.each do |option| %>
          <%= link_to new_resume_path(
                step: "setup",
                template_id: start_flow_state.selected_template_id,
                resume: {
                  intake_details: {
                    experience_level: start_flow_state.selected_experience_level,
                    student_status: option.fetch(:value)
                  }
                }
              ),
              class: [ui_inset_panel_classes(tone: :subtle), "block transition hover:border-canvas-300 hover:bg-canvas-50/92 focus:outline-none focus:ring-2 focus:ring-ink-400/30"].join(" ") do %>
            <div class="space-y-2">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70">Student status</p>
              <p class="text-base font-semibold tracking-tight text-ink-950"><%= option.fetch(:label) %></p>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "Skip for now",
          new_resume_path(
            step: "setup",
            template_id: start_flow_state.selected_template_id,
            resume: {
              intake_details: {
                experience_level: start_flow_state.selected_experience_level,
                student_status: ""
              }
            }
          ),
          class: ui_button_classes(:secondary) %>
      </div>
    </div>

    <%= render Ui::DashboardPanelComponent.new(
      eyebrow: "Why we ask",
      title: "Keep the flow relevant for entry-level resumes",
      description: "Student status can shape later guidance for internships, coursework, projects, and volunteer work. You can skip it and keep moving.",
      tone: :subtle,
      padding: :md,
      density: :compact
    ) do %>
      <div class="space-y-3 text-sm leading-6 text-ink-700/80">
        <p>The answer stays lightweight and optional. It only helps us carry better context into the next setup step.</p>
        <div class="flex flex-wrap gap-2">
          <span class="<%= ui_badge_classes(:neutral) %>">Optional question</span>
          <span class="<%= ui_badge_classes(:neutral) %>">Skip supported</span>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
