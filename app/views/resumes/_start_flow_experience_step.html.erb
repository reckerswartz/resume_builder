<%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "mx-auto w-full max-w-5xl") do %>
  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem]">
    <div class="space-y-6">
      <div class="space-y-3">
        <span class="atelier-pill"><%= t(".step_badge") %></span>
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold tracking-tight text-ink-950"><%= t(".title") %></h2>
          <p class="text-sm leading-6 text-ink-700/80"><%= t(".description") %></p>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        <% start_flow_state.experience_options.each do |option| %>
          <%= link_to new_resume_path(
                step: start_flow_state.next_step_for_experience(option.fetch(:value)),
                template_id: start_flow_state.selected_template_id,
                resume: {
                  intake_details: {
                    experience_level: option.fetch(:value)
                  }
                }
              ),
              class: [ui_inset_panel_classes(tone: :subtle), "block transition hover:border-canvas-300 hover:bg-canvas-50/92 focus:outline-none focus:ring-2 focus:ring-ink-400/30"].join(" ") do %>
            <div class="space-y-2">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t(".option_eyebrow") %></p>
              <p class="text-base font-semibold tracking-tight text-ink-950"><%= option.fetch(:label) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%= render Ui::DashboardPanelComponent.new(
      eyebrow: t(".panel_eyebrow"),
      title: t(".panel_title"),
      description: t(".panel_description"),
      tone: :subtle,
      padding: :md,
      density: :compact
    ) do %>
      <div class="space-y-3">
        <div class="flex flex-wrap gap-2">
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".quick_choices_badge") %></span>
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".template_carry_through_badge") %></span>
        </div>

        <ol class="space-y-2 text-sm leading-6 text-ink-700/80">
          <li class="flex items-start gap-2">
            <span class="<%= ui_step_circle_classes %>">1</span>
            <span><%= t(".steps.choose_experience") %></span>
          </li>
          <li class="flex items-start gap-2">
            <span class="<%= ui_step_circle_classes %>">2</span>
            <span><%= t(".steps.review_setup") %></span>
          </li>
          <li class="flex items-start gap-2">
            <span class="<%= ui_step_circle_classes %>">3</span>
            <span><%= t(".steps.create_draft") %></span>
          </li>
        </ol>
      </div>
    <% end %>
  </div>
<% end %>
