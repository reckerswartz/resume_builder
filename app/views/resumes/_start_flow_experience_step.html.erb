<%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "mx-auto w-full max-w-5xl") do %>
  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem]">
    <div class="space-y-6">
      <div class="space-y-3">
        <span class="atelier-pill">Step 1</span>
        <div class="space-y-2">
          <h2 class="text-2xl font-semibold tracking-tight text-ink-950">How long have you been working?</h2>
          <p class="text-sm leading-6 text-ink-700/80">We’ll find the best templates for your experience level.</p>
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        <% start_flow_state.experience_options.each do |option| %>
          <%= link_to new_resume_path(
                step: start_flow_state.next_step_for_experience(option.fetch(:value)),
                template_id: start_flow_state.selected_template_id,
                resume: {
                  intake_details: {
                    experience_level: option.fetch(:value)
                  }
                }
              ),
              class: [ui_inset_panel_classes(tone: :subtle), "block transition hover:border-canvas-300 hover:bg-canvas-50/92 focus:outline-none focus:ring-2 focus:ring-ink-400/30"].join(" ") do %>
            <div class="space-y-2">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70">Experience level</p>
              <p class="text-base font-semibold tracking-tight text-ink-950"><%= option.fetch(:label) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%= render Ui::DashboardPanelComponent.new(
      eyebrow: "What happens next",
      title: "Choose your starting path",
      description: "We’ll keep the flow lightweight, carry your template selection forward, and open the setup form once you choose your experience level.",
      tone: :subtle,
      padding: :md,
      density: :compact
    ) do %>
      <div class="space-y-3">
        <div class="flex flex-wrap gap-2">
          <span class="<%= ui_badge_classes(:neutral) %>">5 quick choices</span>
          <span class="<%= ui_badge_classes(:neutral) %>">Template carry-through</span>
        </div>

        <ol class="space-y-2 text-sm leading-6 text-ink-700/80">
          <li class="flex items-start gap-2">
            <span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-ink-950 text-[0.65rem] font-semibold text-white">1</span>
            <span>Pick the experience band that best fits the draft you want to build.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-ink-950 text-[0.65rem] font-semibold text-white">2</span>
            <span>Review the fast-create setup form with your selected template already in place.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full bg-ink-950 text-[0.65rem] font-semibold text-white">3</span>
            <span>Create the draft shell and continue into the guided builder.</span>
          </li>
        </ol>
      </div>
    <% end %>
  </div>
<% end %>
