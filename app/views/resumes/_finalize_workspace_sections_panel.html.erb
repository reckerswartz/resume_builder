<div class="space-y-5">
  <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <h3 class="text-lg font-semibold tracking-tight text-ink-950"><%= t("resumes.editor_finalize_step.sections_workspace.title") %></h3>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_finalize_step.sections_workspace.description") %></p>
    </div>

    <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_finalize_step.sections_workspace.badge") %></span>
  </div>

  <% if finalize_workspace_state.has_section_order_controls? %>
    <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'space-y-4'].join(' ') %>" data-finalize-section-order>
      <div class="flex flex-col gap-2 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <p class="text-sm font-semibold text-ink-950"><%= t("resumes.editor_finalize_step.sections_workspace.order_title") %></p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_finalize_step.sections_workspace.order_description") %></p>
        </div>

        <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_finalize_step.sections_workspace.order_badge") %></span>
      </div>

      <div class="space-y-3" data-controller="sortable">
        <% finalize_workspace_state.section_order_states.each do |section_state| %>
          <div
            id="<%= section_state.fetch(:id) %>"
            class="<%= ui_inset_panel_classes %>"
            data-action="dragstart->sortable#dragstart dragover->sortable#dragover drop->sortable#drop dragend->sortable#dragend"
            data-sortable-target="item"
            data-sortable-move-url="<%= section_state.fetch(:move_url) %>"
            draggable="true"
          >
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
              <div class="space-y-1.5">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="<%= ui_badge_classes(:neutral) %>"><%= section_state.fetch(:position_label) %></span>
                  <span class="<%= ui_badge_classes(section_state.fetch(:visibility_badge_tone)) %>"><%= section_state.fetch(:visibility_badge_label) %></span>
                </div>
                <p class="text-sm font-semibold text-ink-950"><%= section_state.fetch(:title) %></p>
                <p class="text-sm leading-6 text-ink-700/80"><%= [section_state.fetch(:section_type_label), section_state.fetch(:entry_count_label)].join(" · ") %></p>
              </div>

              <span class="text-xs font-medium uppercase tracking-[0.18em] text-ink-500/80"><%= t("resumes.editor_finalize_step.sections_workspace.order_drag_hint") %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%= form_with model: resume, url: resume_path(resume, **resume_builder_step_params), data: { controller: "autosave", autosave_delay_value: 500, action: "input->autosave#queue change->autosave#queue" }, class: "space-y-5" do %>
    <%= hidden_field_tag :tab, "sections", data: { workspace_tabs_target: "input" } %>

    <% if finalize_workspace_state.has_section_visibility_controls? %>
      <%= hidden_field_tag "resume[settings][hidden_sections][]", "", id: nil %>

      <div class="space-y-3">
        <% finalize_workspace_state.section_visibility_states.each do |section_state| %>
          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <label class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between" for="<%= section_state.fetch(:input_id) %>">
              <span>
                <span class="block <%= ui_label_classes %>"><%= section_state.fetch(:label) %></span>
                <span class="mt-1 block text-sm leading-6 text-ink-700/80"><%= section_state.fetch(:summary) %></span>
              </span>

              <span class="flex items-center gap-3">
                <span class="<%= ui_badge_classes(section_state.fetch(:badge_tone)) %>"><%= section_state.fetch(:badge_label) %></span>
                <span class="flex items-center gap-3">
                  <span class="text-sm font-medium text-ink-700/80"><%= t("resumes.editor_finalize_step.sections_workspace.hide_label") %></span>
                  <%= check_box_tag "resume[settings][hidden_sections][]", section_state.fetch(:section_type), section_state.fetch(:hidden), id: section_state.fetch(:input_id), class: ui_checkbox_classes %>
                </span>
              </span>
            </label>
          </div>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::EmptyStateComponent.new(
        title: t("resumes.editor_finalize_step.sections_workspace.empty_state.title"),
        description: t("resumes.editor_finalize_step.sections_workspace.empty_state.description"),
        padding: :sm,
        tone: :subtle,
        align: :left
      ) %>
    <% end %>
  <% end %>

  <section id="<%= dom_id(resume, :step_sections) %>" class="space-y-4">
    <div data-finalize-additional-sections-surface>
      <%= render Ui::SurfaceCardComponent.new(padding: :sm, extra_classes: "overflow-hidden") do %>
        <div class="relative">
          <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>

          <div class="relative flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-3">
              <span class="atelier-pill">
                <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
                <%= t("resumes.editor_finalize_step.additional_sections.pill") %>
              </span>
              <div>
                <h3 class="text-xl font-semibold tracking-tight text-ink-950"><%= t("resumes.editor_finalize_step.additional_sections.title") %></h3>
                <p class="mt-2 max-w-3xl text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_finalize_step.additional_sections.description") %></p>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_finalize_step.additional_sections.badge") %></span>
            </div>
          </div>
        </div>

        <div class="mt-4 space-y-4">
          <% if step_sections.any? %>
            <div class="space-y-4" data-controller="sortable">
              <% step_sections.each do |section| %>
                <div id="<%= dom_id(section, :sortable_item) %>" data-action="dragstart->sortable#dragstart dragover->sortable#dragover drop->sortable#drop dragend->sortable#dragend" data-sortable-target="item" data-sortable-move-url="<%= move_resume_section_path(resume, section, **resume_builder_step_params) %>" draggable="true">
                  <%= render "resumes/section_editor", resume: resume, section: section, allowed_section_types: add_section_types %>
                </div>
              <% end %>
            </div>
          <% else %>
            <%= render Ui::EmptyStateComponent.new(
              title: t("resumes.editor_finalize_step.empty_state.title"),
              description: t("resumes.editor_finalize_step.empty_state.description")
            ) %>
          <% end %>

          <% if add_section_types.any? %>
            <%= render "resumes/section_form", resume: resume, allowed_section_types: add_section_types, open: step_sections.empty? %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
</div>
