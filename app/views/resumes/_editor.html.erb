<%= turbo_frame_tag dom_id(resume, :editor) do %>
  <div class="space-y-6">
    <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-4 border-b border-slate-200 pb-5 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Resume details</h2>
          <p class="mt-1 text-sm text-slate-600">Changes save in place and refresh the preview automatically.</p>
        </div>

        <div class="flex flex-wrap gap-2">
          <%= link_to "View", resume_path(resume), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
          <%= button_to "Export PDF", export_resume_path(resume), method: :post, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
          <% if resume.pdf_export.attached? %>
            <%= link_to "Download PDF", download_resume_path(resume), class: "rounded-full bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-700" %>
          <% end %>
        </div>
      </div>

      <%= form_with model: resume, data: { controller: "autosave", autosave_delay_value: 500, action: "input->autosave#queue change->autosave#queue" }, class: "mt-6 space-y-6" do |form| %>
        <% if resume.errors.any? %>
          <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            <%= resume.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="grid gap-5 sm:grid-cols-2">
          <div class="sm:col-span-2">
            <%= form.label :title, class: "text-sm font-medium text-slate-700" %>
            <%= form.text_field :title, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div class="sm:col-span-2">
            <%= form.label :headline, class: "text-sm font-medium text-slate-700" %>
            <%= form.text_field :headline, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= form.label :slug, class: "text-sm font-medium text-slate-700" %>
            <%= form.text_field :slug, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= form.label :template_id, "Template", class: "text-sm font-medium text-slate-700" %>
            <%= form.select :template_id, options_for_select(template_options_for_builder, resume.template_id), {}, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div class="sm:col-span-2">
            <%= form.label :summary, class: "text-sm font-medium text-slate-700" %>
            <%= form.text_area :summary, rows: 6, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <%= label_tag "resume_contact_details_full_name", "Full name", class: "text-sm font-medium text-slate-700" %>
            <%= text_field_tag "resume[contact_details][full_name]", resume.contact_field("full_name"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= label_tag "resume_contact_details_email", "Email", class: "text-sm font-medium text-slate-700" %>
            <%= email_field_tag "resume[contact_details][email]", resume.contact_field("email"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= label_tag "resume_contact_details_phone", "Phone", class: "text-sm font-medium text-slate-700" %>
            <%= telephone_field_tag "resume[contact_details][phone]", resume.contact_field("phone"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= label_tag "resume_contact_details_location", "Location", class: "text-sm font-medium text-slate-700" %>
            <%= text_field_tag "resume[contact_details][location]", resume.contact_field("location"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= label_tag "resume_contact_details_website", "Website", class: "text-sm font-medium text-slate-700" %>
            <%= url_field_tag "resume[contact_details][website]", resume.contact_field("website"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= label_tag "resume_contact_details_linkedin", "LinkedIn", class: "text-sm font-medium text-slate-700" %>
            <%= url_field_tag "resume[contact_details][linkedin]", resume.contact_field("linkedin"), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <%= label_tag "resume_settings_accent_color", "Accent color", class: "text-sm font-medium text-slate-700" %>
            <%= color_field_tag "resume[settings][accent_color]", resume.settings.fetch("accent_color", "#0F172A"), class: "mt-2 block h-12 w-full rounded-2xl border border-slate-300 bg-white px-2 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div>
            <%= label_tag "resume_settings_page_size", "Page size", class: "text-sm font-medium text-slate-700" %>
            <%= select_tag "resume[settings][page_size]", options_for_select([["A4", "A4"], ["Letter", "Letter"]], resume.settings.fetch("page_size", "A4")), class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
          </div>

          <div class="sm:col-span-2 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
            <%= hidden_field_tag "resume[settings][show_contact_icons]", false %>
            <label class="flex items-center justify-between gap-4">
              <span>
                <span class="block text-sm font-medium text-slate-700">Show contact icons</span>
                <span class="mt-1 block text-sm text-slate-500">Keep contact info compact in the preview and exported PDF.</span>
              </span>
              <%= check_box_tag "resume[settings][show_contact_icons]", true, resume.settings.fetch("show_contact_icons", true), class: "h-5 w-5 rounded border-slate-300 text-slate-900 focus:ring-slate-400" %>
            </label>
          </div>
        </div>

        <div class="flex justify-end">
          <%= form.submit "Save now", class: "inline-flex justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-700" %>
        </div>
      <% end %>
    </section>

    <section class="space-y-4">
      <div>
        <h3 class="text-xl font-semibold tracking-tight text-slate-900">Sections</h3>
        <p class="mt-1 text-sm text-slate-600">Manage the structure and content blocks that appear in your resume preview.</p>
      </div>

      <% resume.ordered_sections.each do |section| %>
        <%= render "section_editor", resume: resume, section: section %>
      <% end %>

      <%= render "section_form", resume: resume %>
    </section>
  </div>
<% end %>
