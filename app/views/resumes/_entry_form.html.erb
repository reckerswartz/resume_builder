<% persisted = entry.persisted? %>
<% disclosure_storage_key = persisted ? "resume-builder:entry:#{entry.id}" : "resume-builder:section:#{section.id}:new-entry" %>
<% disclosure_default_open = !persisted && section.ordered_entries.none? %>
<% form_options = persisted ? { data: { controller: "autosave", autosave_delay_value: 350, action: "input->autosave#queue change->autosave#queue" } } : {} %>
<% entry_url = persisted ? resume_section_entry_path(resume, section, entry, **resume_builder_step_params) : resume_section_entries_path(resume, section, **resume_builder_step_params) %>
<% section_type_label = ResumeBuilder::SectionRegistry.title_for(section.section_type) %>
<% card_options = {
  id: persisted ? dom_id(entry, :sortable_item) : dom_id(section, :new_entry),
  data: {
    controller: "disclosure",
    action: "toggle->disclosure#remember",
    disclosure_storage_key_value: disclosure_storage_key,
    disclosure_default_open_value: disclosure_default_open
  }
} %>
<% if persisted %>
  <% card_options[:data].merge!(
    action: "#{card_options.dig(:data, :action)} dragstart->sortable#dragstart dragover->sortable#dragover drop->sortable#drop dragend->sortable#dragend",
    sortable_target: "item",
    sortable_move_url: move_resume_section_entry_path(resume, section, entry, **resume_builder_step_params)
  ) %>
  <% card_options[:draggable] = true %>
<% end %>
<% card_options[:open] = true if disclosure_default_open %>

<%= render Ui::SurfaceCardComponent.new(
  tone: :default,
  tag: :details,
  padding: :none,
  extra_classes: "overflow-hidden",
  html_options: card_options
) do %>
  <summary class="list-none cursor-pointer bg-canvas-50/92 px-4 py-4 sm:px-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <span class="atelier-pill">
          <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
          <%= t("resumes.entry_form.pill") %>
        </span>

        <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-ink-700/70">
          <span class="<%= ui_badge_classes(:neutral) %>"><%= persisted ? t("resumes.entry_form.badges.live_entry") : t("resumes.entry_form.badges.new_entry") %></span>
          <span class="<%= ui_badge_classes(:info) %>"><%= section_type_label %></span>
          <% if persisted %>
            <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.entry_form.badges.drag_to_reorder") %></span>
          <% end %>
        </div>

        <h5 class="mt-3 break-words text-base font-semibold text-ink-950"><%= persisted ? entry_editor_title(entry, section) : t("resumes.entry_form.titles.add_entry", section: section_type_label.singularize) %></h5>
        <% if persisted && entry_editor_metadata(entry, section).present? %>
          <p class="mt-1 break-words text-sm text-ink-700/80"><%= entry_editor_metadata(entry, section) %></p>
        <% end %>

        <p class="mt-2 break-words text-sm leading-6 text-ink-700/80"><%= persisted ? entry_editor_supporting_text(entry, section).presence || t("resumes.entry_form.supporting_text.persisted_fallback", section: section_type_label) : (section.ordered_entries.any? ? t("resumes.entry_form.supporting_text.new_with_existing") : t("resumes.entry_form.supporting_text.new_without_existing")) %></p>
      </div>

      <span class="rounded-full border border-canvas-200/80 bg-white/80 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= persisted ? t("resumes.entry_form.disclosure_labels.expand_to_edit") : t("resumes.entry_form.disclosure_labels.open_form") %></span>
    </div>
  </summary>

  <div class="border-t border-canvas-200/80 px-4 py-4 sm:px-5 sm:py-5">
    <% if persisted %>
      <div class="mb-4 flex flex-wrap gap-2">
        <%= button_to t("resumes.entry_form.actions.up"), move_resume_section_entry_path(resume, section, entry, direction: :up, **resume_builder_step_params), method: :patch, class: ui_button_classes(:secondary, size: :sm) %>
        <%= button_to t("resumes.entry_form.actions.down"), move_resume_section_entry_path(resume, section, entry, direction: :down, **resume_builder_step_params), method: :patch, class: ui_button_classes(:secondary, size: :sm) %>
        <% if feature_enabled?("resume_suggestions") && llm_role_enabled?(:text_generation) %>
          <%= button_to t("resumes.entry_form.actions.improve"), improve_resume_section_entry_path(resume, section, entry, **resume_builder_step_params), method: :post, class: ui_button_classes(:warning, size: :sm) %>
        <% end %>
        <%= button_to t("resumes.entry_form.actions.remove"), resume_section_entry_path(resume, section, entry, **resume_builder_step_params), method: :delete, class: ui_button_classes(:danger, size: :sm) %>
      </div>
    <% end %>

    <%= form_with model: [resume, section, entry], url: entry_url, class: "grid gap-4 sm:grid-cols-2", **form_options do |form| %>
      <% entry_fields_for(section).each do |field| %>
        <div class="<%= entry_field_text_area?(field) || entry_field_checkbox?(field) ? 'sm:col-span-2' : '' %>">
          <%= label_tag "#{form.object_name}_content_#{field[:key]}", field[:label], class: ui_label_classes %>
          <% if entry_field_text_area?(field) %>
            <%= text_area_tag "#{form.object_name}[content][#{field[:key]}]", entry_field_value(entry, field[:key]), rows: 4, id: "#{form.object_name}_content_#{field[:key]}", class: ui_input_classes %>
          <% elsif entry_field_checkbox?(field) %>
            <div class="mt-2 <%= ui_inset_panel_classes %>">
              <%= hidden_field_tag "#{form.object_name}[content][#{field[:key]}]", false %>
              <label class="flex items-center justify-between gap-4" for="#{form.object_name}_content_#{field[:key]}">
                <span class="text-sm leading-6 text-ink-700/80"><%= t("resumes.entry_form.checkbox_hint") %></span>
                <%= check_box_tag "#{form.object_name}[content][#{field[:key]}]", true, entry_field_checked?(entry, field[:key]), id: "#{form.object_name}_content_#{field[:key]}", class: ui_checkbox_classes %>
              </label>
            </div>
          <% else %>
            <%= text_field_tag "#{form.object_name}[content][#{field[:key]}]", entry_field_value(entry, field[:key]), id: "#{form.object_name}_content_#{field[:key]}", class: ui_input_classes %>
          <% end %>
        </div>
      <% end %>

      <div class="flex flex-col gap-3 sm:col-span-2 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-ink-700/70"><%= persisted ? t("resumes.entry_form.footer_note.persisted") : t("resumes.entry_form.footer_note.new_entry") %></p>
        <%= form.submit(persisted ? t("resumes.entry_form.submit.save") : t("resumes.entry_form.submit.add"), class: ui_button_classes(:primary, size: :sm)) %>
      </div>
    <% end %>
  </div>
<% end %>
