<% guidance_state = resume_skills_step_state(resume).suggestions %>

<details class="<%= [ui_inset_panel_classes(tone: :subtle), 'group overflow-hidden'].join(' ') %>" data-skills-entry-guidance>
  <summary class="flex cursor-pointer list-none items-start justify-between gap-4 [&::-webkit-details-marker]:hidden">
    <div class="space-y-1">
      <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("resumes.skills_step_state.eyebrow") %></p>
      <p class="text-sm font-semibold text-ink-950"><%= guidance_state.fetch(:title) %></p>
      <p class="text-sm leading-6 text-ink-700/80"><%= guidance_state.fetch(:description) %></p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <span class="<%= ui_badge_classes(:info) %>"><%= guidance_state.fetch(:badge_label) %></span>
      <span class="<%= ui_badge_classes(:neutral) %>"><%= guidance_state.fetch(:results_label) %></span>
    </div>
  </summary>

  <div class="mt-4 grid gap-3 xl:grid-cols-2">
    <% guidance_state.fetch(:results).each do |suggestion| %>
      <div class="<%= [ui_inset_panel_classes(tone: :default, padding: :sm), 'space-y-3'].join(' ') %>" data-skills-suggestions-card>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div class="space-y-2">
            <p class="text-sm font-semibold text-ink-950"><%= suggestion.fetch(:role_title) %></p>
            <div class="flex flex-wrap gap-2">
              <% if suggestion.fetch(:expert_recommended) %>
                <span class="<%= ui_badge_classes(:success) %>"><%= suggestion.fetch(:expert_badge_label) %></span>
              <% end %>
              <span class="<%= ui_badge_classes(:info) %>"><%= suggestion.fetch(:audience_badge_label) %></span>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-2">
          <% suggestion.fetch(:skills).each do |skill_name| %>
            <button
              type="button"
              class="<%= ui_button_classes(:secondary, size: :sm) %>"
              data-action="skills-suggestions#add"
              data-skills-suggestions-card>
              <span data-skills-suggestions-skill-name><%= skill_name %></span>
            </button>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</details>
