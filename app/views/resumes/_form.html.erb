<div class="mx-auto w-full max-w-3xl rounded-[2rem] border border-slate-200 bg-white p-8 shadow-xl shadow-slate-200/70">
  <%= form_with model: resume, class: "space-y-6" do |form| %>
    <% if resume.errors.any? %>
      <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
        <%= resume.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid gap-5 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= form.label :title, class: "text-sm font-medium text-slate-700" %>
        <%= form.text_field :title, required: true, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :headline, class: "text-sm font-medium text-slate-700" %>
        <%= form.text_field :headline, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :summary, class: "text-sm font-medium text-slate-700" %>
        <%= form.text_area :summary, rows: 5, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :template_id, "Template", class: "text-sm font-medium text-slate-700" %>
        <%= form.select :template_id, options_for_select(template_options_for_builder, resume.template_id), {}, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>
    </div>

    <div class="flex items-center justify-between gap-4">
      <p class="text-sm text-slate-500">You can refine contact details, settings, and entries from the editor after creation.</p>
      <%= form.submit(resume.persisted? ? "Save changes" : "Create resume", class: "inline-flex justify-center rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-700") %>
    </div>
  <% end %>
</div>
