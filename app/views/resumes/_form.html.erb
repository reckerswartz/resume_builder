<% start_flow_state = local_assigns[:start_flow_state] %>
<% autofill_enabled = feature_enabled?("autofill_content") && llm_role_enabled?(:text_generation) %>
<% template_picker_state = resume_template_picker_state(
     resume: resume,
     form_object_name: "resume",
     field_label: t(".template_field_label"),
     description: t(".template_picker_description"),
     mode: :compact
   ) %>

<%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "resume-create-fast-path mx-auto w-full max-w-5xl") do %>
  <%= form_with model: resume, class: "space-y-6" do |form| %>
    <% if start_flow_state&.setup_step? %>
      <%= hidden_field_tag :step, start_flow_state.current_step %>
    <% end %>

    <% if start_flow_state&.selected_experience_level.present? %>
      <%= hidden_field_tag "#{form.object_name}[intake_details][experience_level]", start_flow_state.selected_experience_level %>
    <% end %>

    <% if start_flow_state&.selected_experience_level == "less_than_3_years" %>
      <%= hidden_field_tag "#{form.object_name}[intake_details][student_status]", start_flow_state.selected_student_status %>
    <% end %>

    <% if resume.errors.any? %>
      <div class="<%= [ ui_inset_panel_classes(tone: :danger), 'text-sm text-rose-700' ].join(' ') %>">
        <%= resume.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="space-y-6">
        <% if start_flow_state&.selected_experience_option.present? %>
          <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'resume-start-flow-selection'].join(' ') %>">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t(".experience_level_label") %></p>
            <p class="mt-2 text-sm font-semibold tracking-tight text-ink-950"><%= start_flow_state.selected_experience_option.fetch(:label) %></p>
          </div>
        <% end %>

        <div>
          <%= form.label :title, t(".title_label"), class: ui_label_classes %>
          <%= form.text_field :title, required: true, class: ui_input_classes %>
          <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t(".title_hint") %></p>
        </div>

        <details class="<%= [ui_inset_panel_classes(tone: :subtle), 'resume-create-optional-fields group'].join(' ') %>" <%= 'open' if resume.headline.present? || resume.summary.present? %>>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold tracking-tight text-ink-950 [&::-webkit-details-marker]:hidden">
            <span><%= t(".optional_fields_summary") %></span>
            <span class="text-xs font-medium uppercase tracking-[0.2em] text-ink-700/70"><%= t(".optional_badge") %></span>
          </summary>

          <div class="mt-4 grid gap-5 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <%= form.label :headline, t(".headline_label"), class: ui_label_classes %>
              <%= form.text_field :headline, class: ui_input_classes %>
            </div>

            <div class="sm:col-span-2">
              <%= form.label :summary, t(".summary_label"), class: ui_label_classes %>
              <%= form.text_area :summary, rows: 4, class: ui_input_classes %>
            </div>
          </div>
        </details>

        <details class="<%= [ui_inset_panel_classes(tone: :subtle), 'resume-create-source-import group'].join(' ') %>" <%= 'open' if resume.source_text.present? || resume.source_document.attached? %>>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold tracking-tight text-ink-950 [&::-webkit-details-marker]:hidden">
            <span><%= t(".import_title") %></span>
            <span class="text-xs font-medium uppercase tracking-[0.2em] text-ink-700/70"><%= t(".optional_badge") %></span>
          </summary>

          <div class="mt-4 space-y-4">
            <%= render "resumes/source_import_fields", form: form, resume: resume, autofill_enabled: autofill_enabled %>
          </div>
        </details>

        <details class="<%= [ui_inset_panel_classes(tone: :subtle), 'resume-create-template-picker group'].join(' ') %>" data-resume-template-disclosure>
          <summary class="flex cursor-pointer list-none items-start justify-between gap-3 [&::-webkit-details-marker]:hidden">
            <div>
              <span class="text-sm font-semibold tracking-tight text-ink-950"><%= t(".template_disclosure_summary") %></span>
              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t(".template_disclosure_description", template: template_picker_state.selected_card_state.fetch(:template).name) %></p>
            </div>
            <span class="text-xs font-medium uppercase tracking-[0.2em] text-ink-700/70"><%= t(".template_disclosure_badge") %></span>
          </summary>

          <div class="mt-4">
            <%= render "resumes/template_picker",
              form: form,
              resume: resume,
              template_picker_state: template_picker_state %>
          </div>
        </details>
      </div>

      <%= render Ui::DashboardPanelComponent.new(
        eyebrow: t(".next_panel_eyebrow"),
        title: resume.persisted? ? t(".next_panel_title_update") : t(".next_panel_title_create"),
        description: t(".next_panel_description"),
        tone: :subtle,
        padding: :md,
        density: :compact
      ) do %>
        <div class="space-y-3">
          <div class="flex flex-wrap gap-2">
            <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".starter_sections_badge") %></span>
            <span class="<%= ui_badge_classes(:neutral) %>"><%= t(".template_switch_later_badge") %></span>
          </div>

          <ol class="space-y-2 text-sm leading-6 text-ink-700/80">
            <li class="flex items-start gap-2">
              <span class="<%= ui_step_circle_classes %>">1</span>
              <span><%= t(".steps.build_shell") %></span>
            </li>
            <li class="flex items-start gap-2">
              <span class="<%= ui_step_circle_classes %>">2</span>
              <span><%= t(".steps.guided_builder") %></span>
            </li>
            <li class="flex items-start gap-2">
              <span class="<%= ui_step_circle_classes %>">3</span>
              <span><%= t(".steps.refine_later") %></span>
            </li>
          </ol>
        </div>
      <% end %>
    </div>

    <div class="flex flex-col gap-3 border-t border-canvas-200/80 pt-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm leading-6 text-ink-700/80"><%= t(".footer_note") %></p>
      <%= form.submit(resume.persisted? ? t(".save_changes") : t(".create_resume"), class: ui_button_classes(:primary)) %>
    </div>
  <% end %>
<% end %>
