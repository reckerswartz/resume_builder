<section class="space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Resume builder</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900"><%= @resume.title %></h1>
      <p class="mt-2 text-sm text-slate-600">Edit details, sections, and entries on the left. The right panel stays in sync through Turbo updates.</p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Back to resumes", resumes_path, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
      <%= link_to "Preview page", resume_path(@resume), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr] xl:items-start">
    <%= render "editor", resume: @resume %>
    <%= render "preview", resume: @resume %>
  </div>
</section>
