<%= render Ui::SurfaceCardComponent.new(padding: :none, extra_classes: "overflow-hidden") do %>
  <%= form_with model: resume, url: resume_path(resume, **resume_builder_step_params), data: { controller: "autosave", autosave_delay_value: 500, action: "input->autosave#queue change->autosave#queue" }, class: "space-y-6 px-6 py-6" do |form| %>
    <% if resume.errors.any? %>
      <div class="<%= [ ui_inset_panel_classes(tone: :danger), 'text-sm text-rose-700' ].join(' ') %>">
        <%= resume.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="<%= [ ui_inset_panel_classes(tone: :subtle, padding: :lg), 'space-y-5' ].join(' ') %>">
      <div class="space-y-1">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("resumes.editor_personal_details_step.profile_links.eyebrow") %></p>
        <h3 class="text-base font-semibold text-ink-950"><%= t("resumes.editor_personal_details_step.profile_links.title") %></h3>
        <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_personal_details_step.profile_links.description") %></p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
        <div>
          <%= label_tag "resume_contact_details_website", t("resumes.editor_personal_details_step.labels.website"), class: ui_label_classes %>
          <%= url_field_tag "resume[contact_details][website]", resume.contact_field("website"), class: ui_input_classes %>
        </div>

        <div>
          <%= label_tag "resume_contact_details_linkedin", t("resumes.editor_personal_details_step.labels.linkedin"), class: ui_label_classes %>
          <%= url_field_tag "resume[contact_details][linkedin]", resume.contact_field("linkedin"), class: ui_input_classes %>
        </div>

        <div>
          <%= label_tag "resume_contact_details_driving_licence", t("resumes.editor_personal_details_step.labels.driving_licence"), class: ui_label_classes %>
          <%= text_field_tag "resume[contact_details][driving_licence]", resume.contact_field("driving_licence"), class: ui_input_classes %>
        </div>
      </div>
    </div>

    <details class="<%= [ ui_inset_panel_classes(tone: :subtle, padding: :lg) ].join(' ') %>" data-personal-information-disclosure>
      <summary class="flex cursor-pointer items-center gap-3 list-none [&::-webkit-details-marker]:hidden">
        <div class="flex-1 space-y-1">
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("resumes.editor_personal_details_step.personal_information.eyebrow") %></p>
          <h3 class="text-base font-semibold text-ink-950"><%= t("resumes.editor_personal_details_step.personal_information.title") %></h3>
          <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_personal_details_step.personal_information.description") %></p>
        </div>
        <span class="text-ink-400 transition-transform group-open:rotate-180">▾</span>
      </summary>

      <div class="mt-5 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        <div>
          <%= label_tag "resume_personal_details_date_of_birth", t("resumes.editor_personal_details_step.labels.date_of_birth"), class: ui_label_classes %>
          <%= date_field_tag "resume[personal_details][date_of_birth]", resume.personal_detail_field("date_of_birth"), class: ui_input_classes %>
        </div>

        <div>
          <%= label_tag "resume_personal_details_nationality", t("resumes.editor_personal_details_step.labels.nationality"), class: ui_label_classes %>
          <%= text_field_tag "resume[personal_details][nationality]", resume.personal_detail_field("nationality"), class: ui_input_classes %>
        </div>

        <div>
          <%= label_tag "resume_personal_details_marital_status", t("resumes.editor_personal_details_step.labels.marital_status"), class: ui_label_classes %>
          <%= text_field_tag "resume[personal_details][marital_status]", resume.personal_detail_field("marital_status"), class: ui_input_classes %>
        </div>

        <div>
          <%= label_tag "resume_personal_details_visa_status", t("resumes.editor_personal_details_step.labels.visa_status"), class: ui_label_classes %>
          <%= text_field_tag "resume[personal_details][visa_status]", resume.personal_detail_field("visa_status"), class: ui_input_classes %>
        </div>
      </div>
    </details>

    <details class="<%= [ ui_inset_panel_classes(tone: :subtle, padding: :lg) ].join(' ') %>" data-autosave-ignore="true" data-headshot-disclosure>
      <summary class="flex cursor-pointer items-center gap-3 list-none [&::-webkit-details-marker]:hidden">
        <div class="flex-1 space-y-1">
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("resumes.editor_personal_details_step.headshot.eyebrow") %></p>
          <h3 class="text-base font-semibold text-ink-950"><%= t("resumes.editor_personal_details_step.headshot.title") %></h3>
          <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_personal_details_step.headshot.description") %></p>
        </div>
        <span class="text-ink-400 transition-transform group-open:rotate-180">▾</span>
      </summary>

      <div class="mt-5 grid gap-5 xl:grid-cols-[minmax(0,1fr)_18rem] xl:items-start">
        <div>
          <%= form.label :headshot, t("resumes.editor_personal_details_step.headshot.label"), class: ui_label_classes %>
          <%= form.file_field :headshot,
            accept: Resume::HEADSHOT_CONTENT_TYPES.join(","),
            class: ui_input_classes,
            data: { action: "change->autosave#submitNow" } %>
          <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_personal_details_step.headshot.upload_hint") %></p>
        </div>

        <% if resume.headshot.attached? %>
          <div class="<%= [ui_inset_panel_classes(tone: :default), 'space-y-3'].join(' ') %>">
            <div>
              <p class="text-sm font-semibold text-ink-950"><%= t("resumes.editor_personal_details_step.headshot.current_upload_title") %></p>
              <p class="mt-1 break-all text-sm leading-6 text-ink-700/80"><%= resume.headshot.filename.to_s %></p>
            </div>

            <div class="flex flex-wrap gap-2">
              <span class="<%= ui_badge_classes(:neutral) %>"><%= resume.headshot.blob.content_type.presence || t("resumes.editor_personal_details_step.headshot.unknown_type") %></span>
              <span class="<%= ui_badge_classes(:neutral) %>"><%= number_to_human_size(resume.headshot.byte_size) %></span>
              <% if resume.template.normalized_layout_config.fetch("supports_headshot") %>
                <span class="<%= ui_badge_classes(:success) %>"><%= t("resumes.editor_personal_details_step.headshot.template_badges.active") %></span>
              <% else %>
                <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_personal_details_step.headshot.template_badges.fallback") %></span>
              <% end %>
            </div>

            <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_personal_details_step.headshot.remove_hint") %></p>

            <div>
              <%= button_tag t("resumes.editor_personal_details_step.headshot.remove_action"), name: "#{form.object_name}[remove_headshot]", value: true, class: ui_button_classes(:secondary, size: :sm) %>
            </div>
          </div>
        <% end %>
      </div>
    </details>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_personal_details_step.footer_note") %></p>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <% if next_step_path.present? %>
          <%= link_to t("resumes.editor_personal_details_step.optional_step.skip_for_now"), next_step_path, class: ui_button_classes(:secondary) %>
        <% end %>
        <%= form.submit t("resumes.editor_personal_details_step.save_personal_details"), class: ui_button_classes(:primary) %>
      </div>
    </div>

  <% end %>

  <%= render "resumes/photo_library", resume: resume %>
<% end %>
