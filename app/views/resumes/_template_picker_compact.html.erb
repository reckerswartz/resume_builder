<% compact_text_scope = local_assigns.fetch(:compact_text_scope, "resumes.template_picker_compact") %>

<div class="<%= [ui_inset_panel_classes(tone: :subtle), "space-y-4 template-picker-compact-summary"].join(" ") %>">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <span class="atelier-pill">
        <%= render Ui::GlyphComponent.new(name: :spark, size: :xs, tone: :minimal) %>
        <%= t("#{compact_text_scope}.fast_start_pill") %>
      </span>
      <p class="mt-3 text-sm leading-6 text-ink-700/80"><%= t("#{compact_text_scope}.fast_start_description") %></p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <%= link_to t("#{compact_text_scope}.open_marketplace"), templates_path, class: ui_button_classes(:secondary, size: :sm) %>
      <span class="<%= ui_badge_classes(:neutral) %>" data-template-picker-target="resultsLabel"><%= template_picker_state.results_label %></span>
    </div>
  </div>

  <details class="group">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 [&::-webkit-details-marker]:hidden">
      <div class="flex items-center gap-3">
        <span class="text-sm font-semibold tracking-tight text-ink-950"><%= template_picker_state.selected_card_state&.dig(:template)&.name || t("#{compact_text_scope}.fast_start_pill") %></span>
        <% if template_picker_state.has_custom_accent? %>
          <span class="inline-flex items-center gap-1.5">
            <span class="h-3 w-3 rounded-full border border-black/10" style="background-color: <%= template_picker_state.selected_accent_color %>;"></span>
            <span class="text-xs font-medium text-ink-700/80"><%= t("#{compact_text_scope}.accent_carry_through", variant: template_picker_state.selected_accent_variant_label) %></span>
          </span>
        <% end %>
        <span class="<%= ui_badge_classes(:neutral) %>"><%= t("#{compact_text_scope}.preview_selected_badge") %></span>
      </div>
      <span class="text-xs font-medium uppercase tracking-[0.2em] text-ink-700/70"><%= t("#{compact_text_scope}.expand_preview_hint") %></span>
    </summary>

    <div class="mt-4 space-y-4">
      <%= render "resumes/template_picker_summaries",
        template_picker_state: template_picker_state,
        preview_size: :compact,
        wrapper_classes: "grid gap-4" %>

      <% if template_picker_state.recommended_card_states.any? %>
        <div class="<%= [ui_inset_panel_classes(tone: :default), "space-y-3"].join(" ") %>">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :spark, size: :xs, tone: :minimal) %>
              <%= t("#{compact_text_scope}.recommended_pill") %>
            </span>
            <p class="mt-3 text-sm leading-6 text-ink-700/80"><%= t("#{compact_text_scope}.recommended_description") %></p>
          </div>

          <div class="space-y-2">
            <% template_picker_state.recommended_card_states.each do |card_state| %>
              <div class="rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92 px-4 py-3 shadow-[0_14px_30px_rgba(15,23,42,0.05)]">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-semibold tracking-tight text-ink-950"><%= card_state.fetch(:template).name %></p>
                    <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= card_state.fetch(:recommendation_reason) %></p>
                  </div>
                  <span class="<%= ui_badge_classes(:info) %>"><%= card_state.fetch(:recommendation_badge_label) %></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </details>

  <button type="button" class="<%= [ui_inset_panel_classes(tone: :default), "w-full cursor-pointer text-left transition hover:-translate-y-0.5 hover:border-aqua-200/80 hover:bg-canvas-50"].join(" ") %>" data-action="click->template-picker#chooseLater">
    <div class="flex items-start gap-3">
      <%= render Ui::GlyphComponent.new(name: :spark, size: :xs, tone: :minimal) %>
      <div>
        <p class="text-sm font-semibold tracking-tight text-ink-950"><%= t("#{compact_text_scope}.choose_later_pill") %></p>
        <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("#{compact_text_scope}.choose_later_description") %></p>
      </div>
    </div>
  </button>
</div>

<details class="<%= [ui_inset_panel_classes(tone: :default), "group template-picker-disclosure"].join(" ") %>">
  <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-semibold tracking-tight text-ink-950 [&::-webkit-details-marker]:hidden">
    <span><%= t("#{compact_text_scope}.browse_all_templates") %></span>
    <span class="text-xs font-medium uppercase tracking-[0.2em] text-ink-700/70"><%= t("#{compact_text_scope}.browse_all_templates_description") %></span>
  </summary>

  <div class="mt-4">
    <%= render "resumes/template_picker_browser",
      template_picker_state: template_picker_state,
      form: form,
      wrapper_classes: "space-y-4",
      show_results_label: false %>
  </div>
</details>
