<%= render Ui::SurfaceCardComponent.new(padding: :none, extra_classes: "overflow-hidden") do %>
  <%= render Ui::StepHeaderComponent.new(
    title: current_step.fetch(:title),
    description: current_step.fetch(:description),
    aside_classes: "flex flex-wrap gap-2"
  ) do %>
    <%= link_to t("resumes.editor_finalize_step.preview_action"), resume_path(resume, **resume_builder_step_params("finalize")), data: { turbo_frame: "_top" }, class: ui_button_classes(:secondary, size: :sm) %>
    <%= render "resumes/export_actions", resume: resume, context: :finalize, export_actions_state: resume_export_actions_state(resume, context: :finalize) %>
  <% end %>

  <%= form_with model: resume, url: resume_path(resume, **resume_builder_step_params), data: { controller: "autosave", autosave_delay_value: 500, action: "input->autosave#queue change->autosave#queue" }, class: "space-y-6 px-6 py-6" do |form| %>
    <% if resume.errors.any? %>
      <div class="<%= [ ui_inset_panel_classes(tone: :danger), 'text-sm text-rose-700' ].join(' ') %>">
        <%= resume.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-4' ].join(' ') %>">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
            <%= t("resumes.editor_finalize_step.preview_actions.pill") %>
          </span>
          <h4 class="mt-4 text-sm font-semibold text-ink-950"><%= t("resumes.editor_finalize_step.preview_actions.title") %></h4>
        </div>

        <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_finalize_step.preview_actions.badge") %></span>
      </div>

      <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_finalize_step.preview_actions.description") %></p>
    </div>

    <div class="space-y-5">
      <div>
        <%= render "resumes/template_picker",
          form: form,
          resume: resume,
          template_picker_state: resume_template_picker_state(
            resume: resume,
            form_object_name: form.object_name,
            field_label: t("resumes.editor_finalize_step.template_field_label"),
            description: t("resumes.editor_finalize_step.template_picker_description")
          ) %>
      </div>

      <details
        class="rounded-[1.5rem] border border-canvas-200/80 bg-canvas-50/92 px-4 py-4 shadow-[0_16px_36px_rgba(15,23,42,0.06)]"
        data-controller="disclosure"
        data-disclosure-storage-key-value="resume-finalize-output-settings"
        data-action="toggle->disclosure#remember">
        <summary class="cursor-pointer list-none">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-ink-700/70"><%= t("resumes.editor_finalize_step.output_settings.eyebrow") %></p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_finalize_step.output_settings.description") %></p>
            </div>
            <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_finalize_step.output_settings.optional_badge") %></span>
          </div>
        </summary>

        <div class="mt-4 grid gap-5 sm:grid-cols-2">
          <div>
            <%= form.label :slug, t("resumes.editor_finalize_step.output_settings.resume_link"), class: ui_label_classes %>
            <%= form.text_field :slug, class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "resume_settings_page_size", t("resumes.editor_finalize_step.output_settings.page_size"), class: ui_label_classes %>
            <%= select_tag "resume[settings][page_size]", options_for_select([["A4", "A4"], ["Letter", "Letter"]], resume.settings.fetch("page_size", "A4")), class: ui_input_classes %>
          </div>

          <div>
            <%= label_tag "resume_settings_accent_color", t("resumes.editor_finalize_step.output_settings.accent_color"), class: ui_label_classes %>
            <%= color_field_tag "resume[settings][accent_color]", resume.settings.fetch("accent_color", "#0F172A"), class: "#{ui_input_classes} h-12 px-2 py-2" %>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <%= hidden_field_tag "resume[settings][show_contact_icons]", false %>
            <label class="flex items-center justify-between gap-4">
              <span>
                <span class="block <%= ui_label_classes %>"><%= t("resumes.editor_finalize_step.output_settings.show_contact_icons") %></span>
                <span class="mt-1 block text-sm text-ink-700/80"><%= t("resumes.editor_finalize_step.output_settings.show_contact_icons_description") %></span>
              </span>
              <%= check_box_tag "resume[settings][show_contact_icons]", true, resume.settings.fetch("show_contact_icons", true), class: ui_checkbox_classes %>
            </label>
          </div>
        </div>
      </details>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-ink-700/70"><%= t("resumes.editor_finalize_step.footer_note") %></p>
      <%= form.submit t("resumes.editor_finalize_step.save_finalize_settings"), class: ui_button_classes(:primary) %>
    </div>
  <% end %>
<% end %>

<section id="<%= dom_id(resume, :step_sections) %>" class="space-y-4">
  <%= render Ui::SurfaceCardComponent.new(padding: :sm, extra_classes: "overflow-hidden") do %>
    <div class="relative">
      <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>

      <div class="relative space-y-3">
        <span class="atelier-pill">
          <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
          <%= t("resumes.editor_finalize_step.additional_sections.pill") %>
        </span>
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <h3 class="text-xl font-semibold tracking-tight text-ink-950"><%= t("resumes.editor_finalize_step.additional_sections.title") %></h3>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_finalize_step.additional_sections.description") %></p>
          </div>

          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_finalize_step.additional_sections.badge") %></span>
        </div>
      </div>
    </div>
  <% end %>

  <% if step_sections.any? %>
    <div class="space-y-4" data-controller="sortable">
      <% step_sections.each do |section| %>
        <div id="<%= dom_id(section, :sortable_item) %>" data-action="dragstart->sortable#dragstart dragover->sortable#dragover drop->sortable#drop dragend->sortable#dragend" data-sortable-target="item" data-sortable-move-url="<%= move_resume_section_path(resume, section, **resume_builder_step_params) %>" draggable="true">
          <%= render "resumes/section_editor", resume: resume, section: section, allowed_section_types: add_section_types %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render Ui::EmptyStateComponent.new(
      title: t("resumes.editor_finalize_step.empty_state.title"),
      description: t("resumes.editor_finalize_step.empty_state.description")
    ) %>
  <% end %>

  <% if add_section_types.any? %>
    <%= render "resumes/section_form", resume: resume, allowed_section_types: add_section_types %>
  <% end %>
</section>
