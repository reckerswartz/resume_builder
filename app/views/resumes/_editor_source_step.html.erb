<% autofill_enabled = feature_enabled?("autofill_content") && llm_role_enabled?(:text_generation) %>
<% autofill_action_ready = resume_source_autofill_action_ready?(resume, autofill_enabled:) %>
<% autofill_status_label = resume_source_autofill_status_label(resume, autofill_enabled:) %>
<% autofill_status_message = resume_source_autofill_status_message(resume, autofill_enabled:) %>

<%= render Ui::SurfaceCardComponent.new(padding: :none, extra_classes: "overflow-hidden") do %>
  <%= render Ui::StepHeaderComponent.new(
    title: current_step.fetch(:title),
    description: current_step.fetch(:description),
    aside_classes: "grid w-full gap-4 lg:max-w-2xl lg:grid-cols-2"
  ) do %>
      <%= render Ui::WidgetCardComponent.new(
        eyebrow: t("resumes.editor_source_step.import_status.eyebrow"),
        title: autofill_status_label,
        description: autofill_status_message,
        tone: autofill_action_ready ? :success : :subtle,
        padding: :sm
      ) do %>
        <div class="flex flex-wrap gap-2">
          <span class="<%= ui_badge_classes(resume.source_mode == "paste" ? :success : :neutral) %>"><%= t("resumes.editor_source_step.import_status.paste_badge") %></span>
          <span class="<%= ui_badge_classes(resume.source_mode == "upload" ? :success : :neutral) %>"><%= t("resumes.editor_source_step.import_status.upload_badge") %></span>
          <span class="<%= ui_badge_classes(autofill_enabled ? :success : :neutral) %>"><%= autofill_enabled ? t("resumes.editor_source_step.import_status.llm_ready_badge") : t("resumes.editor_source_step.import_status.llm_unavailable_badge") %></span>
        </div>
      <% end %>

      <%= render Ui::WidgetCardComponent.new(
        eyebrow: t("resumes.editor_source_step.supported_formats.eyebrow"),
        title: Resumes::SourceTextResolver.supported_upload_formats_label,
        description: t("resumes.editor_source_step.supported_formats.description"),
        tone: :subtle,
        padding: :sm
      ) do %>
        <div class="flex flex-wrap gap-2">
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_source_step.supported_formats.original_file_badge") %></span>
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_source_step.supported_formats.autofill_badge") %></span>
        </div>
      <% end %>
  <% end %>

  <%= form_with model: resume, url: resume_path(resume, **resume_builder_step_params), data: { controller: "autosave", autosave_delay_value: 500, action: "input->autosave#queue change->autosave#queue" }, class: "space-y-6 px-6 py-6" do |form| %>
    <% if resume.errors.any? %>
      <div class="<%= [ ui_inset_panel_classes(tone: :danger), 'text-sm text-rose-700' ].join(' ') %>">
        <%= resume.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <%= render "resumes/source_import_fields", form: form, resume: resume, autofill_enabled: autofill_enabled %>

    <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-4' ].join(' ') %>">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
            <%= t("resumes.editor_source_step.guidance.pill") %>
          </span>
          <h4 class="mt-4 text-sm font-semibold text-ink-950"><%= t("resumes.editor_source_step.guidance.title") %></h4>
        </div>

        <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_source_step.guidance.badge") %></span>
      </div>

      <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_source_step.guidance.description") %></p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-ink-700/70"><%= autofill_enabled ? t("resumes.editor_source_step.footer_note_ready") : t("resumes.editor_source_step.footer_note_default") %></p>
      <div class="flex flex-wrap gap-3">
        <%= form.submit t("resumes.editor_source_step.save_source_setup"), class: ui_button_classes(:primary) %>
        <% if autofill_enabled %>
          <%= button_tag t("resumes.editor_source_step.save_and_autofill"), name: "run_autofill", value: true, disabled: !autofill_action_ready, class: autofill_action_ready ? ui_button_classes(:warning) : ui_button_classes(:disabled) %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
