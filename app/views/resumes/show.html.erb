<%= turbo_stream_from [@resume, :export] %>

<% show_state = resume_show_state(@resume) %>

<section class="space-y-6">
  <%= render Ui::PageHeaderComponent.new(**show_state.page_header_attributes) %>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_22rem] xl:items-start">
    <%= render Ui::SurfaceCardComponent.new(**show_state.preview_surface_attributes) do %>
      <div class="absolute -right-12 top-6 h-24 w-24 rounded-full atelier-glow opacity-35"></div>
      <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

      <div class="relative space-y-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <span class="atelier-pill">
              <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
              <%= t("resumes.show.preview_pill") %>
            </span>
            <h2 class="mt-4 text-xl font-semibold tracking-tight text-ink-950"><%= t("resumes.show.preview_title") %></h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-ink-700/80"><%= t("resumes.show.preview_description") %></p>
          </div>

          <div class="flex flex-wrap gap-2">
            <% show_state.artifact_badges.each do |badge| %>
              <span class="<%= ui_badge_classes(badge.fetch(:tone, :neutral)) %>"><%= badge.fetch(:label) %></span>
            <% end %>
          </div>
        </div>

        <div class="xl:hidden">
          <%= render Ui::DashboardPanelComponent.new(
            eyebrow: t("resumes.show.mobile_actions.eyebrow"),
            title: t("resumes.show.mobile_actions.title"),
            description: t("resumes.show.mobile_actions.description"),
            padding: :sm,
            density: :compact
          ) do %>
            <div class="space-y-4">
              <%= render "export_actions", resume: @resume, context: :show_mobile, export_actions_state: show_state.export_actions_state %>
              <%= render "export_status_panel", resume: @resume, context: :show_mobile, export_status_state: show_state.export_status_state %>
            </div>
          <% end %>
        </div>

        <div class="relative overflow-hidden rounded-[1.75rem] border border-canvas-200/80 bg-canvas-50/92 p-4 shadow-[0_16px_36px_rgba(15,23,42,0.06)] sm:p-6">
          <div class="absolute -right-12 top-6 h-24 w-24 rounded-full atelier-glow opacity-30"></div>
          <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

          <div class="relative">
            <%= render ResumeTemplates::ComponentResolver.component_for(@resume) %>
          </div>
        </div>
      </div>
    <% end %>

    <aside class="hidden space-y-4 xl:sticky xl:top-6 xl:block">
      <%= render Ui::DashboardPanelComponent.new(
        eyebrow: t("resumes.show.desktop_actions.eyebrow"),
        title: t("resumes.show.desktop_actions.title"),
        description: t("resumes.show.desktop_actions.description"),
        padding: :sm,
        density: :compact
      ) do %>
        <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-4' ].join(' ') %>">
          <div class="space-y-2">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("resumes.show.what_this_shows.eyebrow") %></p>
            <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.show.what_this_shows.description") %></p>
          </div>

          <%= render "export_actions", resume: @resume, context: :show, export_actions_state: show_state.export_actions_state %>
        </div>
      <% end %>

      <%= render "export_status_panel", resume: @resume, context: :show, export_status_state: show_state.export_status_state %>
    </aside>
  </div>
</section>
