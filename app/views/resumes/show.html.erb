<section class="space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Preview</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900"><%= @resume.title %></h1>
      <p class="mt-2 text-sm text-slate-600">Shared rendering used for both on-screen preview and PDF export.</p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit resume", edit_resume_path(@resume), class: "rounded-full bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-700" %>
      <% if @resume.pdf_export.attached? %>
        <%= link_to "Download PDF", download_resume_path(@resume), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
      <% else %>
        <%= button_to "Export PDF", export_resume_path(@resume), method: :post, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
      <% end %>
    </div>
  </div>

  <div class="rounded-[2rem] border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <%= render ResumeTemplates::ComponentResolver.component_for(@resume) %>
  </div>
</section>
