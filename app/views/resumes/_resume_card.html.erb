<article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-slate-500"><%= resume.template.name %></p>
      <h2 class="mt-2 text-xl font-semibold tracking-tight text-slate-900"><%= resume.title %></h2>
      <% if resume.headline.present? %>
        <p class="mt-1 text-sm text-slate-600"><%= resume.headline %></p>
      <% end %>
      <p class="mt-3 text-sm text-slate-500">Updated <%= time_ago_in_words(resume.updated_at) %> ago</p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Edit", edit_resume_path(resume), class: "rounded-full bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-700" %>
      <%= link_to "Preview", resume_path(resume), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
      <%= button_to "Delete", resume_path(resume), method: :delete, class: "rounded-full border border-rose-200 px-4 py-2 text-sm font-medium text-rose-700 transition hover:bg-rose-50" %>
    </div>
  </div>
</article>
