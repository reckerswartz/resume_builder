<%= render Ui::SurfaceCardComponent.new(
  tag: :article,
  padding: :none,
  extra_classes: "group overflow-hidden transition hover:-translate-y-0.5 hover:shadow-[0_24px_52px_rgba(15,23,42,0.1)]"
) do %>
  <div class="border-b border-canvas-200/80 bg-canvas-50/92 px-6 py-5">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <span class="atelier-pill">
          <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
          Resume canvas
        </span>

        <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-ink-700/70">
          <span class="<%= "#{ui_badge_classes(:neutral)} uppercase tracking-[0.18em]" %>"><%= resume.template.name %></span>
          <span class="<%= ui_badge_classes(resume.summary.present? ? :success : :warning) %>"><%= resume.summary.present? ? "Summary ready" : "Needs summary" %></span>
        </div>

        <h2 class="mt-4 text-xl font-semibold tracking-tight text-ink-950"><%= resume.title %></h2>
        <% if resume.headline.present? %>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= resume.headline %></p>
        <% else %>
          <p class="mt-1 text-sm leading-6 text-ink-700/80">Add a headline to make the workspace and exported preview more scannable.</p>
        <% end %>
      </div>

      <div class="flex h-12 w-12 items-center justify-center rounded-[1.25rem] border border-canvas-200/80 bg-canvas-50/92 text-sm font-semibold tracking-[0.18em] text-ink-950 shadow-[0_12px_28px_rgba(15,23,42,0.08)]">
        <%= resume_identity_initials(resume) %>
      </div>
    </div>
  </div>

  <div class="space-y-4 px-6 py-5">
    <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-3' ].join(' ') %>">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70">Preview grouping</p>
          <p class="mt-2 text-sm font-semibold text-ink-950"><%= resume.contact_field("full_name").presence || "Identity details pending" %></p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= resume.summary.present? ? "This draft is ready for a fast preview pass and final export checks." : "Finish the summary and identity details before moving into final preview and export review." %></p>
        </div>

        <span class="<%= ui_badge_classes(:info) %>">Preview + metadata grouped</span>
      </div>

      <div class="flex flex-wrap gap-2 text-xs font-medium text-ink-700/70">
        <span class="<%= ui_badge_classes(:neutral) %>"><%= resume.slug %></span>
        <span class="<%= ui_badge_classes(:neutral) %>">Updated <%= time_ago_in_words(resume.updated_at) %> ago</span>
        <span class="<%= ui_badge_classes(:neutral) %>"><%= resume.source_mode.to_s.humanize %> start</span>
      </div>
    </div>

    <div class="flex flex-col gap-3 border-t border-canvas-200/80 pt-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm leading-6 text-ink-700/80">Jump back into editing, open the preview page, or remove the draft once you no longer need it.</p>

      <div class="flex flex-wrap gap-2">
        <%= link_to "Edit", edit_resume_path(resume), class: ui_button_classes(:primary, size: :sm) %>
        <%= link_to "Preview", resume_path(resume), class: ui_button_classes(:secondary, size: :sm) %>
        <%= button_to "Delete", resume_path(resume), method: :delete, form: { class: "inline-flex" }, class: ui_button_classes(:danger, size: :sm) %>
      </div>
    </div>
  </div>
<% end %>
