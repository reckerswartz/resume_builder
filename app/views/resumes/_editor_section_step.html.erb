<%= render Ui::SurfaceCardComponent.new(padding: :none, extra_classes: "overflow-hidden") do %>
  <%= render Ui::StepHeaderComponent.new(
    title: current_step[:title],
    description: current_step[:description]
  ) do %>
    <%= render Ui::WidgetCardComponent.new(
      eyebrow: "Current step",
      title: "Keep this section focused",
      description: "Only the entries for this step stay visible here so you can edit faster without losing the preview.",
      padding: :sm
    ) do %>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="<%= ui_badge_classes(:neutral) %>"><%= current_step[:label] %></span>
        <span class="<%= ui_badge_classes(:info) %>">Preview stays in sync</span>
        <% if current_step[:key] == "experience" %>
          <%= link_to "Open examples", "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
        <% end %>
        <% if next_step_path.present? %>
          <%= link_to "Next step", next_step_path, class: ui_button_classes(:secondary, size: :sm) %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>

<% if current_step[:key] == "experience" %>
  <%= render Ui::SurfaceCardComponent.new(
    tag: :details,
    padding: :none,
    extra_classes: "overflow-hidden",
    html_options: { id: "experience-step-tips" }
  ) do %>
    <summary class="cursor-pointer border-b border-canvas-200/80 bg-canvas-50/92 px-6 py-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :layers, size: :xs, tone: :minimal) %>
            Experience guidance
          </span>
          <h3 class="mt-4 text-lg font-semibold tracking-tight text-ink-950">Examples that still count</h3>
          <p class="mt-2 text-sm leading-6 text-ink-700/80">Relevant experience can include paid roles, internships, volunteering, teaching help, tutoring, and adjacent project work.</p>
        </div>

        <span class="<%= ui_badge_classes(:neutral) %>">Early-career friendly</span>
      </div>
    </summary>

    <div class="px-6 py-6">
      <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-4' ].join(' ') %>">
        <p class="text-sm leading-6 text-ink-700/80">Use nearby examples when the category feels too narrow. The goal is to show credible work, not to force one job-title pattern.</p>
        <div class="flex flex-wrap gap-2">
          <%= link_to "Internships", "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to "Volunteering", "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to "Teaching assistant", "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to "Tutor", "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>

<section id="<%= dom_id(resume, :step_sections) %>" class="space-y-4">
  <% if step_sections.any? %>
    <div class="space-y-4" data-controller="sortable">
      <% step_sections.each do |section| %>
        <div id="<%= dom_id(section, :sortable_item) %>" data-action="dragstart->sortable#dragstart dragover->sortable#dragover drop->sortable#drop dragend->sortable#dragend" data-sortable-target="item" data-sortable-move-url="<%= move_resume_section_path(resume, section, **resume_builder_step_params) %>" draggable="true">
          <%= render "resumes/section_editor", resume: resume, section: section, allowed_section_types: add_section_types %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render Ui::EmptyStateComponent.new(
      title: "No #{current_step[:label].downcase} entries yet",
      description: "Create the first section for this step and then add your entries below it."
    ) %>
  <% end %>

  <% if add_section_types.any? %>
    <%= render "resumes/section_form", resume: resume, allowed_section_types: add_section_types %>
  <% end %>
</section>
