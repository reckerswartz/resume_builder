<% if current_step[:key] == "experience" %>
  <%= render Ui::SurfaceCardComponent.new(padding: :none, extra_classes: "overflow-hidden") do %>
    <%= render Ui::StepHeaderComponent.new(
      title: current_step[:title],
      description: current_step[:description]
    ) do %>
      <div class="flex flex-wrap items-center gap-2">
        <%= link_to t("resumes.editor_section_step.current_step.open_examples"), "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
      </div>
    <% end %>
  <% end %>
<% end %>

<% if current_step[:key] == "experience" %>
  <%= render Ui::SurfaceCardComponent.new(
    tag: :details,
    padding: :none,
    extra_classes: "overflow-hidden",
    html_options: { id: "experience-step-tips" }
  ) do %>
    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 border-b border-canvas-200/80 bg-canvas-50/92 px-6 py-3 [&::-webkit-details-marker]:hidden">
      <span class="text-sm font-semibold text-ink-950"><%= t("resumes.editor_section_step.experience_guidance.title") %></span>
      <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_section_step.experience_guidance.badge") %></span>
    </summary>

    <div class="px-6 py-6">
      <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-4' ].join(' ') %>">
        <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_section_step.experience_guidance.helper_text") %></p>
        <div class="flex flex-wrap gap-2">
          <%= link_to t("resumes.editor_section_step.experience_guidance.internships"), "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to t("resumes.editor_section_step.experience_guidance.volunteering"), "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to t("resumes.editor_section_step.experience_guidance.teaching_assistant"), "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to t("resumes.editor_section_step.experience_guidance.tutor"), "#experience-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>

<% if current_step[:key] == "skills" %>
  <%= render Ui::SurfaceCardComponent.new(
    tag: :details,
    padding: :none,
    extra_classes: "overflow-hidden",
    html_options: { id: "skills-step-tips" }
  ) do %>
    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 border-b border-canvas-200/80 bg-canvas-50/92 px-6 py-3 [&::-webkit-details-marker]:hidden">
      <span class="text-sm font-semibold text-ink-950"><%= t("resumes.editor_section_step.skills_guidance.title") %></span>
      <span class="<%= ui_badge_classes(:neutral) %>"><%= t("resumes.editor_section_step.skills_guidance.badge") %></span>
    </summary>

    <div class="px-6 py-6">
      <div class="<%= [ ui_inset_panel_classes(tone: :subtle), 'space-y-4' ].join(' ') %>">
        <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.editor_section_step.skills_guidance.helper_text") %></p>
        <div class="flex flex-wrap gap-2">
          <%= link_to t("resumes.editor_section_step.skills_guidance.technical"), "#skills-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to t("resumes.editor_section_step.skills_guidance.analytical"), "#skills-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to t("resumes.editor_section_step.skills_guidance.leadership"), "#skills-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
          <%= link_to t("resumes.editor_section_step.skills_guidance.communication"), "#skills-step-tips", class: ui_button_classes(:secondary, size: :sm) %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>

<section id="<%= dom_id(resume, :step_sections) %>" class="space-y-4">
  <% if step_sections.any? %>
    <div class="space-y-4" data-controller="sortable">
      <% step_sections.each do |section| %>
        <div id="<%= dom_id(section, :sortable_item) %>" data-action="dragstart->sortable#dragstart dragover->sortable#dragover drop->sortable#drop dragend->sortable#dragend" data-sortable-target="item" data-sortable-move-url="<%= move_resume_section_path(resume, section, **resume_builder_step_params) %>" draggable="true">
          <%= render "resumes/section_editor", resume: resume, section: section, allowed_section_types: add_section_types, show_section_type_badge: false, hide_redundant_title: true, collapse_section_actions: true %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render Ui::EmptyStateComponent.new(
      title: t("resumes.editor_section_step.empty_state.title", step: current_step[:label].downcase),
      description: t("resumes.editor_section_step.empty_state.description")
    ) %>
  <% end %>

  <% if add_section_types.any? %>
    <%= render "resumes/section_form", resume: resume, allowed_section_types: add_section_types, open: step_sections.empty? %>
  <% end %>
</section>
