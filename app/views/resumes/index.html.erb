<section class="space-y-8">
  <div class="flex flex-col gap-4 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Your workspace</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-900">Resumes</h1>
      <p class="mt-2 text-sm text-slate-600">Create a new resume or continue editing an existing one with live preview and PDF export.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Create new resume", new_resume_path, class: "rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-700" %>
      <% if current_user.admin? %>
        <%= link_to "Open admin", admin_root_path, class: "rounded-full border border-slate-300 px-5 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-400 hover:text-slate-900" %>
      <% end %>
    </div>
  </div>

  <% if @resumes.any? %>
    <div class="grid gap-5 xl:grid-cols-2">
      <% @resumes.each do |resume| %>
        <%= render "resume_card", resume: resume %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white px-6 py-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-slate-900">No resumes yet</h2>
      <p class="mt-2 text-sm text-slate-600">Create your first resume to start editing and previewing live.</p>
      <%= link_to "Create resume", new_resume_path, class: "mt-5 inline-flex rounded-full bg-slate-900 px-5 py-3 text-sm font-medium text-white transition hover:bg-slate-700" %>
    </div>
  <% end %>
</section>
