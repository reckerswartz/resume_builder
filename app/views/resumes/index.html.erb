<% resume_count = @resumes.size %>
<% ready_count = @resumes.count { |resume| resume.summary.present? && resume.contact_field("email").present? } %>
<% draft_count = resume_count - ready_count %>
<% page_header_actions = [
  { label: t("resumes.index.actions.create_new_resume"), path: new_resume_path, style: :primary },
  { label: t("resumes.index.actions.browse_templates"), path: templates_path, style: :secondary },
  (current_user.admin? ? { label: t("resumes.index.actions.open_admin"), path: admin_root_path, style: :secondary } : nil)
].compact %>
<% quick_actions_state = if resume_count.positive? && draft_count.zero?
     {
       eyebrow: t("resumes.index.quick_actions.review_ready.eyebrow"),
       title: t("resumes.index.quick_actions.review_ready.title"),
       description: t("resumes.index.quick_actions.review_ready.description"),
       counts_summary: t("resumes.index.quick_actions.review_ready.counts_summary", count: ready_count),
       focus_note: t("resumes.index.quick_actions.review_ready.focus_note"),
       action: nil
     }
   else
     {
       eyebrow: t("resumes.index.quick_actions.eyebrow"),
       title: t("resumes.index.quick_actions.title"),
       description: t("resumes.index.quick_actions.description"),
       counts_summary: t("resumes.index.quick_actions.counts_summary", ready_count:, draft_count:),
       focus_note: t("resumes.index.quick_actions.focus_note"),
       action: { label: t("resumes.index.quick_actions.create_resume"), path: new_resume_path }
     }
   end %>

<section class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem]">
  <div class="space-y-6">
    <%= render Ui::PageHeaderComponent.new(
      eyebrow: t("resumes.index.header_eyebrow"),
      title: t("resumes.index.header_title"),
      description: t("resumes.index.header_description"),
      badges: [
        { label: t("resumes.index.badges.resume_count", count: resume_count), tone: :neutral },
        { label: t("resumes.index.badges.ready_to_review", count: ready_count), tone: :neutral }
      ],
      actions: page_header_actions,
      density: :compact
    ) %>

    <% if @resumes.size == 1 && current_user.created_at > 1.hour.ago %>
      <%= render Ui::SurfaceCardComponent.new(tone: :default, padding: :sm, extra_classes: "relative overflow-hidden") do %>
        <div class="absolute -right-10 top-6 h-28 w-28 rounded-full atelier-glow opacity-55"></div>
        <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>
        <div class="relative space-y-4 p-1" data-testid="welcome-card">
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :spark, size: :xs, tone: :minimal) %>
            <%= t("resumes.index.welcome.pill") %>
          </span>
          <h2 class="font-serif text-xl font-semibold tracking-[-0.03em] text-ink-950"><%= t("resumes.index.welcome.title") %></h2>
          <p class="text-sm leading-6 text-ink-700/80"><%= t("resumes.index.welcome.description") %></p>
          <%= link_to t("resumes.index.welcome.action"), edit_resume_path(@resumes.first, step: :heading), class: "#{ui_button_classes(:primary)} inline-flex" %>
        </div>
      <% end %>
    <% end %>

    <% if @resumes.any? %>
      <div class="grid gap-5 xl:grid-cols-2">
        <% @resumes.each do |resume| %>
          <%= render "resume_card", resume: resume %>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::EmptyStateComponent.new(
        title: t("resumes.index.empty_state.title"),
        description: t("resumes.index.empty_state.description"),
        action_label: t("resumes.index.empty_state.create_resume"),
        action_path: new_resume_path,
        padding: :lg,
        title_size: :lg
      ) %>
    <% end %>
  </div>

  <aside class="space-y-4 xl:sticky xl:top-6">
    <%= render Ui::DashboardPanelComponent.new(
      eyebrow: quick_actions_state.fetch(:eyebrow),
      title: quick_actions_state.fetch(:title),
      description: quick_actions_state.fetch(:description),
      padding: :sm,
      density: :compact
    ) do %>
      <div class="space-y-3">
        <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
          <p class="text-sm font-semibold text-ink-950"><%= quick_actions_state.fetch(:counts_summary) %></p>
          <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= quick_actions_state.fetch(:focus_note) %></p>
        </div>

        <% if (quick_action = quick_actions_state[:action]) %>
          <div class="flex flex-col gap-2 text-sm">
            <%= link_to quick_action.fetch(:label), quick_action.fetch(:path), class: "#{ui_button_classes(:primary)} w-full justify-center" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </aside>
</section>
