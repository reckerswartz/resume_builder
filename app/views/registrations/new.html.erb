<div class="mx-auto grid w-full max-w-4xl gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
  <div class="space-y-4">
    <%= render Ui::PageHeaderComponent.new(
      eyebrow: t("registrations.new.page_header.eyebrow"),
      title: t("registrations.new.page_header.title"),
      description: t("registrations.new.page_header.description"),
      badges: [
        { label: t("registrations.new.page_header.badges.starter_draft"), tone: :neutral },
        { label: t("registrations.new.page_header.badges.live_preview"), tone: :neutral }
      ],
      density: :compact
    ) %>

    <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :sm) do %>
      <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>
      <div class="relative space-y-3">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-ink-700/70"><%= t("registrations.new.included_eyebrow") %></p>

        <%= render "shared/glyph_inset_card", glyph: :preview, title: t("registrations.new.starter_draft.title"), description: t("registrations.new.starter_draft.description") %>

        <%= render "shared/glyph_inset_card", glyph: :layers, title: t("registrations.new.change_layouts.title"), description: t("registrations.new.change_layouts.description") %>
      </div>
    <% end %>
  </div>

  <%= render Ui::SurfaceCardComponent.new(padding: :lg, extra_classes: "relative") do %>
    <div class="absolute -right-8 top-6 h-24 w-24 rounded-full atelier-glow opacity-45"></div>
    <div class="absolute inset-x-6 top-0 h-px atelier-rule-ink opacity-70"></div>

    <div class="relative mb-6">
      <span class="atelier-pill">
        <%= render Ui::GlyphComponent.new(name: :swatches, size: :xs, tone: :minimal) %>
        <%= t("registrations.new.form.pill") %>
      </span>
      <h2 class="mt-4 font-serif text-3xl font-semibold tracking-[-0.03em] text-ink-950"><%= t("registrations.new.form.title") %></h2>
      <p class="mt-3 text-sm leading-6 text-ink-700/80"><%= t("registrations.new.form.description") %></p>
    </div>

    <%= form_with model: @user, url: registration_path, class: "relative space-y-5" do |form| %>
      <% if @selected_template.present? %>
        <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'space-y-3'].join(' ') %>" data-selected-template-summary>
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70"><%= t("registrations.new.selected_template.eyebrow") %></p>
              <p class="mt-2 text-sm font-semibold text-ink-950"><%= t("registrations.new.selected_template.title", template: @selected_template.name) %></p>
              <p class="mt-1 text-sm leading-6 text-ink-700/80"><%= t("registrations.new.selected_template.description") %></p>
            </div>

            <span class="<%= ui_badge_classes(:neutral) %>"><%= t("registrations.new.selected_template.badge") %></span>
          </div>

          <% if @selected_template_accent_color.present? %>
            <div class="flex items-center gap-3">
              <span class="h-4 w-4 rounded-full border border-black/10" style="background-color: <%= @selected_template_accent_color %>;"></span>
              <p class="text-sm leading-6 text-ink-700/80"><%= t("registrations.new.selected_template.accent_description") %></p>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @user.errors.any? %>
        <div class="<%= ui_inset_panel_classes(tone: :danger) %>">
          <p class="text-sm text-rose-700"><%= @user.errors.full_messages.to_sentence %></p>
        </div>
      <% end %>

      <% if @selected_template.present? %>
        <%= hidden_field_tag :template_id, @selected_template.id %>
      <% end %>
      <% @starter_resume_intake_details.to_h.each do |key, value| %>
        <%= hidden_field_tag "resume[intake_details][#{key}]", value %>
      <% end %>
      <% if @selected_template_accent_color.present? %>
        <%= hidden_field_tag "resume[settings][accent_color]", @selected_template_accent_color %>
      <% end %>

      <div>
        <%= form.label :email_address, class: ui_label_classes %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", class: ui_input_classes %>
      </div>

      <div data-controller="password-field">
        <%= form.label :password, class: ui_label_classes %>
        <div class="relative mt-2">
          <%= form.password_field :password,
            required: true,
            autocomplete: "new-password",
            maxlength: 72,
            class: "#{ui_input_classes.delete_prefix("mt-2 ")} pr-20",
            data: {
              password_field_target: "input",
              action: "keyup->password-field#updateCapsState keydown->password-field#updateCapsState blur->password-field#hideCapsHint"
            } %>
          <button
            type="button"
            aria-label="<%= t("registrations.new.form.toggle_password_visibility") %>"
            class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-medium text-ink-700 transition hover:text-ink-950"
            data-action="password-field#toggle"
            data-password-field-target="toggle"></button>
        </div>
        <p class="mt-2 hidden text-sm text-amber-700" data-password-field-target="capsHint"><%= t("registrations.new.form.caps_lock_hint") %></p>
      </div>

      <div data-controller="password-field">
        <%= form.label :password_confirmation, class: ui_label_classes %>
        <div class="relative mt-2">
          <%= form.password_field :password_confirmation,
            required: true,
            autocomplete: "new-password",
            maxlength: 72,
            class: "#{ui_input_classes.delete_prefix("mt-2 ")} pr-20",
            data: {
              password_field_target: "input",
              action: "keyup->password-field#updateCapsState keydown->password-field#updateCapsState blur->password-field#hideCapsHint"
            } %>
          <button
            type="button"
            aria-label="<%= t("registrations.new.form.toggle_password_visibility") %>"
            class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-medium text-ink-700 transition hover:text-ink-950"
            data-action="password-field#toggle"
            data-password-field-target="toggle"></button>
        </div>
        <p class="mt-2 hidden text-sm text-amber-700" data-password-field-target="capsHint"><%= t("registrations.new.form.caps_lock_hint") %></p>
      </div>

      <div class="<%= [ui_inset_panel_classes(tone: :subtle), 'space-y-3'].join(' ') %>">
        <p class="text-sm font-semibold text-ink-950"><%= t("registrations.new.form.what_you_get_title") %></p>
        <p class="text-sm leading-6 text-ink-700/80"><%= t("registrations.new.form.what_you_get_description") %></p>
        <div class="flex flex-wrap gap-2">
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("registrations.new.form.badges.starter_draft_included") %></span>
          <span class="<%= ui_badge_classes(:neutral) %>"><%= t("registrations.new.form.badges.switch_templates_later") %></span>
        </div>
      </div>

      <div class="space-y-3">
        <%= form.submit t("registrations.new.form.submit"), class: "#{ui_button_classes(:primary)} w-full sm:w-auto" %>
        <p class="text-sm leading-6 text-ink-700/70"><%= t("registrations.new.form.already_have_account") %> <%= link_to t("registrations.new.form.sign_in"), new_session_path, class: ui_button_classes(:ghost) %></p>
      </div>
    <% end %>
  <% end %>
</div>
