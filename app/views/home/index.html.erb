<section class="space-y-6">
  <%= render Ui::HeroHeaderComponent.new(
    eyebrow: "Resume builder",
    title: "Build a polished resume faster.",
    description: "Start from scratch or bring in an existing resume, then keep the preview in view while you refine each section.",
    badges: [
      { label: "Guided steps", tone: :hero },
      { label: "Live preview", tone: :hero },
      { label: "PDF export", tone: :hero }
    ],
    actions: [
      { label: "Create account", path: new_registration_path, style: :hero_primary },
      { label: "Sign in", path: new_session_path, style: :hero_secondary }
    ]
  ) %>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem] xl:items-start">
    <%= render Ui::SurfaceCardComponent.new(tone: :default, padding: :sm, extra_classes: "relative overflow-hidden") do %>
      <div class="absolute -right-10 top-6 h-28 w-28 rounded-full atelier-glow opacity-55"></div>
      <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>

      <div class="relative space-y-5 p-1">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
            See how it works
          </span>
          <h2 class="mt-3 font-serif text-2xl font-semibold tracking-[-0.03em] text-ink-950">One workspace from first draft to export</h2>
          <p class="mt-2 text-sm leading-6 text-ink-700/80">Keep your content, preview, and layout decisions together so you can move faster without juggling extra tools.</p>
        </div>

        <div class="atelier-panel-dark p-5">
          <div class="absolute left-5 right-5 top-16 h-px atelier-rule opacity-60"></div>

          <div class="relative flex items-start justify-between gap-4">
            <div>
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/55">Preview snapshot</p>
              <h3 class="mt-3 text-2xl font-semibold tracking-tight text-white">Alex Morgan</h3>
              <p class="mt-1 text-sm text-white/65">Senior Product Designer</p>
            </div>
            <span class="<%= ui_badge_classes(:hero) %>">Preview updates live</span>
          </div>

          <div class="relative mt-6 space-y-3 text-sm text-white/72">
            <div class="rounded-[1.35rem] border border-white/10 bg-white/6 p-4">
              <p class="font-medium text-white">Summary</p>
              <p class="mt-2">Product designer with 8 years of experience turning complex workflows into simple, high-converting product journeys.</p>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-[1.35rem] border border-white/10 bg-white/6 p-4">
                <p class="font-medium text-white">Experience</p>
                <p class="mt-2">Led redesigns that improved conversion and reduced time to complete core tasks.</p>
              </div>

              <div class="rounded-[1.35rem] border border-white/10 bg-white/6 p-4">
                <p class="font-medium text-white">Skills</p>
                <p class="mt-2">Product strategy, UX writing, design systems, stakeholder alignment</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
      <%= render Ui::DashboardPanelComponent.new(
        eyebrow: "Start here",
        title: "Three simple ways to begin",
        description: "Choose the lightest path for your situation and leave the rest for later.",
        padding: :sm,
        density: :compact
      ) do %>
        <div class="space-y-3">
          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <div class="flex items-start gap-3">
              <%= render Ui::GlyphComponent.new(name: :spark, size: :sm, tone: :soft) %>
              <div>
                <p class="text-sm font-semibold text-ink-950">Start from scratch</p>
                <p class="mt-1 text-sm leading-6 text-ink-700/80">Open a starter draft and work through the guided steps one section at a time.</p>
              </div>
            </div>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <div class="flex items-start gap-3">
              <%= render Ui::GlyphComponent.new(name: :layers, size: :sm, tone: :soft) %>
              <div>
                <p class="text-sm font-semibold text-ink-950">Bring an existing resume</p>
                <p class="mt-1 text-sm leading-6 text-ink-700/80">Paste or upload the resume you already have and reshape it inside the builder.</p>
              </div>
            </div>
          </div>

          <div class="<%= ui_inset_panel_classes(tone: :subtle) %>">
            <div class="flex items-start gap-3">
              <%= render Ui::GlyphComponent.new(name: :preview, size: :sm, tone: :soft) %>
              <div>
                <p class="text-sm font-semibold text-ink-950">Keep the preview in view</p>
                <p class="mt-1 text-sm leading-6 text-ink-700/80">Edit content and watch the layout update before you export the final PDF.</p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </aside>
  </div>

  <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :md) do %>
    <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start">
      <div>
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-ink-700/70">Common questions</p>
        <dl class="mt-4 space-y-4">
          <div>
            <dt class="text-sm font-semibold text-ink-950">Do I need design experience?</dt>
            <dd class="mt-1 text-sm leading-6 text-ink-700/80">No. Choose a template, fill in the sections, and adjust the presentation later if you want to.</dd>
          </div>

          <div>
            <dt class="text-sm font-semibold text-ink-950">Can I switch templates later?</dt>
            <dd class="mt-1 text-sm leading-6 text-ink-700/80">Yes. Your content stays reusable, so changing layouts does not mean starting over.</dd>
          </div>

          <div>
            <dt class="text-sm font-semibold text-ink-950">Can I start from an existing resume?</dt>
            <dd class="mt-1 text-sm leading-6 text-ink-700/80">Yes. After you create your workspace, you can paste text or attach a file before moving into the guided editor.</dd>
          </div>
        </dl>
      </div>

      <div class="<%= ui_inset_panel_classes(tone: :default) %>">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-ink-700/70">Quick reassurance</p>
        <ul class="mt-3 space-y-3 text-sm leading-6 text-ink-700/80">
          <li>No design tools or formatting knowledge required.</li>
          <li>Keep one version of your content and reuse it across templates.</li>
          <li>Export when the preview looks right.</li>
        </ul>
      </div>
    </div>
  <% end %>
</section>
