<section class="space-y-6">
  <%= render Ui::HeroHeaderComponent.new(
    eyebrow: t("home.index.hero.eyebrow"),
    title: t("home.index.hero.title"),
    description: t("home.index.hero.description"),
    badges: [
      { label: t("home.index.hero.badges.guided_steps"), tone: :hero },
      { label: t("home.index.hero.badges.live_preview"), tone: :hero },
      { label: t("home.index.hero.badges.pdf_export"), tone: :hero }
    ],
    actions: [
      { label: t("home.index.hero.actions.create_account"), path: new_registration_path, style: :hero_primary },
      { label: t("home.index.hero.actions.sign_in"), path: new_session_path, style: :hero_secondary }
    ]
  ) %>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem] xl:items-start">
    <%= render Ui::SurfaceCardComponent.new(tone: :default, padding: :sm, extra_classes: "relative overflow-hidden") do %>
      <div class="absolute -right-10 top-6 h-28 w-28 rounded-full atelier-glow opacity-55"></div>
      <div class="absolute inset-x-5 top-0 h-px atelier-rule-ink opacity-70"></div>

      <div class="relative space-y-5 p-1">
        <div>
          <span class="atelier-pill">
            <%= render Ui::GlyphComponent.new(name: :preview, size: :xs, tone: :minimal) %>
            <%= t("home.index.preview_panel.pill") %>
          </span>
          <h2 class="mt-3 font-serif text-2xl font-semibold tracking-[-0.03em] text-ink-950"><%= t("home.index.preview_panel.title") %></h2>
          <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("home.index.preview_panel.description") %></p>
        </div>

        <div class="atelier-panel-dark p-5">
          <div class="absolute left-5 right-5 top-16 h-px atelier-rule opacity-60"></div>

          <div class="relative flex items-start justify-between gap-4">
            <div>
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/55"><%= t("home.index.preview_panel.snapshot_label") %></p>
              <h3 class="mt-3 text-2xl font-semibold tracking-tight text-white"><%= t("home.index.preview_panel.sample_name") %></h3>
              <p class="mt-1 text-sm text-white/65"><%= t("home.index.preview_panel.sample_role") %></p>
            </div>
            <span class="<%= ui_badge_classes(:hero) %>"><%= t("home.index.preview_panel.live_badge") %></span>
          </div>

          <div class="relative mt-6 space-y-3 text-sm text-white/72">
            <div class="atelier-dark-inset">
              <p class="font-medium text-white"><%= t("home.index.preview_panel.summary_label") %></p>
              <p class="mt-2"><%= t("home.index.preview_panel.summary_text") %></p>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="atelier-dark-inset">
                <p class="font-medium text-white"><%= t("home.index.preview_panel.experience_label") %></p>
                <p class="mt-2"><%= t("home.index.preview_panel.experience_text") %></p>
              </div>

              <div class="atelier-dark-inset">
                <p class="font-medium text-white"><%= t("home.index.preview_panel.skills_label") %></p>
                <p class="mt-2"><%= t("home.index.preview_panel.skills_text") %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <aside class="space-y-4 xl:sticky xl:top-6 xl:self-start">
      <%= render Ui::DashboardPanelComponent.new(
        eyebrow: t("home.index.start_here.eyebrow"),
        title: t("home.index.start_here.title"),
        description: t("home.index.start_here.description"),
        padding: :sm,
        density: :compact
      ) do %>
        <div class="space-y-3">
          <%= render "shared/glyph_inset_card", glyph: :spark, title: t("home.index.start_here.cards.scratch.title"), description: t("home.index.start_here.cards.scratch.description"), href: new_registration_path %>

          <%= render "shared/glyph_inset_card", glyph: :layers, title: t("home.index.start_here.cards.existing_resume.title"), description: t("home.index.start_here.cards.existing_resume.description"), href: new_registration_path %>

          <%= render "shared/glyph_inset_card", glyph: :preview, title: t("home.index.start_here.cards.keep_preview.title"), description: t("home.index.start_here.cards.keep_preview.description"), href: new_registration_path %>
        </div>
      <% end %>
    </aside>
  </div>

  <%= render Ui::SurfaceCardComponent.new(tone: :subtle, padding: :md) do %>
    <div>
      <span class="atelier-pill">
        <%= render Ui::GlyphComponent.new(name: :spark, size: :xs, tone: :minimal) %>
        <%= t("home.index.common_questions.pill") %>
      </span>
      <h2 class="mt-4 text-lg font-semibold tracking-tight text-ink-950"><%= t("home.index.common_questions.title") %></h2>
      <p class="mt-2 text-sm leading-6 text-ink-700/80"><%= t("home.index.common_questions.description") %></p>

      <div class="mt-4 space-y-3">
        <%= render "shared/glyph_inset_card", glyph: :preview, title: t("home.index.common_questions.questions.design_experience.title"), description: t("home.index.common_questions.questions.design_experience.description") %>

        <%= render "shared/glyph_inset_card", glyph: :layers, title: t("home.index.common_questions.questions.switch_templates.title"), description: t("home.index.common_questions.questions.switch_templates.description") %>

        <%= render "shared/glyph_inset_card", glyph: :spark, title: t("home.index.common_questions.questions.existing_resume.title"), description: t("home.index.common_questions.questions.existing_resume.description") %>
      </div>
    </div>
  <% end %>
</section>
