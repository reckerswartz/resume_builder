{
  "name": "resume_builder",
  "private": true,
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "esbuild app/javascript/application.js --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --asset-names=[name]-[hash].digested --loader:.css=css --loader:.eot=file --loader:.gif=file --loader:.jpeg=file --loader:.jpg=file --loader:.png=file --loader:.svg=file --loader:.ttf=file --loader:.webp=file --loader:.woff=file --loader:.woff2=file",
    "watch:js": "npm run build:js -- --watch",
    "build:css": "npx @tailwindcss/cli -i ./app/assets/tailwind/application.css -o ./app/assets/builds/app.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./app/assets/tailwind/application.css -o ./app/assets/builds/app.css --watch"
  },
  "dependencies": {
    "@hotwired/stimulus": "3.2.2",
    "@hotwired/turbo-rails": "8.0.23"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "esbuild": "0.21.5",
    "tailwindcss": "^4.0.0"
  }
}
