{
  "name": "resume_builder",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "yarn build:js && yarn build:css",
    "build:js": "webpack --config webpack.config.js --mode production",
    "watch:js": "webpack --config webpack.config.js --watch --mode development",
    "build:css": "tailwindcss -i ./app/assets/tailwind/application.css -o ./app/assets/builds/app.css --minify",
    "watch:css": "tailwindcss -i ./app/assets/tailwind/application.css -o ./app/assets/builds/app.css --watch"
  },
  "dependencies": {
    "@hotwired/stimulus": "3.2.2",
    "@hotwired/turbo-rails": "8.0.23"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "tailwindcss": "4.2.2",
    "webpack": "5.105.4",
    "webpack-cli": "6.0.1"
  }
}
